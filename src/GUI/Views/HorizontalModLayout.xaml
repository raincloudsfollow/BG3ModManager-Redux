<local:HorizontalModLayoutBase x:Class="DivinityModManager.Views.HorizontalModLayout"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
	xmlns:adonisUI="clr-namespace:AdonisUI;assembly=AdonisUI"
	xmlns:behavior="clr-namespace:DivinityModManager.Controls.Behavior"
	xmlns:c="clr-namespace:DivinityModManager.Controls"
	xmlns:conv="clr-namespace:DivinityModManager.Converters"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:data="clr-namespace:DivinityModManager.Models;assembly=DivinityModManagerCore"
	xmlns:dapp="clr-namespace:DivinityModManager;assembly=DivinityModManagerCore"
	xmlns:dd="urn:gong-wpf-dragdrop"
	xmlns:local="clr-namespace:DivinityModManager.Views"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:reactiveui="clr-namespace:ReactiveUI;assembly=ReactiveUI"
	xmlns:vm="clr-namespace:DivinityModManager.ViewModels"
	x:Name="HorizontalModLayoutView"
	d:DesignHeight="450"
	d:DesignWidth="800"
	mc:Ignorable="d">
	<UserControl.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="../Themes/MainResourceDictionary.xaml" />
			</ResourceDictionary.MergedDictionaries>
			<conv:ModDetailsMediaWidthConverter x:Key="ModDetailsMediaWidthConverter" />
			<conv:NexusDescriptionToPlainTextConverter x:Key="NexusDescriptionToPlainTextConverter" />
			<Style x:Key="ListViewItemMouseEvents" BasedOn="{StaticResource DivinityModDataListItem}" TargetType="{x:Type ListViewItem}">
				<!--<EventSetter Event="PreviewMouseLeftButtonDown" Handler="ListViewItem_ModifySelection" />-->
			</Style>
			<Style x:Key="ModOrderListViewWithDrag" BasedOn="{StaticResource ModOrderListView}" TargetType="ListView">
				<Setter Property="dd:DragDrop.DragDirectlySelectedOnly" Value="True" />
				<Setter Property="dd:DragDrop.IsDragSource" Value="True" />
				<Setter Property="dd:DragDrop.IsDropTarget" Value="True" />
				<Setter Property="dd:DragDrop.DropTargetAdornerBrush" Value="{DynamicResource ReduxAccentBrush}" />
				<Setter Property="dd:DragDrop.DropTargetAdornerPen">
					<Setter.Value>
						<Pen Brush="{DynamicResource ReduxAccentBrush}" Thickness="2" />
					</Setter.Value>
				</Setter>
			</Style>
			<Style x:Key="ModSectionCard" TargetType="{x:Type Border}">
				<Setter Property="Background" Value="{DynamicResource ReduxSurfaceBrush}" />
				<Setter Property="BorderBrush" Value="{DynamicResource ReduxBorderBrush}" />
				<Setter Property="BorderThickness" Value="1" />
				<Setter Property="CornerRadius" Value="8" />
				<Setter Property="ClipToBounds" Value="True" />
			</Style>
			<Style x:Key="ModSectionTitle" BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="{x:Type TextBlock}">
				<Setter Property="FontSize" Value="14" />
				<Setter Property="FontWeight" Value="SemiBold" />
			</Style>
			<Style x:Key="ModCategoryListItemStyle" TargetType="{x:Type ListBoxItem}">
				<Setter Property="Margin" Value="0,1" />
				<Setter Property="Padding" Value="10,7" />
				<Setter Property="Background" Value="Transparent" />
				<Setter Property="BorderBrush" Value="Transparent" />
				<Setter Property="BorderThickness" Value="1" />
				<Setter Property="Cursor" Value="Hand" />
				<Setter Property="FocusVisualStyle" Value="{x:Null}" />
				<Setter Property="HorizontalContentAlignment" Value="Stretch" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type ListBoxItem}">
							<Border x:Name="CategorySurface"
								Background="{TemplateBinding Background}"
								BorderBrush="{TemplateBinding BorderBrush}"
								BorderThickness="{TemplateBinding BorderThickness}"
								CornerRadius="{DynamicResource Redux.CornerRadius.Control}">
								<Grid>
									<Border x:Name="CategoryHoverSurface"
										Background="{Binding SoftColor}"
										BorderBrush="{Binding Color}"
										BorderThickness="1"
										CornerRadius="{DynamicResource Redux.CornerRadius.ControlInner}"
										IsHitTestVisible="False"
										Opacity="0" />
									<ContentPresenter Margin="{TemplateBinding Padding}" />
								</Grid>
							</Border>
							<ControlTemplate.Triggers>
								<MultiTrigger>
									<MultiTrigger.Conditions>
										<Condition Property="IsMouseOver" Value="True" />
										<Condition Property="IsSelected" Value="False" />
									</MultiTrigger.Conditions>
									<MultiTrigger.EnterActions>
										<BeginStoryboard>
											<Storyboard>
												<DoubleAnimation Storyboard.TargetName="CategoryHoverSurface"
													Storyboard.TargetProperty="Opacity"
													To="1"
													Duration="{StaticResource Redux.Motion.Fast}"
													EasingFunction="{StaticResource Redux.Motion.EaseOut}" />
											</Storyboard>
										</BeginStoryboard>
									</MultiTrigger.EnterActions>
									<MultiTrigger.ExitActions>
										<BeginStoryboard>
											<Storyboard>
												<DoubleAnimation Storyboard.TargetName="CategoryHoverSurface"
													Storyboard.TargetProperty="Opacity"
													To="0"
													Duration="{StaticResource Redux.Motion.Standard}" />
											</Storyboard>
										</BeginStoryboard>
									</MultiTrigger.ExitActions>
								</MultiTrigger>
								<Trigger Property="IsSelected" Value="True">
									<Setter TargetName="CategorySurface" Property="Background" Value="{Binding SoftColor}" />
									<Setter TargetName="CategorySurface" Property="BorderBrush" Value="{Binding Color}" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style x:Key="ModDetailsToggleStyle" TargetType="{x:Type ToggleButton}">
				<Setter Property="Width" Value="30" />
				<Setter Property="Height" Value="28" />
				<Setter Property="Background" Value="Transparent" />
				<Setter Property="BorderThickness" Value="0" />
				<Setter Property="Cursor" Value="Hand" />
				<Setter Property="FocusVisualStyle" Value="{x:Null}" />
				<Setter Property="Foreground" Value="{DynamicResource ReduxTextSecondaryBrush}" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type ToggleButton}">
							<Border x:Name="ToggleSurface" Padding="6,2" Background="Transparent" CornerRadius="{DynamicResource Redux.CornerRadius.Small}">
								<Path x:Name="ToggleGlyph"
									Width="12" Height="7"
									Data="M 0,7 L 6,1 L 12,7"
									Stroke="{TemplateBinding Foreground}"
									StrokeEndLineCap="Round"
									StrokeLineJoin="Round"
									StrokeStartLineCap="Round"
									StrokeThickness="1.5"
									Stretch="Fill" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger Property="IsChecked" Value="False">
									<Setter TargetName="ToggleGlyph" Property="Data" Value="M 0,1 L 6,7 L 12,1" />
								</Trigger>
								<Trigger Property="IsMouseOver" Value="True">
									<Setter TargetName="ToggleSurface" Property="Background" Value="{DynamicResource ReduxAccentSoftBrush}" />
									<Setter Property="Foreground" Value="{DynamicResource ReduxAccentHoverBrush}" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style x:Key="CategoryPanelToggleStyle" TargetType="{x:Type ToggleButton}">
				<Setter Property="Background" Value="Transparent" />
				<Setter Property="BorderThickness" Value="0" />
				<Setter Property="Cursor" Value="Hand" />
				<Setter Property="FocusVisualStyle" Value="{x:Null}" />
				<Setter Property="Foreground" Value="{DynamicResource ReduxTextSecondaryBrush}" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type ToggleButton}">
							<Border x:Name="ToggleSurface" Padding="6,2" Background="Transparent" CornerRadius="{DynamicResource Redux.CornerRadius.Small}">
								<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger Property="IsMouseOver" Value="True">
									<Setter TargetName="ToggleSurface" Property="Background" Value="{DynamicResource ReduxAccentSoftBrush}" />
									<Setter Property="Foreground" Value="{DynamicResource ReduxAccentHoverBrush}" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style x:Key="ModDetailsTabControlStyle" TargetType="{x:Type TabControl}">
				<Setter Property="Background" Value="Transparent" />
				<Setter Property="BorderThickness" Value="0" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type TabControl}">
							<Grid KeyboardNavigation.TabNavigation="Local">
								<Grid.RowDefinitions>
								<RowDefinition Height="42" />
									<RowDefinition Height="1" />
									<RowDefinition Height="*" />
								</Grid.RowDefinitions>
							<TabPanel Margin="14,2,14,2"
									ClipToBounds="False"
									IsItemsHost="True"
									KeyboardNavigation.TabIndex="1" />
								<Border Grid.Row="1"
									Height="1"
									Background="{DynamicResource ReduxBorderBrush}" />
								<ContentPresenter x:Name="PART_SelectedContentHost"
									Grid.Row="2"
									ContentSource="SelectedContent"
									KeyboardNavigation.DirectionalNavigation="Contained"
									SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
									TextElement.Foreground="{DynamicResource ReduxTextPrimaryBrush}" />
							</Grid>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style x:Key="ModDetailsTabItemStyle" TargetType="{x:Type TabItem}">
				<Setter Property="FontWeight" Value="{DynamicResource Redux.FontWeight.Control}" />
				<Setter Property="Background" Value="Transparent" />
				<Setter Property="BorderBrush" Value="Transparent" />
				<Setter Property="BorderThickness" Value="1" />
				<Setter Property="ClipToBounds" Value="False" />
				<Setter Property="Cursor" Value="Hand" />
				<Setter Property="FocusVisualStyle" Value="{x:Null}" />
				<Setter Property="Foreground" Value="{DynamicResource ReduxTextPrimaryBrush}" />
				<Setter Property="MinWidth" Value="86" />
				<Setter Property="Padding" Value="12,7" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type TabItem}">
							<!--
								Inter-tab gap lives on the template root, NOT on TabItem.Margin:
								TabPanel double-counts external child margins and applies a layout
								clip narrower than the tab, shearing the hover pill's right corner.
							-->
							<Grid Margin="0,0,6,0" Background="Transparent">
								<Grid.RowDefinitions>
									<RowDefinition Height="*" />
									<RowDefinition Height="2" />
								</Grid.RowDefinitions>
								<Border x:Name="TabHoverSurface"
									Grid.RowSpan="2"
									Margin="2,3"
									Background="{DynamicResource ReduxHoverBrush}"
									CornerRadius="{DynamicResource Redux.CornerRadius.ControlInner}"
									IsHitTestVisible="False"
									Opacity="0" />
								<TextBlock x:Name="HeaderText"
									Margin="{TemplateBinding Padding}"
									HorizontalAlignment="Center"
									VerticalAlignment="Center"
									Foreground="{DynamicResource ReduxTextMutedBrush}"
									Text="{TemplateBinding Header}" />
								<Border x:Name="SelectionUnderline"
									Grid.Row="1"
									Margin="5,0"
									Background="{DynamicResource ReduxAccentBrush}"
									CornerRadius="1"
									Opacity="0"
									RenderTransformOrigin="0.5,0.5">
									<Border.RenderTransform>
										<ScaleTransform ScaleX="0.4" />
									</Border.RenderTransform>
								</Border>
							</Grid>
							<ControlTemplate.Triggers>
								<MultiTrigger>
									<MultiTrigger.Conditions>
										<Condition Property="IsMouseOver" Value="True" />
										<Condition Property="IsSelected" Value="False" />
									</MultiTrigger.Conditions>
									<MultiTrigger.EnterActions>
										<BeginStoryboard>
											<Storyboard>
												<DoubleAnimation Storyboard.TargetName="TabHoverSurface" Storyboard.TargetProperty="Opacity"
													To="1" Duration="{StaticResource Redux.Motion.Fast}" EasingFunction="{StaticResource Redux.Motion.EaseOut}" />
											</Storyboard>
										</BeginStoryboard>
									</MultiTrigger.EnterActions>
									<MultiTrigger.ExitActions>
										<BeginStoryboard>
											<Storyboard>
												<DoubleAnimation Storyboard.TargetName="TabHoverSurface" Storyboard.TargetProperty="Opacity"
													To="0" Duration="{StaticResource Redux.Motion.Standard}" />
											</Storyboard>
										</BeginStoryboard>
									</MultiTrigger.ExitActions>
								</MultiTrigger>
								<Trigger Property="IsMouseOver" Value="True">
									<Setter TargetName="HeaderText" Property="Foreground" Value="{DynamicResource ReduxTextPrimaryBrush}" />
								</Trigger>
								<Trigger Property="IsSelected" Value="True">
									<Setter Property="Panel.ZIndex" Value="1" />
									<Setter TargetName="HeaderText" Property="Foreground" Value="{DynamicResource ReduxAccentHoverBrush}" />
									<Setter TargetName="HeaderText" Property="FontWeight" Value="SemiBold" />
									<Trigger.EnterActions>
										<BeginStoryboard>
											<Storyboard>
												<DoubleAnimation Storyboard.TargetName="SelectionUnderline"
													Storyboard.TargetProperty="Opacity"
													To="1" Duration="0:0:0.14" />
												<DoubleAnimation Storyboard.TargetName="SelectionUnderline"
													Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
													To="1" Duration="0:0:0.14">
													<DoubleAnimation.EasingFunction>
														<QuadraticEase EasingMode="EaseOut" />
													</DoubleAnimation.EasingFunction>
												</DoubleAnimation>
											</Storyboard>
										</BeginStoryboard>
									</Trigger.EnterActions>
									<Trigger.ExitActions>
										<BeginStoryboard>
											<Storyboard>
												<DoubleAnimation Storyboard.TargetName="SelectionUnderline"
													Storyboard.TargetProperty="Opacity"
													To="0" Duration="0:0:0.10" />
												<DoubleAnimation Storyboard.TargetName="SelectionUnderline"
													Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
													To="0.4" Duration="0:0:0.10" />
											</Storyboard>
										</BeginStoryboard>
									</Trigger.ExitActions>
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style x:Key="ModDetailsMetadataChipStyle" TargetType="{x:Type Border}">
				<Setter Property="Margin" Value="0,0,6,5" />
				<Setter Property="Padding" Value="9,3" />
				<Setter Property="Background" Value="{DynamicResource ReduxSurfaceMutedBrush}" />
				<Setter Property="BorderBrush" Value="{DynamicResource ReduxBorderBrush}" />
				<Setter Property="BorderThickness" Value="1.5" />
				<Setter Property="CornerRadius" Value="10" />
			</Style>
			<Style x:Key="ModDetailsLegacyStatusChipStyle" BasedOn="{StaticResource ModDetailsMetadataChipStyle}" TargetType="{x:Type Border}">
				<Setter Property="Background" Value="{DynamicResource ReduxWarningSoftBrush}" />
				<Setter Property="BorderBrush" Value="{DynamicResource ReduxWarningBrush}" />
			</Style>
			<Style x:Key="ModDetailsAuthorChipStyle" BasedOn="{StaticResource ModDetailsMetadataChipStyle}" TargetType="{x:Type Border}">
				<Style.Triggers>
					<DataTrigger Binding="{Binding Metadata.SourceType}" Value="{x:Static dapp:ModSourceType.MODIO}">
						<Setter Property="ToolTip" Value="mod.io's user ID system does not provide Redux with enough reliable information to automatically open the author's direct profile. Use the mod.io mod page instead." />
					</DataTrigger>
				</Style.Triggers>
			</Style>
			<!-- The drawer header is auto-sized, so its pill must measure naturally instead of
				 using the list-cell template's arranged-width clamp. -->
			<DataTemplate x:Key="ModDetailsTitleCategoryPillItemTemplate">
				<Border Style="{StaticResource ReduxCategoryPillStyle}">
					<StackPanel Orientation="Horizontal">
						<c:ReduxIcon Width="12" Height="12" Margin="0,0,5,0"
							IconKey="{Binding IconId}" Foreground="{Binding Color}">
							<c:ReduxIcon.Style>
								<Style BasedOn="{StaticResource {x:Type c:ReduxIcon}}" TargetType="{x:Type c:ReduxIcon}">
									<Setter Property="Visibility" Value="Collapsed" />
									<Style.Triggers>
										<MultiDataTrigger>
											<MultiDataTrigger.Conditions>
												<Condition Binding="{Binding HasIcon}" Value="True" />
												<Condition Binding="{Binding DataContext.Settings.ShowCategoryIconsInPills, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" Value="True" />
											</MultiDataTrigger.Conditions>
											<Setter Property="Visibility" Value="Visible" />
										</MultiDataTrigger>
									</Style.Triggers>
								</Style>
							</c:ReduxIcon.Style>
						</c:ReduxIcon>
						<TextBlock FontSize="11" FontWeight="Medium" Foreground="{Binding Color}"
							Text="{Binding Name}" />
					</StackPanel>
				</Border>
			</DataTemplate>
			<DataTemplate x:Key="ModDetailsCategoryTemplate" DataType="{x:Type data:DivinityModData}">
				<ItemsControl ClipToBounds="False"
					ItemTemplate="{StaticResource ModDetailsTitleCategoryPillItemTemplate}"
					ItemsSource="{Binding DisplayCategories}"
					ToolTip="{Binding DisplayCategory}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
				</ItemsControl>
			</DataTemplate>
			<Style x:Key="ModDetailsSourceButtonStyle" TargetType="{x:Type Button}">
				<Setter Property="Height" Value="27" />
				<Setter Property="Margin" Value="0,0,6,5" />
				<Setter Property="Padding" Value="9,3" />
				<Setter Property="Background" Value="{DynamicResource ReduxAccentSoftBrush}" />
				<Setter Property="BorderBrush" Value="{DynamicResource ReduxAccentBrush}" />
				<Setter Property="BorderThickness" Value="1.5" />
				<Setter Property="Cursor" Value="Hand" />
				<Setter Property="Foreground" Value="{DynamicResource ReduxAccentHoverBrush}" />
				<Setter Property="FontWeight" Value="SemiBold" />
				<Setter Property="FocusVisualStyle" Value="{x:Null}" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type Button}">
							<Border x:Name="SourceButtonSurface"
								Padding="{TemplateBinding Padding}"
								Background="{TemplateBinding Background}"
								BorderBrush="{TemplateBinding BorderBrush}"
								BorderThickness="{TemplateBinding BorderThickness}"
								CornerRadius="{DynamicResource Redux.CornerRadius.Pill}">
								<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger Property="IsMouseOver" Value="True">
									<Setter TargetName="SourceButtonSurface" Property="Opacity" Value="0.78" />
								</Trigger>
								<Trigger Property="IsPressed" Value="True">
									<Setter TargetName="SourceButtonSurface" Property="Opacity" Value="0.75" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
				<Style.Triggers>
					<DataTrigger Binding="{Binding Metadata.SourceType}" Value="{x:Static dapp:ModSourceType.NEXUSMODS}">
						<Setter Property="Background" Value="{StaticResource Redux.Pill.Nexus.Background}" />
						<Setter Property="BorderBrush" Value="{StaticResource Redux.Pill.Nexus.Border}" />
						<Setter Property="Foreground" Value="{StaticResource Redux.Pill.Nexus.Border}" />
					</DataTrigger>
					<DataTrigger Binding="{Binding Metadata.SourceType}" Value="{x:Static dapp:ModSourceType.MODIO}">
						<Setter Property="Background" Value="{StaticResource Redux.Pill.Modio.Background}" />
						<Setter Property="BorderBrush" Value="{StaticResource Redux.Pill.Modio.Border}" />
						<Setter Property="Foreground" Value="{StaticResource Redux.Pill.Modio.Border}" />
					</DataTrigger>
				</Style.Triggers>
			</Style>
			<DataTemplate x:Key="PlatformAuthorButtonTemplate" DataType="{x:Type data:DivinityModData}">
				<StackPanel Orientation="Horizontal">
					<ContentControl Margin="0,0,6,0" Content="{Binding}" ContentTemplate="{StaticResource PlatformIconPresenterTemplate}" />
					<TextBlock VerticalAlignment="Center" Text="{Binding Metadata.UploaderLabel}" />
				</StackPanel>
			</DataTemplate>
			<DataTemplate x:Key="PlatformSourceButtonTemplate" DataType="{x:Type data:DivinityModData}">
				<StackPanel Orientation="Horizontal">
					<ContentControl Margin="0,0,6,0" Content="{Binding}" ContentTemplate="{StaticResource PlatformIconPresenterTemplate}" />
					<TextBlock VerticalAlignment="Center" Text="{Binding Metadata.SourcePageButtonLabel}" />
				</StackPanel>
			</DataTemplate>
			<DataTemplate x:Key="PlatformChangelogButtonTemplate" DataType="{x:Type data:DivinityModData}">
				<StackPanel Orientation="Horizontal">
					<ContentControl Margin="0,0,6,0" Content="{Binding}" ContentTemplate="{StaticResource PlatformIconPresenterTemplate}" />
					<TextBlock VerticalAlignment="Center" Text="{Binding Metadata.ChangelogButtonLabel}" />
				</StackPanel>
			</DataTemplate>
			<DataTemplate x:Key="ModDetailsOverviewTemplate" DataType="{x:Type data:DivinityModData}">
				<Grid Margin="14,10">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="14" />
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>
					<Border MinWidth="250"
						MaxWidth="620"
						Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={StaticResource ModDetailsMediaWidthConverter}}"
						VerticalAlignment="Stretch"
						Background="{DynamicResource ReduxListInteriorBrush}"
						BorderThickness="1"
						ClipToBounds="True"
						CornerRadius="{DynamicResource Redux.CornerRadius.Control}">
						<Border.InputBindings>
							<MouseBinding Command="{Binding Path=OpenModGalleryPageCommand, Source={x:Static dapp:DivinityApp.Commands}}"
								CommandParameter="{Binding}"
								MouseAction="LeftClick" />
						</Border.InputBindings>
						<Border.Style>
							<Style TargetType="{x:Type Border}">
								<Setter Property="BorderBrush" Value="{DynamicResource ReduxBorderBrush}" />
								<Style.Triggers>
									<DataTrigger Binding="{Binding Metadata.OnlineSourceVisibility}" Value="Visible">
										<Setter Property="Cursor" Value="Hand" />
										<Setter Property="ToolTip" Value="{Binding Metadata.GalleryTooltip}" />
									</DataTrigger>
									<MultiDataTrigger>
										<MultiDataTrigger.Conditions>
											<Condition Binding="{Binding Metadata.OnlineSourceVisibility}" Value="Visible" />
											<Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
										</MultiDataTrigger.Conditions>
										<Setter Property="BorderBrush" Value="{DynamicResource ReduxAccentHoverBrush}" />
										<Setter Property="Effect">
											<Setter.Value>
												<DropShadowEffect BlurRadius="10"
													Color="{DynamicResource ReduxAccentColor}"
													Opacity="0.65"
													ShadowDepth="0" />
											</Setter.Value>
										</Setter>
									</MultiDataTrigger>
								</Style.Triggers>
							</Style>
						</Border.Style>
						<Grid>
							<Grid.RowDefinitions>
								<RowDefinition Height="*" />
								<RowDefinition Height="29" />
							</Grid.RowDefinitions>
							<!--  Future linked artwork belongs in this layer. Uniform preserves the complete image without aggressive cropping.  -->
							<Image x:Name="ModDetailsPreviewImage"
								Margin="6"
								HorizontalAlignment="Stretch"
								VerticalAlignment="Stretch"
								IsHitTestVisible="False"
								RenderOptions.BitmapScalingMode="HighQuality"
								Source="{Binding Metadata.PreviewImageUri, Converter={StaticResource UriToBitmapImageConverter}}"
								Stretch="Uniform"
								Visibility="{Binding Metadata.PreviewImageVisibility}" />
							<Grid x:Name="ModDetailsLocalPreviewPlaceholder">
								<Grid.Style>
									<Style TargetType="{x:Type Grid}">
										<Setter Property="Visibility" Value="Visible" />
										<Style.Triggers>
											<DataTrigger Binding="{Binding Metadata.PreviewImageVisibility}" Value="Visible">
												<Setter Property="Visibility" Value="Collapsed" />
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</Grid.Style>
								<StackPanel MaxWidth="205"
									Margin="8"
									HorizontalAlignment="Center"
									VerticalAlignment="Center">
									<Border Width="64"
										Height="34"
										HorizontalAlignment="Center"
										Background="{DynamicResource ReduxAccentSoftBrush}"
										BorderBrush="{DynamicResource ReduxAccentBrush}"
										BorderThickness="1"
										CornerRadius="{DynamicResource Redux.CornerRadius.Card}">
										<TextBlock HorizontalAlignment="Center"
											VerticalAlignment="Center"
											FontSize="15"
											FontWeight="Bold"
											Foreground="{DynamicResource ReduxAccentHoverBrush}"
											Text="MOD" />
									</Border>
									<TextBlock Margin="0,6,0,0"
										HorizontalAlignment="Center"
										FontWeight="SemiBold"
										Foreground="{DynamicResource ReduxTextSecondaryBrush}"
										Text="No linked media" />
									<TextBlock Margin="0,2,0,0"
										HorizontalAlignment="Center"
										Foreground="{DynamicResource ReduxTextMutedBrush}"
										Text="Online source will appear here when linked."
										TextAlignment="Center"
										TextWrapping="Wrap" />
								</StackPanel>
							</Grid>
							<Border Grid.Row="1"
								Margin="6,0,6,6"
								BorderThickness="1"
								CornerRadius="{DynamicResource Redux.CornerRadius.Card}">
								<Border.Style><Style TargetType="Border">
									<Setter Property="Background" Value="{StaticResource Redux.Pill.Local.Background}" /><Setter Property="BorderBrush" Value="{StaticResource Redux.Pill.Local.Border}" /><Setter Property="TextElement.Foreground" Value="{StaticResource Redux.Pill.Local.Border}" />
									<Style.Triggers>
										<DataTrigger Binding="{Binding Metadata.SourceType}" Value="{x:Static dapp:ModSourceType.NEXUSMODS}"><Setter Property="Background" Value="{StaticResource Redux.Pill.Nexus.Background}" /><Setter Property="BorderBrush" Value="{StaticResource Redux.Pill.Nexus.Border}" /><Setter Property="TextElement.Foreground" Value="{StaticResource Redux.Pill.Nexus.Border}" /></DataTrigger>
										<DataTrigger Binding="{Binding Metadata.SourceType}" Value="{x:Static dapp:ModSourceType.MODIO}"><Setter Property="Background" Value="{StaticResource Redux.Pill.Modio.Background}" /><Setter Property="BorderBrush" Value="{StaticResource Redux.Pill.Modio.Border}" /><Setter Property="TextElement.Foreground" Value="{StaticResource Redux.Pill.Modio.Border}" /></DataTrigger>
									</Style.Triggers>
								</Style></Border.Style>
								<StackPanel HorizontalAlignment="Center"
									VerticalAlignment="Center"
									Orientation="Horizontal">
									<ContentControl Margin="0,0,5,0" Content="{Binding}" ContentTemplate="{StaticResource PlatformIconPresenterTemplate}" Visibility="{Binding Metadata.OnlineSourceVisibility}" />
									<TextBlock VerticalAlignment="Center"
										FontSize="10"
										FontWeight="SemiBold">
									<TextBlock.Style>
										<Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="{x:Type TextBlock}">
											<Setter Property="Text" Value="Local" />
											<Style.Triggers>
										<DataTrigger Binding="{Binding Metadata.OnlineSourceVisibility}" Value="Visible">
											<Setter Property="Text" Value="{Binding Metadata.SourceLabel}" />
												</DataTrigger>
											</Style.Triggers>
										</Style>
									</TextBlock.Style>
									</TextBlock>
								</StackPanel>
							</Border>
						</Grid>
					</Border>
					<Grid Grid.Column="2">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="*" />
						</Grid.RowDefinitions>
						<StackPanel>
							<WrapPanel Margin="0,1,0,0">
								<Border>
									<Border.ToolTip>
										<ToolTip Style="{StaticResource ReduxRichToolTipStyle}">
											<Border MaxWidth="390" Padding="12,10" Background="{DynamicResource ReduxSurfaceElevatedBrush}" BorderBrush="{DynamicResource ReduxWarningBrush}" BorderThickness="1" CornerRadius="{DynamicResource Redux.CornerRadius.Card}">
												<StackPanel>
													<TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ReduxWarningBrush}" Text="Contains Mod Fixer" />
													<TextBlock Margin="0,5,0,0" Foreground="{DynamicResource ReduxTextPrimaryBrush}" Text="This package contains the older Mod Fixer technique used by some BG3 mods." TextWrapping="Wrap" />
													<TextBlock Margin="0,6,0,0" Foreground="{DynamicResource ReduxTextSecondaryBrush}" Text="BG3 Patch 7 and newer generally do not require Mod Fixer, and it does not need to be installed separately." TextWrapping="Wrap" />
												</StackPanel>
											</Border>
										</ToolTip>
									</Border.ToolTip>
									<Border.Style>
										<Style BasedOn="{StaticResource ModDetailsLegacyStatusChipStyle}" TargetType="{x:Type Border}">
											<Setter Property="Visibility" Value="Collapsed" />
											<Style.Triggers>
												<DataTrigger Binding="{Binding OsirisModStatus}" Value="{x:Static dapp:DivinityOsirisModStatus.MODFIXER}">
													<Setter Property="Visibility" Value="Visible" />
												</DataTrigger>
											</Style.Triggers>
										</Style>
									</Border.Style>
									<TextBlock Foreground="{DynamicResource ReduxWarningBrush}" FontWeight="SemiBold" Text="Contains Mod Fixer" />
								</Border>
								<Border Style="{StaticResource ModDetailsLegacyStatusChipStyle}"
									ToolTip="This package contains files that directly override built-in game files. Those overrides remain active while the .pak exists in the Mods folder."
									Visibility="{Binding IsForceLoaded, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
									<TextBlock Foreground="{DynamicResource ReduxWarningBrush}" FontWeight="SemiBold" Text="Overrides Game Files" />
								</Border>
								<Border ToolTip="This package overrides built-in game files and loads whenever its .pak is present. It is outside the normal load order and usually is not written to modsettings.lsx.">
									<Border.Style>
										<Style BasedOn="{StaticResource ModDetailsLegacyStatusChipStyle}" TargetType="{x:Type Border}">
											<Setter Property="Visibility" Value="Collapsed" />
											<Style.Triggers>
												<MultiDataTrigger>
													<MultiDataTrigger.Conditions>
														<Condition Binding="{Binding IsForceLoaded}" Value="True" />
														<Condition Binding="{Binding IsForceLoadedMergedMod}" Value="False" />
														<Condition Binding="{Binding ForceAllowInLoadOrder}" Value="False" />
													</MultiDataTrigger.Conditions>
													<Setter Property="Visibility" Value="Visible" />
												</MultiDataTrigger>
											</Style.Triggers>
										</Style>
									</Border.Style>
									<TextBlock Foreground="{DynamicResource ReduxWarningBrush}" FontWeight="SemiBold" Text="Always Loaded" />
								</Border>
								<Border ToolTip="This mod has a normal load-order entry and also contains direct file overrides. Disabling its load-order entry may not disable those overrides.">
									<Border.Style>
										<Style BasedOn="{StaticResource ModDetailsLegacyStatusChipStyle}" TargetType="{x:Type Border}">
											<Setter Property="Visibility" Value="Collapsed" />
											<Style.Triggers>
												<MultiDataTrigger>
													<MultiDataTrigger.Conditions>
														<Condition Binding="{Binding IsForceLoadedMergedMod}" Value="True" />
														<Condition Binding="{Binding ForceAllowInLoadOrder}" Value="False" />
													</MultiDataTrigger.Conditions>
													<Setter Property="Visibility" Value="Visible" />
												</MultiDataTrigger>
											</Style.Triggers>
										</Style>
									</Border.Style>
									<TextBlock Foreground="{DynamicResource ReduxWarningBrush}" FontWeight="SemiBold" Text="Contains File Overrides" />
								</Border>
								<Border ToolTip="This Always Loaded package is also being treated as a load-order entry.">
									<Border.Style>
										<Style BasedOn="{StaticResource ModDetailsLegacyStatusChipStyle}" TargetType="{x:Type Border}">
											<Setter Property="Visibility" Value="Collapsed" />
											<Style.Triggers>
												<DataTrigger Binding="{Binding ForceAllowInLoadOrder}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
											</Style.Triggers>
										</Style>
									</Border.Style>
									<TextBlock Foreground="{DynamicResource ReduxWarningBrush}" FontWeight="SemiBold" Text="Always Loaded + Load Order Entry" />
								</Border>
							</WrapPanel>
						</StackPanel>
						<WrapPanel Grid.Row="1" Margin="0,2,0,0" VerticalAlignment="Center">
							<TextBlock VerticalAlignment="Center"
								Foreground="{DynamicResource ReduxTextMutedBrush}"
								Text="{Binding Metadata.LinkStatus}"
								ToolTip="{Binding Metadata.LinkStatusTooltip}" />
						</WrapPanel>
						<WrapPanel Grid.Row="2" Margin="0,7,0,0">
							<Border Style="{StaticResource ModDetailsMetadataChipStyle}"
								ToolTip="{Binding SourceComponentTooltip}"
								Visibility="{Binding SourceComponentVisibility}">
								<TextBlock Foreground="{DynamicResource ReduxTextSecondaryBrush}"
									Text="{Binding SourceComponentSummary}" />
							</Border>
							<Border Style="{StaticResource ModDetailsMetadataChipStyle}">
								<TextBlock Foreground="{DynamicResource ReduxTextSecondaryBrush}"
									Text="{Binding Metadata.VersionLabel}" />
							</Border>
							<Border Style="{StaticResource ModDetailsMetadataChipStyle}">
								<TextBlock Foreground="{DynamicResource ReduxTextSecondaryBrush}"
									Text="{Binding Metadata.UpdatedLabel}" />
							</Border>
							<Border Margin="0,0,6,5"
								Padding="8,4"
								Background="{DynamicResource ReduxAccentSoftBrush}"
								BorderBrush="{DynamicResource ReduxAccentBrush}"
								BorderThickness="1.5"
								CornerRadius="{DynamicResource Redux.CornerRadius.Pill}"
								ToolTip="{Binding Metadata.OfflineDatabaseNoticeTooltip}"
								Visibility="Collapsed">
								<StackPanel Orientation="Horizontal">
									<TextBlock Margin="0,0,5,0"
										Foreground="{DynamicResource ReduxAccentHoverBrush}"
										Text="◇" />
									<TextBlock FontWeight="SemiBold"
										Foreground="{DynamicResource ReduxAccentHoverBrush}"
										Text="{Binding Metadata.OfflineDatabaseNotice}" />
								</StackPanel>
							</Border>
							<Border Style="{StaticResource ModDetailsAuthorChipStyle}" Visibility="{Binding Metadata.LocalAuthorVisibility}">
								<TextBlock Foreground="{DynamicResource ReduxTextSecondaryBrush}"
									Text="{Binding Metadata.AuthorLabel}" />
							</Border>
							<Button Command="{Binding Path=OpenURLCommand, Source={x:Static dapp:DivinityApp.Commands}}"
								CommandParameter="{Binding Metadata.AuthorPageUrl}"
								Content="{Binding}"
								ContentTemplate="{StaticResource PlatformAuthorButtonTemplate}"
								Style="{StaticResource ModDetailsSourceButtonStyle}"
								ToolTip="Open the mod author's profile"
								Visibility="{Binding Metadata.AuthorPageVisibility}" />
							<Button Command="{Binding Path=OpenModSourcePageCommand, Source={x:Static dapp:DivinityApp.Commands}}"
								CommandParameter="{Binding}"
								Content="{Binding}"
								ContentTemplate="{StaticResource PlatformSourceButtonTemplate}"
								Style="{StaticResource ModDetailsSourceButtonStyle}"
								Visibility="{Binding Metadata.OnlineSourceVisibility}" />
						</WrapPanel>
						<Border Grid.Row="3"
							Margin="0,3,0,0"
							Padding="10,8"
							Background="{DynamicResource ReduxListInteriorBrush}"
							BorderBrush="{DynamicResource ReduxBorderBrush}"
							BorderThickness="1"
							CornerRadius="{DynamicResource Redux.CornerRadius.Control}">
							<Grid>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="*" />
								</Grid.RowDefinitions>
								<TextBlock FontSize="11"
									FontWeight="SemiBold"
									Foreground="{DynamicResource ReduxTextMutedBrush}"
									Text="SUMMARY" />
								<ScrollViewer Grid.Row="1"
									Margin="0,4,0,0"
									HorizontalScrollBarVisibility="Disabled"
									VerticalScrollBarVisibility="Auto">
									<TextBlock Foreground="{DynamicResource ReduxTextSecondaryBrush}"
										Text="{Binding Metadata.Summary, TargetNullValue='No local description is available.'}"
										TextWrapping="Wrap" />
								</ScrollViewer>
							</Grid>
						</Border>
					</Grid>
				</Grid>
			</DataTemplate>
			<DataTemplate x:Key="ModDetailsDescriptionTemplate" DataType="{x:Type data:DivinityModData}">
				<Grid Margin="18,12">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>
					<Grid>
						<TextBlock FontSize="16"
							FontWeight="SemiBold"
							Text="{Binding Metadata.DescriptionHeading}" />
					</Grid>
					<TextBlock Grid.Row="1"
						Margin="0,2,0,0"
						Foreground="{DynamicResource ReduxTextMutedBrush}">
						<TextBlock.Style>
							<Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="{x:Type TextBlock}">
								<Setter Property="Text" Value="Description stored inside the installed mod package." />
								<Style.Triggers>
									<DataTrigger Binding="{Binding NexusModsInformationVisibility}" Value="Visible">
									<Setter Property="Text" Value="Readable plain-text view of the author's description." />
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</TextBlock.Style>
					</TextBlock>
					<Border Grid.Row="2"
						Margin="0,9,0,0"
						Padding="12,10"
						Background="{DynamicResource ReduxListInteriorBrush}"
						BorderBrush="{DynamicResource ReduxBorderBrush}"
						BorderThickness="1"
						CornerRadius="{DynamicResource Redux.CornerRadius.Control}">
						<ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
							<TextBlock Foreground="{DynamicResource ReduxTextSecondaryBrush}"
								Text="{Binding Metadata.Description, Converter={StaticResource NexusDescriptionToPlainTextConverter}, TargetNullValue='No local description is available for this mod.'}"
								TextWrapping="Wrap" />
						</ScrollViewer>
					</Border>
				</Grid>
			</DataTemplate>
			<DataTemplate x:Key="ModDetailsFilesTemplate" DataType="{x:Type data:DivinityModData}">
				<Grid Margin="18,14">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>
					<TextBlock FontSize="16" FontWeight="SemiBold" Text="Installed package" />
					<Grid Grid.Row="1" Margin="0,10,0,0">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="80" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<TextBlock Foreground="{DynamicResource ReduxTextSecondaryBrush}" Text="Mod UUID" />
						<TextBlock Grid.Column="1" Text="{Binding UUID}" TextTrimming="CharacterEllipsis" ToolTip="{Binding UUID}" />
					</Grid>
					<Grid Grid.Row="2" Margin="0,8,0,0">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="80" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<TextBlock Foreground="{DynamicResource ReduxTextSecondaryBrush}" Text="File path" />
						<TextBlock Grid.Column="1" Text="{Binding FilePath}" TextTrimming="CharacterEllipsis" ToolTip="{Binding FilePath}" />
					</Grid>
				</Grid>
			</DataTemplate>
			<DataTemplate x:Key="ModDetailsMediaTemplate" DataType="{x:Type data:DivinityModData}">
				<Grid Margin="18,12">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<TextBlock FontSize="16" FontWeight="SemiBold">
							<TextBlock.Style>
								<Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="{x:Type TextBlock}">
									<Setter Property="Text" Value="No linked media yet" />
									<Style.Triggers>
										<DataTrigger Binding="{Binding Metadata.PreviewImageVisibility}" Value="Visible">
											<Setter Property="Text" Value="{Binding Metadata.SourceLabel, StringFormat='Media from {0}'}" />
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</TextBlock.Style>
						</TextBlock>
						<Button Grid.Column="1"
							Command="{Binding Path=OpenModSourcePageCommand, Source={x:Static dapp:DivinityApp.Commands}}"
							CommandParameter="{Binding}"
							Content="{Binding}"
							ContentTemplate="{StaticResource PlatformSourceButtonTemplate}"
							Style="{StaticResource ModDetailsSourceButtonStyle}"
							Visibility="{Binding Metadata.OnlineSourceVisibility}" />
					</Grid>
					<TextBlock Grid.Row="1"
						Margin="0,2,0,0"
						Foreground="{DynamicResource ReduxTextMutedBrush}">
						<TextBlock.Style>
							<Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="{x:Type TextBlock}">
								<Setter Property="Text" Value="Images from the linked mod source will appear here when its gallery is available." />
								<Style.Triggers>
									<DataTrigger Binding="{Binding Metadata.PreviewImageVisibility}" Value="Visible">
										<Setter Property="Text" Value="The linked source image is shown without cropping." />
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</TextBlock.Style>
					</TextBlock>
					<Border Grid.Row="2"
						MinHeight="120"
						Margin="0,9,0,0"
						Padding="8"
						Background="{DynamicResource ReduxListInteriorBrush}"
						BorderBrush="{DynamicResource ReduxBorderBrush}"
						BorderThickness="1"
						CornerRadius="{DynamicResource Redux.CornerRadius.Control}">
						<Grid>
							<Image HorizontalAlignment="Stretch"
								VerticalAlignment="Stretch"
								IsHitTestVisible="False"
								RenderOptions.BitmapScalingMode="HighQuality"
								Source="{Binding Metadata.PreviewImageUri, Converter={StaticResource UriToBitmapImageConverter}}"
								Stretch="Uniform"
								Visibility="{Binding Metadata.PreviewImageVisibility}" />
							<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
								<StackPanel.Style>
									<Style TargetType="StackPanel">
										<Setter Property="Visibility" Value="Visible" />
										<Style.Triggers>
											<DataTrigger Binding="{Binding Metadata.PreviewImageVisibility}" Value="Visible">
												<Setter Property="Visibility" Value="Collapsed" />
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</StackPanel.Style>
								<TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Text="No image available" />
								<TextBlock MaxWidth="520"
									Margin="0,5,0,0"
									Foreground="{DynamicResource ReduxTextMutedBrush}"
									Text="Local metadata remains available while Redux looks for a linked online source."
									TextAlignment="Center"
									TextWrapping="Wrap" />
							</StackPanel>
						</Grid>
					</Border>
				</Grid>
			</DataTemplate>
			<DataTemplate x:Key="ModDetailsRequirementsTemplate" DataType="{x:Type data:DivinityModData}">
				<Grid Margin="18,12">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>
					<TextBlock FontSize="16" FontWeight="SemiBold" Text="Installed mod dependencies" />
					<TextBlock Grid.Row="1"
						Margin="0,2,0,0"
						Foreground="{DynamicResource ReduxTextMutedBrush}"
						Text="Dependencies parsed from the installed mod package. Online requirements can be added when a source provides them." />
					<Border Grid.Row="2"
						Margin="0,9,0,0"
						Padding="10"
						Background="{DynamicResource ReduxListInteriorBrush}"
						BorderBrush="{DynamicResource ReduxBorderBrush}"
						BorderThickness="1"
						CornerRadius="{DynamicResource Redux.CornerRadius.Control}">
						<Grid>
							<ListBox ItemTemplate="{StaticResource DependencyModTemplate}"
								ItemsSource="{Binding DisplayedDependencies}">
								<ListBox.Style>
									<Style BasedOn="{StaticResource ModuleShortDescListBox}" TargetType="ListBox">
										<Setter Property="Visibility" Value="Visible" />
										<Style.Triggers>
											<DataTrigger Binding="{Binding HasDependencies}" Value="False">
												<Setter Property="Visibility" Value="Collapsed" />
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</ListBox.Style>
							</ListBox>
							<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
								<StackPanel.Style>
									<Style TargetType="StackPanel">
										<Setter Property="Visibility" Value="Collapsed" />
										<Style.Triggers>
											<DataTrigger Binding="{Binding HasDependencies}" Value="False">
												<Setter Property="Visibility" Value="Visible" />
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</StackPanel.Style>
								<TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Text="No installed dependencies declared" />
								<TextBlock Margin="0,5,0,0"
									Foreground="{DynamicResource ReduxTextMutedBrush}"
									Text="This mod's local metadata does not list another mod as a dependency."
									TextAlignment="Center"
									TextWrapping="Wrap" />
							</StackPanel>
						</Grid>
					</Border>
				</Grid>
			</DataTemplate>
			<DataTemplate x:Key="ModDetailsChangelogTemplate" DataType="{x:Type data:DivinityModData}">
				<Grid Margin="18,12">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<TextBlock FontSize="16"
							FontWeight="SemiBold"
							Text="{Binding Metadata.ChangelogHeading}" />
						<Button Grid.Column="1"
							Command="{Binding Path=OpenModChangelogPageCommand, Source={x:Static dapp:DivinityApp.Commands}}"
							CommandParameter="{Binding}"
							Content="{Binding}"
							ContentTemplate="{StaticResource PlatformChangelogButtonTemplate}"
							Style="{StaticResource ModDetailsSourceButtonStyle}"
							Visibility="{Binding Metadata.OnlineSourceVisibility}" />
					</Grid>
					<TextBlock Grid.Row="1"
						Margin="0,2,0,0"
						Foreground="{DynamicResource ReduxTextMutedBrush}"
						Text="{Binding Metadata.ChangelogHelperText}" />
					<Border Grid.Row="2"
						Margin="0,9,0,0"
						Padding="12,10"
						Background="{DynamicResource ReduxListInteriorBrush}"
						BorderBrush="{DynamicResource ReduxBorderBrush}"
						BorderThickness="1"
						CornerRadius="{DynamicResource Redux.CornerRadius.Control}">
						<ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
							<TextBlock Foreground="{DynamicResource ReduxTextSecondaryBrush}" TextWrapping="Wrap">
								<TextBlock.Style>
									<Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="{x:Type TextBlock}">
										<Setter Property="Text" Value="No online changelog is linked to this installed mod." />
										<Style.Triggers>
										<DataTrigger Binding="{Binding Metadata.OnlineSourceVisibility}" Value="Visible">
											<Setter Property="Text" Value="{Binding Metadata.ChangelogText, Converter={StaticResource NexusDescriptionToPlainTextConverter}, ConverterParameter='No online changelog is available for this mod.'}" />
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</TextBlock.Style>
							</TextBlock>
						</ScrollViewer>
					</Border>
				</Grid>
			</DataTemplate>
			<DataTemplate x:Key="ModDetailsTabbedTemplate" DataType="{x:Type data:DivinityModData}">
				<TabControl ItemContainerStyle="{StaticResource ModDetailsTabItemStyle}"
					SelectedIndex="0"
					Style="{StaticResource ModDetailsTabControlStyle}">
					<TabItem Header="Overview">
						<ContentControl Content="{Binding}" ContentTemplate="{StaticResource ModDetailsOverviewTemplate}" />
					</TabItem>
					<TabItem Header="Description">
						<ContentControl Content="{Binding}" ContentTemplate="{StaticResource ModDetailsDescriptionTemplate}" />
					</TabItem>
					<TabItem Header="Requirements">
						<ContentControl Content="{Binding}" ContentTemplate="{StaticResource ModDetailsRequirementsTemplate}" />
					</TabItem>
					<TabItem Header="Files">
						<ContentControl Content="{Binding}" ContentTemplate="{StaticResource ModDetailsFilesTemplate}" />
					</TabItem>
					<TabItem Header="Changelog">
						<ContentControl Content="{Binding}" ContentTemplate="{StaticResource ModDetailsChangelogTemplate}" />
					</TabItem>
				</TabControl>
			</DataTemplate>
		</ResourceDictionary>
	</UserControl.Resources>
	<UserControl.Style>
		<Style BasedOn="{StaticResource {x:Type UserControl}}" TargetType="UserControl" />
	</UserControl.Style>
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition x:Name="ModListsRow" Height="*" MinHeight="180" />
			<RowDefinition x:Name="ModDetailsSplitterRow" Height="0" />
			<RowDefinition x:Name="ModDetailsRow" Height="0" />
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition x:Name="CategoriesColumn" Width="220" MinWidth="52" />
			<ColumnDefinition Width="4" />
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="4" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>
		<Border x:Name="CategoriesPanel" Grid.Column="0"
			Margin="10,4,5,10"
			Style="{StaticResource ModSectionCard}">
			<Border.ContextMenu>
				<ContextMenu Opened="CategoriesContextMenu_Opened">
					<MenuItem x:Name="ShowEmptyCategoriesMenuItem"
						Header="Show categories with 0 mods"
						IsCheckable="True"
						Click="ShowEmptyCategoriesMenuItem_Click">
						<MenuItem.Icon><c:ReduxIcon StrokeData="{StaticResource Redux.Icon.ListStroke}" /></MenuItem.Icon>
					</MenuItem>
					<MenuItem x:Name="SaveCategoryFilterMenuItem"
						Header="Save filter state between sessions"
						IsCheckable="True"
						Click="SaveCategoryFilterMenuItem_Click">
						<MenuItem.Icon><c:ReduxIcon Data="{StaticResource Redux.Icon.Save}" /></MenuItem.Icon>
					</MenuItem>
					<MenuItem x:Name="DisableNewModIndicatorsMenuItem"
						Header="Disable new-mod indicators"
						IsCheckable="True"
						Click="DisableNewModIndicatorsMenuItem_Click">
						<MenuItem.Icon><c:ReduxIcon Data="{StaticResource Redux.Icon.Information}" /></MenuItem.Icon>
					</MenuItem>
					<Separator />
					<MenuItem Header="Add New Custom Category..." Click="AddCustomCategoryMenuItem_Click">
						<MenuItem.Icon><c:ReduxIcon Data="{StaticResource Redux.Icon.AddCircle}" /></MenuItem.Icon>
					</MenuItem>
					<MenuItem x:Name="EditCategoryMenuItem" Header="Edit Selected Category..." Click="EditCategoryMenuItem_Click">
						<MenuItem.Icon><c:ReduxIcon Data="{StaticResource Redux.Icon.ColorPalette}" /></MenuItem.Icon>
					</MenuItem>
					<Separator />
					<MenuItem x:Name="EnableCategoriesMenuItem" Header="Enable / Disable Categories">
						<MenuItem.Icon><c:ReduxIcon Data="{StaticResource Redux.Icon.Pricetag}" /></MenuItem.Icon>
					</MenuItem>
					<MenuItem x:Name="DeleteCustomCategoryMenuItem" Header="Delete Custom Category">
						<MenuItem.Icon><c:ReduxIcon Data="{StaticResource Redux.Icon.Trash}" Foreground="{DynamicResource ReduxErrorBrush}" /></MenuItem.Icon>
					</MenuItem>
				</ContextMenu>
			</Border.ContextMenu>
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="1" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>
				<Grid>
					<Grid.Style>
						<Style TargetType="{x:Type Grid}">
							<Setter Property="Margin" Value="10,8" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding IsCategoriesExpanded}" Value="False">
									<Setter Property="Margin" Value="3,8" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</Grid.Style>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>
					<StackPanel VerticalAlignment="Center" Orientation="Horizontal">
						<StackPanel.Style>
							<Style TargetType="StackPanel">
								<Style.Triggers>
									<DataTrigger Binding="{Binding IsCategoriesExpanded}" Value="False">
										<Setter Property="Visibility" Value="Collapsed" />
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</StackPanel.Style>
						<TextBlock Style="{StaticResource ModSectionTitle}" Text="Categories">
							<TextBlock.ToolTip>
								<ToolTip MaxWidth="340">
									<TextBlock Text="Redux automatically suggests categories from the information available for each mod. Provider tags and package details can be incomplete, so reviewing the suggestion and adjusting it when needed is recommended."
										TextWrapping="Wrap" />
								</ToolTip>
							</TextBlock.ToolTip>
						</TextBlock>
					</StackPanel>
					<ToggleButton Grid.Column="1"
						Width="30"
						Height="28"
						Padding="0"
						IsChecked="{Binding IsCategoriesExpanded, Mode=TwoWay}"
						Style="{StaticResource CategoryPanelToggleStyle}"
						ToolTip="Collapse or expand categories">
						<TextBlock HorizontalAlignment="Center"
							VerticalAlignment="Center"
							FontSize="18"
							Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type ToggleButton}}}">
							<TextBlock.Style>
								<Style TargetType="{x:Type TextBlock}">
									<Setter Property="Text" Value="&#x2039;" />
									<Style.Triggers>
										<DataTrigger Binding="{Binding IsCategoriesExpanded}" Value="False">
											<Setter Property="Text" Value="&#x203A;" />
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</TextBlock.Style>
						</TextBlock>
					</ToggleButton>
				</Grid>
				<Border Grid.Row="1" Background="{DynamicResource ReduxBorderBrush}" />
				<ListBox x:Name="CategoryListBox" Grid.Row="2"
					Margin="6"
					Padding="0"
					AllowDrop="True"
					Background="Transparent"
					BorderThickness="0"
					ItemsSource="{Binding ModCategoryFilters}"
					ItemContainerStyle="{StaticResource ModCategoryListItemStyle}"
					ScrollViewer.HorizontalScrollBarVisibility="Disabled"
					SelectedIndex="0"
					PreviewMouseLeftButtonDown="CategoryListBox_PreviewMouseLeftButtonDown"
					PreviewMouseMove="CategoryListBox_PreviewMouseMove"
					PreviewMouseLeftButtonUp="CategoryListBox_PreviewMouseLeftButtonUp"
					DragOver="CategoryListBox_DragOver"
					DragLeave="CategoryListBox_DragLeave"
					Drop="CategoryListBox_Drop"
					SelectedValue="{Binding SelectedModCategory, Mode=TwoWay}"
					SelectedValuePath="Name">
					<ListBox.Style>
						<Style TargetType="{x:Type ListBox}">
							<Setter Property="Visibility" Value="Visible" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding IsCategoriesExpanded}" Value="False">
									<Setter Property="Visibility" Value="Collapsed" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</ListBox.Style>
					<ListBox.ItemTemplate>
						<DataTemplate>
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto" />
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>
								<Grid Grid.Column="0" Width="14"
									Height="14"
									Margin="0,0,7,0"
									VerticalAlignment="Center">
									<Border Width="9" Height="9" CornerRadius="5" BorderThickness="1.5"
										Background="{Binding Color}" BorderBrush="{Binding Color}"
										Visibility="{Binding HasIcon, Converter={StaticResource BoolToVisibilityConverterReversed}}" />
									<c:ReduxIcon Width="14" Height="14" IconKey="{Binding IconId}" Foreground="{Binding Color}"
										Visibility="{Binding HasIcon, Converter={StaticResource BoolToVisibilityConverter}}" />
								</Grid>
								<StackPanel Grid.Column="1" Orientation="Horizontal">
									<TextBlock VerticalAlignment="Center"
										Foreground="{DynamicResource ReduxTextPrimaryBrush}"
										Text="{Binding Name}"
										TextTrimming="CharacterEllipsis" />
									<Border Width="8"
										Height="8"
										Margin="8,0,0,0"
										VerticalAlignment="Center"
										Background="{DynamicResource ReduxSuccessBrush}"
										CornerRadius="4"
										ToolTip="New mod detected in this category">
										<Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding HasNewMods}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Border.Style>
										<Border.Effect>
											<DropShadowEffect BlurRadius="8"
												Color="{DynamicResource ReduxSuccessColor}"
												Opacity="0.85"
												ShadowDepth="0" />
										</Border.Effect>
									</Border>
								</StackPanel>
								<Border Grid.Column="2"
									MinWidth="28"
									Margin="8,0,0,0"
									Padding="6,2"
									Background="{DynamicResource ReduxSurfaceMutedBrush}"
									CornerRadius="9">
									<TextBlock HorizontalAlignment="Center"
										FontSize="11"
										Foreground="{DynamicResource ReduxTextSecondaryBrush}"
										Text="{Binding Count}" />
								</Border>
							</Grid>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>
				<TextBlock Grid.Row="2"
					HorizontalAlignment="Center"
					VerticalAlignment="Center"
					FontSize="12"
					FontWeight="SemiBold"
					Foreground="{DynamicResource ReduxTextMutedBrush}"
					IsHitTestVisible="False"
					Text="CATEGORIES">
					<TextBlock.LayoutTransform>
						<RotateTransform Angle="-90" />
					</TextBlock.LayoutTransform>
					<TextBlock.Style>
						<Style TargetType="{x:Type TextBlock}">
							<Setter Property="Visibility" Value="Collapsed" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding IsCategoriesExpanded}" Value="False">
									<Setter Property="Visibility" Value="Visible" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</TextBlock.Style>
				</TextBlock>
			</Grid>
		</Border>
		<GridSplitter x:Name="CategoriesGridSplitter" Grid.Column="1"
			Width="4"
			HorizontalAlignment="Stretch"
			VerticalAlignment="Stretch"
			ShowsPreview="False" />
		<Border Grid.Column="2"
			Margin="5,4,5,10"
			Style="{StaticResource ModSectionCard}">
		<Grid HorizontalAlignment="Stretch">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>
			<Grid Margin="12,10,12,8">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="8" />
					<ColumnDefinition Width="220" />
				</Grid.ColumnDefinitions>
				<TextBlock Style="{StaticResource ModSectionTitle}" Text="Active Mods" />
				<TextBlock Grid.Column="1"
					Margin="12,0,8,0"
					VerticalAlignment="Center"
					AutomationProperties.HelpText="The active list is sorted by metadata. Click the number-sign column to restore load-order editing."
					FontSize="11"
					Foreground="{DynamicResource ReduxWarningBrush}"
					Text="Sorted view — drag disabled; click # to edit order"
					TextTrimming="CharacterEllipsis"
					ToolTip="The active list is sorted by metadata, so visible rows no longer match load-order positions. Click the # column to restore load-order editing and drag-and-drop."
					Visibility="{Binding IsActiveListMetadataSorted, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />
			<c:UnfocusableTextBox x:Name="ActiveModsFilterTextBox"
					Grid.Column="5"
					Height="28"
					Padding="4,0"
					HorizontalAlignment="Stretch"
					VerticalAlignment="Center"
					behavior:ScreenReaderHelperBehavior.Name="Active Mods Filter"
					AcceptsReturn="False"
					AcceptsTab="False"
					adonisExtensions:CornerRadiusExtension.CornerRadius="{DynamicResource Redux.CornerRadius.ControlInner}"
					Background="{DynamicResource ReduxSurfaceMutedBrush}"
					BorderBrush="{DynamicResource ReduxBorderStrongBrush}"
					CanUndoTextOnEscape="True"
					TextAlignment="Left"
					ToolTip="Filter Active Mods"
					UpdateBindingOnFocusLost="True" />
				<TextBlock Grid.Column="5"
					Margin="0"
					Padding="4,0"
					HorizontalAlignment="Left"
					VerticalAlignment="Center"
					Foreground="{DynamicResource ReduxTextMutedBrush}"
					IsHitTestVisible="False"
					Text="Filter Active Mods">
					<TextBlock.Style>
						<Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="{x:Type TextBlock}">
							<Setter Property="Visibility" Value="Collapsed" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding Text, ElementName=ActiveModsFilterTextBox}" Value="">
									<Setter Property="Visibility" Value="Visible" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</TextBlock.Style>
				</TextBlock>
				<TextBlock x:Name="ActiveModsFilterResultText"
					Grid.Column="2"
					Margin="0,0,8,0"
					HorizontalAlignment="Left"
					VerticalAlignment="Center"
					behavior:ScreenReaderHelperBehavior.Name="Total Hidden Active Mods"
					AutomationProperties.HelpText="{Binding Text, RelativeSource={RelativeSource Self}}" />
				<TextBlock x:Name="ActiveSelectedText"
					Grid.Column="3"
					Margin="0,0,8,0"
					HorizontalAlignment="Left"
					VerticalAlignment="Center"
					AutomationProperties.HelpText="{Binding Text, RelativeSource={RelativeSource Self}}"
					AutomationProperties.Name="Active Mods" />
			</Grid>
			<Grid x:Name="ActiveModListGrid" Grid.Row="1">
				<Grid.RowDefinitions>
					<RowDefinition Name="ActiveModsListRow" Height="10*" />
					<RowDefinition Name="ActiveModsListGridRow" Height="Auto" />
					<RowDefinition Name="ActiveModsListForcedModsRow" Height="2*" />
				</Grid.RowDefinitions>
				<c:ModListView x:Name="ActiveModsListView"
					MaxHeight="99999"
					behavior:ScreenReaderHelperBehavior.Name="Active Mods"
					dd:DragDrop.DragHandler="{Binding DragHandler}"
					dd:DragDrop.DropHandler="{Binding DropHandler}"
					ContextMenuOpening="ModListView_ContextMenuOpening"
					GridViewColumnHeader.Click="ListView_Click"
					GridViewColumnHeader.PreviewMouseLeftButtonUp="ListViewColumnHeader_PreviewMouseLeftButtonUp"
					GridViewColumnHeader.PreviewMouseRightButtonUp="ListViewColumnHeader_RightClick"
					ItemContainerStyle="{StaticResource ListViewItemMouseEvents}"
					Style="{StaticResource ModOrderListViewWithDrag}"
					View="{DynamicResource ModGridView}"
					VirtualizingPanel.IsVirtualizing="True"
					VirtualizingPanel.VirtualizationMode="Recycling">
					<c:ModListView.ContextMenu><ContextMenu /></c:ModListView.ContextMenu>
				</c:ModListView>
				<GridSplitter x:Name="ActiveModListViewGridSplitter"
					Grid.Row="1"
					Height="4"
					HorizontalAlignment="Stretch"
					VerticalAlignment="Stretch"
					Background="{DynamicResource {x:Static adonisUI:Brushes.Layer1BackgroundBrush}}" />
				<Grid x:Name="AlwaysLoadedSectionGrid" Grid.Row="2">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>
					<Grid Margin="8,4,8,3">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<StackPanel VerticalAlignment="Center">
							<TextBlock FontSize="14" FontWeight="SemiBold" Text="Override Mods" />
							<TextBlock FontSize="11" Foreground="{DynamicResource ReduxTextMutedBrush}"
								Text="Always loaded while installed; overrides built-in game files outside the normal load order" />
						</StackPanel>
						<ToggleButton x:Name="AlwaysLoadedToggleButton" Grid.Column="1"
							Width="30" Height="28" Padding="0"
							Style="{StaticResource CategoryPanelToggleStyle}"
							IsChecked="{Binding IsAlwaysLoadedExpanded, Mode=TwoWay}"
							ToolTip="Collapse or expand Override Mods">
							<TextBlock Text="⌃" FontSize="15">
								<TextBlock.Style>
									<Style TargetType="TextBlock">
										<Setter Property="Text" Value="⌃" />
										<Style.Triggers>
											<DataTrigger Binding="{Binding IsAlwaysLoadedExpanded}" Value="False">
												<Setter Property="Text" Value="⌄" />
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</TextBlock.Style>
							</TextBlock>
						</ToggleButton>
					</Grid>
					<c:ModListView x:Name="ForceLoadedModsListView"
						Grid.Row="1"
						MaxHeight="99999"
						behavior:ScreenReaderHelperBehavior.Name="Force-Loaded Mods"
						ContextMenuOpening="ModListView_ContextMenuOpening"
						HideHeader="True"
						ItemContainerStyle="{StaticResource DivinityModDataListItem}"
						LinkedHeaderListView="{Binding ElementName=ActiveModsListView}"
						View="{DynamicResource HeaderlessModGridView}">
						<c:ModListView.ContextMenu><ContextMenu /></c:ModListView.ContextMenu>
					</c:ModListView>
				</Grid>
			</Grid>
		</Grid>
		</Border>
		<GridSplitter Grid.Column="3"
			Width="4"
			HorizontalAlignment="Stretch"
			VerticalAlignment="Stretch" />
		<Border Grid.Column="4"
			Margin="5,4,10,10"
			Style="{StaticResource ModSectionCard}">
		<Grid x:Name="InactiveModListGrid" HorizontalAlignment="Stretch">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="2" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>
			<Grid Margin="12,10,12,8">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="8" />
					<ColumnDefinition Width="220" />
				</Grid.ColumnDefinitions>
				<TextBlock Style="{StaticResource ModSectionTitle}" Text="Inactive Mods" />
			<c:UnfocusableTextBox x:Name="InactiveModsFilterTextBox"
					Grid.Column="5"
					Height="28"
					Padding="4,0"
					HorizontalAlignment="Stretch"
					VerticalAlignment="Center"
					behavior:ScreenReaderHelperBehavior.Name="Inactive Mods Filter"
					AcceptsReturn="False"
					AcceptsTab="False"
					adonisExtensions:CornerRadiusExtension.CornerRadius="{DynamicResource Redux.CornerRadius.ControlInner}"
					Background="{DynamicResource ReduxSurfaceMutedBrush}"
					BorderBrush="{DynamicResource ReduxBorderStrongBrush}"
					CanUndoTextOnEscape="True"
					TextAlignment="Left"
					ToolTip="Filter Inactive Mods"
					UpdateBindingOnFocusLost="True" />
				<TextBlock Grid.Column="5"
					Margin="0"
					Padding="4,0"
					HorizontalAlignment="Left"
					VerticalAlignment="Center"
					Foreground="{DynamicResource ReduxTextMutedBrush}"
					IsHitTestVisible="False"
					Text="Filter Inactive Mods">
					<TextBlock.Style>
						<Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="{x:Type TextBlock}">
							<Setter Property="Visibility" Value="Collapsed" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding Text, ElementName=InactiveModsFilterTextBox}" Value="">
									<Setter Property="Visibility" Value="Visible" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</TextBlock.Style>
				</TextBlock>
				<TextBlock x:Name="InactiveModsFilterResultText"
					Grid.Column="2"
					Margin="0,0,8,0"
					HorizontalAlignment="Left"
					VerticalAlignment="Center"
					behavior:ScreenReaderHelperBehavior.Name="Total Hidden Inactive Mods"
					AutomationProperties.HelpText="{Binding Text, RelativeSource={RelativeSource Self}}" />
				<TextBlock x:Name="InactiveSelectedText"
					Grid.Column="3"
					Margin="0,0,8,0"
					HorizontalAlignment="Left"
					VerticalAlignment="Center"
					behavior:ScreenReaderHelperBehavior.Name="Total Inactive Mods Selected"
					AutomationProperties.HelpText="{Binding Text, RelativeSource={RelativeSource Self}}"
					AutomationProperties.Name="Inactive Mods" />
			</Grid>
			<c:ModListView x:Name="InactiveModsListView"
				Grid.Row="2"
				MaxHeight="99999"
				behavior:ScreenReaderHelperBehavior.Name="Inactive Mods"
				dd:DragDrop.DragHandler="{Binding DragHandler}"
				dd:DragDrop.DropHandler="{Binding DropHandler}"
				ContextMenuOpening="ModListView_ContextMenuOpening"
				GridViewColumnHeader.Click="ListView_Click"
				GridViewColumnHeader.PreviewMouseLeftButtonUp="ListViewColumnHeader_PreviewMouseLeftButtonUp"
				GridViewColumnHeader.PreviewMouseRightButtonUp="ListViewColumnHeader_RightClick"
				ItemContainerStyle="{StaticResource ListViewItemMouseEvents}"
				Style="{StaticResource ModOrderListViewWithDrag}"
				View="{DynamicResource InactiveModGridView}"
				VirtualizingPanel.IsVirtualizing="True"
				VirtualizingPanel.VirtualizationMode="Recycling">
				<c:ModListView.ContextMenu><ContextMenu /></c:ModListView.ContextMenu>
			</c:ModListView>
		</Grid>
		</Border>
		<GridSplitter x:Name="ModDetailsGridSplitter"
			Grid.Row="1"
			Grid.ColumnSpan="5"
			Height="6"
			HorizontalAlignment="Stretch"
			VerticalAlignment="Stretch"
			Background="Transparent"
			Cursor="SizeNS"
			ResizeBehavior="PreviousAndNext"
			ResizeDirection="Rows"
			ShowsPreview="False"
			Visibility="Collapsed">
			<GridSplitter.PreviewStyle>
				<Style TargetType="{x:Type Control}">
					<Setter Property="Template">
						<Setter.Value>
							<ControlTemplate TargetType="{x:Type Control}">
								<Border Height="3"
									Margin="10,0"
									VerticalAlignment="Center"
									Background="{DynamicResource ReduxAccentHoverBrush}"
									CornerRadius="2">
									<Border.Effect>
										<DropShadowEffect BlurRadius="10"
											Color="{DynamicResource ReduxAccentHoverColor}"
											Opacity="0.9"
											ShadowDepth="0" />
									</Border.Effect>
								</Border>
							</ControlTemplate>
						</Setter.Value>
					</Setter>
				</Style>
			</GridSplitter.PreviewStyle>
			<GridSplitter.Template>
				<ControlTemplate TargetType="{x:Type GridSplitter}">
					<Grid Background="Transparent">
						<Border x:Name="InteractionGlow"
							Height="3"
							Margin="10,0"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Center"
							Background="{DynamicResource ReduxAccentHoverBrush}"
							CornerRadius="2"
							Opacity="0">
							<Border.Effect>
								<DropShadowEffect BlurRadius="8"
									Color="{DynamicResource ReduxAccentHoverColor}"
									Opacity="0.8"
									ShadowDepth="0" />
							</Border.Effect>
						</Border>
					</Grid>
					<ControlTemplate.Triggers>
						<EventTrigger RoutedEvent="MouseEnter">
							<BeginStoryboard>
								<Storyboard>
									<DoubleAnimation Storyboard.TargetName="InteractionGlow"
										Storyboard.TargetProperty="Opacity"
										To="0.9"
										Duration="0:0:0.14" />
								</Storyboard>
							</BeginStoryboard>
						</EventTrigger>
						<EventTrigger RoutedEvent="MouseLeave">
							<BeginStoryboard>
								<Storyboard>
									<DoubleAnimation Storyboard.TargetName="InteractionGlow"
										Storyboard.TargetProperty="Opacity"
										To="0"
										Duration="0:0:0.18" />
								</Storyboard>
							</BeginStoryboard>
						</EventTrigger>
					</ControlTemplate.Triggers>
				</ControlTemplate>
			</GridSplitter.Template>
		</GridSplitter>
		<Border x:Name="ModDetailsPanel"
			Grid.Row="2"
			Grid.ColumnSpan="5"
			Margin="10,0,10,10"
			Visibility="Collapsed">
			<Border.Style>
				<Style BasedOn="{StaticResource ModSectionCard}" TargetType="{x:Type Border}">
					<Setter Property="Background" Value="{DynamicResource ReduxSurfaceBrush}" />
					<Setter Property="BorderBrush" Value="{DynamicResource ReduxBorderStrongBrush}" />
				</Style>
			</Border.Style>
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="46" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>
				<Grid Margin="12,0">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>
					<Grid Width="14" Height="14" Margin="2,0,10,0" VerticalAlignment="Center" ToolTip="Primary mod category">
						<Ellipse Width="9" Height="9"
							Fill="{Binding Content.DisplayCategories[0].Color, ElementName=ModDetailsContent, FallbackValue=#8F879E}"
							Stroke="{DynamicResource ReduxBorderStrongBrush}" StrokeThickness="1">
							<Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Visibility" Value="Visible" /><Style.Triggers><DataTrigger Binding="{Binding Content.DisplayCategories[0].HasIcon, ElementName=ModDetailsContent}" Value="True"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger></Style.Triggers></Style></Ellipse.Style>
						</Ellipse>
						<c:ReduxIcon Width="14" Height="14"
							IconKey="{Binding Content.DisplayCategories[0].IconId, ElementName=ModDetailsContent}"
							Foreground="{Binding Content.DisplayCategories[0].Color, ElementName=ModDetailsContent, FallbackValue=#8F879E}">
							<c:ReduxIcon.Style><Style BasedOn="{StaticResource {x:Type c:ReduxIcon}}" TargetType="{x:Type c:ReduxIcon}"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding Content.DisplayCategories[0].HasIcon, ElementName=ModDetailsContent}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></c:ReduxIcon.Style>
						</c:ReduxIcon>
					</Grid>
					<TextBlock Grid.Column="1"
						VerticalAlignment="Center"
						FontSize="15"
						FontWeight="SemiBold"
						Foreground="{DynamicResource ReduxTextPrimaryBrush}"
						MaxWidth="420"
						Text="{Binding Content.Metadata.Title, ElementName=ModDetailsContent, TargetNullValue='Selected Mod'}"
						TextTrimming="CharacterEllipsis" />
					<ContentControl Grid.Column="2" Margin="9,0,0,0" VerticalAlignment="Center"
						Content="{Binding Content, ElementName=ModDetailsContent}"
						ContentTemplate="{StaticResource ModDetailsCategoryTemplate}" />
					<Border Grid.Column="3" MaxWidth="360" Margin="9,0,8,0" Padding="8,3"
						HorizontalAlignment="Left" VerticalAlignment="Center"
						Background="{DynamicResource ReduxSurfaceMutedBrush}"
						BorderBrush="{DynamicResource ReduxBorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource Redux.CornerRadius.Card}"
						ToolTip="{Binding Content.FileName, ElementName=ModDetailsContent}">
						<TextBlock FontSize="11" Foreground="{DynamicResource ReduxTextMutedBrush}"
							Text="{Binding Content.FileName, ElementName=ModDetailsContent, TargetNullValue='Local package'}"
							TextTrimming="CharacterEllipsis" />
					</Border>
					<ToggleButton x:Name="ModDetailsToggleButton"
						Grid.Column="4"
						IsChecked="True"
						Style="{StaticResource ModDetailsToggleStyle}"
						ToolTip="Collapse or expand mod details" />
				</Grid>
				<ContentControl x:Name="ModDetailsContent"
					Grid.Row="1"
					ContentTemplate="{StaticResource ModDetailsTabbedTemplate}">
					<ContentControl.Style>
						<Style TargetType="{x:Type ContentControl}">
							<Setter Property="Visibility" Value="Visible" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding IsChecked, ElementName=ModDetailsToggleButton}" Value="False">
									<Setter Property="Visibility" Value="Collapsed" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</ContentControl.Style>
				</ContentControl>
			</Grid>
		</Border>
	</Grid>
</local:HorizontalModLayoutBase>
