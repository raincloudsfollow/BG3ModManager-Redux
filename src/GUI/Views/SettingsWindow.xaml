<local:SettingsWindowBase x:Class="DivinityModManager.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
    xmlns:adonisUI="clr-namespace:AdonisUI;assembly=AdonisUI"
    xmlns:behavior="clr-namespace:DivinityModManager.Controls.Behavior"
    xmlns:c="clr-namespace:DivinityModManager.Controls"
    xmlns:controls="clr-namespace:DivinityModManager.Controls"
    xmlns:conv="clr-namespace:DivinityModManager.Converters"
    xmlns:core="clr-namespace:DivinityModManager;assembly=DivinityModManagerCore"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dapp="clr-namespace:DivinityModManager;assembly=DivinityModManagerCore"
    xmlns:data="clr-namespace:DivinityModManager.Models;assembly=DivinityModManagerCore"
    xmlns:dd="urn:gong-wpf-dragdrop"
    xmlns:ext="clr-namespace:DivinityModManager.Controls.Extensions"
    xmlns:extdata="clr-namespace:DivinityModManager.Models.Extender;assembly=DivinityModManagerCore"
    xmlns:local="clr-namespace:DivinityModManager.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mv="clr-namespace:DivinityModManager.Models.View"
    xmlns:reactiveui="http://reactiveui.net"
    xmlns:vm="clr-namespace:DivinityModManager.ViewModels"
    xmlns:xc="http://schemas.xceed.com/wpf/xaml/toolkit"
    Title="Preferences"
    Width="940"
    Height="780"
	MinWidth="900"
	MinHeight="700"
	FontFamily="{DynamicResource Redux.FontFamily.UI}" FontSize="{DynamicResource Redux.FontSize.12}"
	FontWeight="{DynamicResource Redux.FontWeight.Body}"
	TextOptions.TextFormattingMode="Ideal"
	TextOptions.TextRenderingMode="ClearType"
    TitleBarBackground="{DynamicResource ReduxSurfaceElevatedBrush}"
    TitleBarForeground="{DynamicResource ReduxTextPrimaryBrush}"
    mc:Ignorable="d">
	<Window.Style>
		<Style BasedOn="{StaticResource {x:Type Window}}" TargetType="Window" />
	</Window.Style>
	<Window.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="../Themes/MainResourceDictionary.xaml" />
			</ResourceDictionary.MergedDictionaries>
			<SolidColorBrush x:Key="SettingsWarningSoftBrush" Color="{DynamicResource ReduxWarningColor}" Opacity="0.14" />
			<SolidColorBrush x:Key="SettingsWarningHoverBrush" Color="{DynamicResource ReduxWarningColor}" Opacity="0.23" />
			<ControlTemplate x:Key="SettingsActionButtonTemplate" TargetType="{x:Type Button}">
				<Border x:Name="ButtonChrome"
					Background="{TemplateBinding Background}"
					BorderBrush="{TemplateBinding BorderBrush}"
					BorderThickness="{TemplateBinding BorderThickness}"
					CornerRadius="{DynamicResource Redux.CornerRadius.Pill}"
					SnapsToDevicePixels="True">
					<ContentPresenter Margin="{TemplateBinding Padding}"
						HorizontalAlignment="Center"
						VerticalAlignment="Center"
						Content="{TemplateBinding Content}"
						ContentTemplate="{TemplateBinding ContentTemplate}" />
				</Border>
				<ControlTemplate.Triggers>
					<Trigger Property="IsMouseOver" Value="True">
						<Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ReduxHoverBrush}" />
						<Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource ReduxAccentHoverBrush}" />
					</Trigger>
					<Trigger Property="IsPressed" Value="True">
						<Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ReduxPressedBrush}" />
						<Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource ReduxAccentBrush}" />
					</Trigger>
					<Trigger Property="IsEnabled" Value="False">
						<Setter TargetName="ButtonChrome" Property="Opacity" Value="0.45" />
					</Trigger>
					<MultiTrigger>
						<MultiTrigger.Conditions>
							<Condition Property="Tag" Value="Warning" />
							<Condition Property="IsMouseOver" Value="True" />
						</MultiTrigger.Conditions>
						<Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource ReduxWarningBrush}" />
						<Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource SettingsWarningHoverBrush}" />
					</MultiTrigger>
				</ControlTemplate.Triggers>
			</ControlTemplate>
			<Style x:Key="SettingsActionButtonStyle" TargetType="{x:Type Button}">
				<Setter Property="Height" Value="31" />
				<Setter Property="Padding" Value="12,3" />
				<Setter Property="Margin" Value="0,0,8,0" />
				<Setter Property="Background" Value="{DynamicResource ReduxAccentSoftBrush}" />
				<Setter Property="BorderBrush" Value="{DynamicResource ReduxAccentBrush}" />
				<Setter Property="BorderThickness" Value="1.5" />
				<Setter Property="Foreground" Value="{DynamicResource ReduxAccentHoverBrush}" />
				<Setter Property="Template" Value="{StaticResource SettingsActionButtonTemplate}" />
			</Style>
			<Style x:Key="SettingsTabControlStyle" TargetType="{x:Type TabControl}">
				<Setter Property="Background" Value="Transparent" />
				<Setter Property="BorderThickness" Value="0" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type TabControl}">
							<Grid>
								<Grid.RowDefinitions>
									<RowDefinition Height="46" />
									<RowDefinition Height="*" />
								</Grid.RowDefinitions>
								<Border Margin="12,0,12,6"
									Background="{DynamicResource ReduxSurfaceElevatedBrush}"
									BorderBrush="{DynamicResource ReduxBorderBrush}"
									BorderThickness="1"
									CornerRadius="{DynamicResource Redux.CornerRadius.Card}">
								<TabPanel Margin="6,4,6,6" ClipToBounds="False" IsItemsHost="True" />
								</Border>
								<Border Grid.Row="1"
									Margin="12,0,12,12"
									Background="{DynamicResource ReduxSurfaceBrush}"
									BorderBrush="{DynamicResource ReduxBorderBrush}"
									BorderThickness="1"
									CornerRadius="{DynamicResource Redux.CornerRadius.Card}">
									<ContentPresenter x:Name="PART_SelectedContentHost"
										ContentSource="SelectedContent"
										KeyboardNavigation.DirectionalNavigation="Contained"
										TextElement.Foreground="{DynamicResource ReduxTextPrimaryBrush}" />
								</Border>
							</Grid>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style x:Key="SettingsTabItemStyle" TargetType="{x:Type TabItem}">
				<Setter Property="Background" Value="Transparent" />
				<Setter Property="BorderBrush" Value="Transparent" />
				<Setter Property="BorderThickness" Value="1" />
				<Setter Property="ClipToBounds" Value="False" />
				<Setter Property="Cursor" Value="Hand" />
				<Setter Property="FocusVisualStyle" Value="{x:Null}" />
				<Setter Property="Foreground" Value="{DynamicResource ReduxTextSecondaryBrush}" />
				<Setter Property="Padding" Value="12,6" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type TabItem}">
							<!--
								Inter-tab gap lives on the template root, NOT on TabItem.Margin:
								TabPanel double-counts external child margins and applies a layout
								clip 4px narrower than the tab, shearing the hover pill's right
								corner (the same clip caused the original selected-pill clipping).
							-->
							<Grid x:Name="HeaderHost"
								Margin="0,0,4,0"
								Background="Transparent"
								TextElement.Foreground="{DynamicResource ReduxTextMutedBrush}">
								<Grid.RowDefinitions>
									<RowDefinition Height="*" />
									<RowDefinition Height="2" />
								</Grid.RowDefinitions>
								<Border x:Name="TabHoverSurface"
									Grid.RowSpan="2"
									Margin="2,3"
									Background="{DynamicResource ReduxHoverBrush}"
									CornerRadius="{DynamicResource Redux.CornerRadius.ControlInner}"
									IsHitTestVisible="False"
									Opacity="0" />
								<ContentPresenter Margin="{TemplateBinding Padding}"
									HorizontalAlignment="Center"
									VerticalAlignment="Center"
									ContentSource="Header"
									RecognizesAccessKey="True" />
								<Border x:Name="SelectionUnderline"
									Grid.Row="1"
									Margin="5,0"
									Background="{DynamicResource ReduxAccentBrush}"
									CornerRadius="1"
									Opacity="0"
									RenderTransformOrigin="0.5,0.5">
									<Border.RenderTransform>
										<ScaleTransform ScaleX="0.4" />
									</Border.RenderTransform>
								</Border>
							</Grid>
							<ControlTemplate.Triggers>
								<MultiTrigger>
									<MultiTrigger.Conditions>
										<Condition Property="IsMouseOver" Value="True" />
										<Condition Property="IsSelected" Value="False" />
									</MultiTrigger.Conditions>
									<MultiTrigger.EnterActions>
										<BeginStoryboard>
											<Storyboard>
												<DoubleAnimation Storyboard.TargetName="TabHoverSurface" Storyboard.TargetProperty="Opacity"
													To="1" Duration="{StaticResource Redux.Motion.Fast}" EasingFunction="{StaticResource Redux.Motion.EaseOut}" />
											</Storyboard>
										</BeginStoryboard>
									</MultiTrigger.EnterActions>
									<MultiTrigger.ExitActions>
										<BeginStoryboard>
											<Storyboard>
												<DoubleAnimation Storyboard.TargetName="TabHoverSurface" Storyboard.TargetProperty="Opacity"
													To="0" Duration="{StaticResource Redux.Motion.Standard}" />
											</Storyboard>
										</BeginStoryboard>
									</MultiTrigger.ExitActions>
								</MultiTrigger>
								<Trigger Property="IsMouseOver" Value="True">
									<Setter TargetName="HeaderHost" Property="TextElement.Foreground" Value="{DynamicResource ReduxTextPrimaryBrush}" />
								</Trigger>
								<Trigger Property="IsSelected" Value="True">
									<Setter Property="Panel.ZIndex" Value="1" />
									<Setter TargetName="HeaderHost" Property="TextElement.Foreground" Value="{DynamicResource ReduxAccentHoverBrush}" />
									<Setter TargetName="HeaderHost" Property="TextElement.FontWeight" Value="SemiBold" />
									<Trigger.EnterActions>
										<BeginStoryboard>
											<Storyboard>
												<DoubleAnimation Storyboard.TargetName="SelectionUnderline"
													Storyboard.TargetProperty="Opacity"
													To="1" Duration="0:0:0.14" />
												<DoubleAnimation Storyboard.TargetName="SelectionUnderline"
													Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
													To="1" Duration="0:0:0.14">
													<DoubleAnimation.EasingFunction>
														<QuadraticEase EasingMode="EaseOut" />
													</DoubleAnimation.EasingFunction>
												</DoubleAnimation>
											</Storyboard>
										</BeginStoryboard>
									</Trigger.EnterActions>
									<Trigger.ExitActions>
										<BeginStoryboard>
											<Storyboard>
												<DoubleAnimation Storyboard.TargetName="SelectionUnderline"
													Storyboard.TargetProperty="Opacity"
													To="0" Duration="0:0:0.10" />
												<DoubleAnimation Storyboard.TargetName="SelectionUnderline"
													Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
													To="0.4" Duration="0:0:0.10" />
											</Storyboard>
										</BeginStoryboard>
									</Trigger.ExitActions>
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style x:Key="SettingsPageTitleStyle" BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="{x:Type TextBlock}">
				<Setter Property="FontSize" Value="{DynamicResource Redux.FontSize.20}" />
				<Setter Property="FontWeight" Value="Bold" />
				<Setter Property="Foreground" Value="{DynamicResource ReduxTextPrimaryBrush}" />
			</Style>
			<Style x:Key="SettingsPageDescriptionStyle" BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="{x:Type TextBlock}">
				<Setter Property="Margin" Value="0,4,0,0" />
				<Setter Property="Foreground" Value="{DynamicResource ReduxTextSecondaryBrush}" />
				<Setter Property="TextWrapping" Value="Wrap" />
			</Style>
			<Style x:Key="SettingsSectionCardStyle" TargetType="{x:Type Border}">
				<Setter Property="Margin" Value="0,14,0,0" />
				<Setter Property="Padding" Value="16,14" />
				<Setter Property="Background" Value="{DynamicResource ReduxListInteriorBrush}" />
				<Setter Property="BorderBrush" Value="{DynamicResource ReduxBorderBrush}" />
				<Setter Property="BorderThickness" Value="1" />
				<Setter Property="CornerRadius" Value="8" />
			</Style>
			<Style x:Key="CompactThemeSectionCardStyle" BasedOn="{StaticResource SettingsSectionCardStyle}" TargetType="{x:Type Border}">
				<Setter Property="Margin" Value="0,10,0,0" />
				<Setter Property="Padding" Value="12,10" />
			</Style>
			<Style x:Key="SettingsSectionTitleStyle" BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="{x:Type TextBlock}">
				<Setter Property="FontSize" Value="{DynamicResource Redux.FontSize.13}" />
				<Setter Property="FontWeight" Value="SemiBold" />
				<Setter Property="Foreground" Value="{DynamicResource ReduxTextPrimaryBrush}" />
			</Style>
			<Style x:Key="SettingsSubsectionTitleStyle" BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="{x:Type TextBlock}">
				<Setter Property="Margin" Value="0,12,0,4" />
				<Setter Property="FontSize" Value="{DynamicResource Redux.FontSize.12}" />
				<Setter Property="FontWeight" Value="SemiBold" />
				<Setter Property="Foreground" Value="{DynamicResource ReduxAccentBrush}" />
			</Style>
			<Style x:Key="ThemeCardRadioStyle" TargetType="{x:Type RadioButton}">
				<Setter Property="Margin" Value="0,0,10,0" />
				<Setter Property="Padding" Value="10" />
				<Setter Property="Background" Value="{DynamicResource ReduxSurfaceElevatedBrush}" />
				<Setter Property="BorderBrush" Value="{DynamicResource ReduxBorderBrush}" />
				<Setter Property="BorderThickness" Value="1" />
				<Setter Property="Cursor" Value="Hand" />
				<Setter Property="FocusVisualStyle" Value="{x:Null}" />
				<Setter Property="HorizontalContentAlignment" Value="Stretch" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="{x:Type RadioButton}">
							<Border x:Name="CardSurface"
								Padding="{TemplateBinding Padding}"
								Background="{TemplateBinding Background}"
								BorderBrush="{TemplateBinding BorderBrush}"
								BorderThickness="{TemplateBinding BorderThickness}"
								CornerRadius="{DynamicResource Redux.CornerRadius.Card}">
								<Grid>
									<ContentPresenter />
									<Border x:Name="SelectionIndicator" Width="18" Height="18"
										HorizontalAlignment="Right" VerticalAlignment="Top"
										Background="{DynamicResource ReduxSurfaceBrush}"
										BorderBrush="{DynamicResource ReduxBorderStrongBrush}"
										BorderThickness="1" CornerRadius="9">
										<TextBlock x:Name="SelectionCheck" HorizontalAlignment="Center" VerticalAlignment="Center"
											FontSize="{DynamicResource Redux.FontSize.11}" FontWeight="Bold" Foreground="{DynamicResource ReduxAccentForegroundBrush}"
											Text="✓" Visibility="Collapsed" />
									</Border>
								</Grid>
							</Border>
							<ControlTemplate.Triggers>
								<Trigger Property="IsMouseOver" Value="True">
									<Setter TargetName="CardSurface" Property="BorderBrush" Value="{DynamicResource ReduxBorderStrongBrush}" />
									<Setter TargetName="CardSurface" Property="Background" Value="{DynamicResource ReduxSurfaceMutedBrush}" />
								</Trigger>
								<Trigger Property="IsChecked" Value="True">
									<Setter TargetName="CardSurface" Property="BorderBrush" Value="{DynamicResource ReduxAccentBrush}" />
									<Setter TargetName="CardSurface" Property="Background" Value="{DynamicResource ReduxAccentSoftBrush}" />
									<Setter TargetName="SelectionIndicator" Property="Background" Value="{DynamicResource ReduxAccentBrush}" />
									<Setter TargetName="SelectionIndicator" Property="BorderBrush" Value="{DynamicResource ReduxAccentHoverBrush}" />
									<Setter TargetName="SelectionCheck" Property="Visibility" Value="Visible" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
			<Style x:Key="SettingsWarningButtonStyle" BasedOn="{StaticResource SettingsActionButtonStyle}" TargetType="{x:Type Button}">
				<Setter Property="Tag" Value="Warning" />
				<Setter Property="Background" Value="{StaticResource SettingsWarningSoftBrush}" />
				<Setter Property="Foreground" Value="{DynamicResource ReduxWarningBrush}" />
				<Setter Property="BorderBrush" Value="{DynamicResource ReduxWarningBrush}" />
			</Style>
			<Style x:Key="SettingsListViewStyle" BasedOn="{StaticResource {x:Type ListView}}" TargetType="{x:Type ListView}">
				<Setter Property="Background" Value="{DynamicResource ReduxListInteriorBrush}" />
				<Setter Property="BorderBrush" Value="{DynamicResource ReduxBorderBrush}" />
				<Setter Property="BorderThickness" Value="0" />
				<Setter Property="Foreground" Value="{DynamicResource ReduxTextPrimaryBrush}" />
			</Style>
			<controls:AutomationTooltip x:Key="ExtenderUpdateEntryToolTip" DataContext="{Binding RelativeSource={RelativeSource Mode=Self}, Path=PlacementTarget.Tag}">
				<controls:AutomationTooltip.Resources>
					<DataTemplate x:Key="RegularVersionTooltip">
						<controls:AutoGrid Margin="10,0"
						    ChildMargin="4"
						    ColumnCount="2"
						    Columns="auto,*"
						    RowCount="4"
						    RowHeight="*"
						    Rows="auto,auto,auto,auto">
							<TextBlock Text="Build Date:" />
							<TextBlock Text="{Binding BuildDateDisplayString}" />
							<TextBlock Text="Game Version:" />
							<TextBlock Text="{Binding MinGameVersion}" />
							<TextBlock Text="Extender Version:" />
							<TextBlock Text="{Binding Version}" />
							<TextBlock Text="URL:" />
							<TextBlock Text="{Binding URL}" />
						</controls:AutoGrid>
					</DataTemplate>
					<DataTemplate x:Key="EmptyVersionTooltip">
						<TextBlock Text="The extender will automatically update to the latest version of the selected UpdateChannel" />
					</DataTemplate>
				</controls:AutomationTooltip.Resources>
				<controls:AutomationTooltip.Style>
					<Style BasedOn="{StaticResource {x:Type ToolTip}}" TargetType="controls:AutomationTooltip" />
				</controls:AutomationTooltip.Style>
				<ContentControl Content="{Binding}">
					<ContentControl.Style>
						<Style TargetType="{x:Type ContentControl}">
							<Setter Property="ContentTemplate" Value="{StaticResource RegularVersionTooltip}" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding IsEmpty}" Value="True">
									<Setter Property="ContentTemplate" Value="{StaticResource EmptyVersionTooltip}" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</ContentControl.Style>
				</ContentControl>
			</controls:AutomationTooltip>
			<Style BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
				<Setter Property="MinHeight" Value="30" />
				<Setter Property="Padding" Value="12,4" />
				<Setter Property="Margin" Value="2,0,2,0" />
			</Style>
			<Style TargetType="StackPanel">
				<Setter Property="VerticalAlignment" Value="Center" />
				<Setter Property="Orientation" Value="Horizontal" />
				<Setter Property="Margin" Value="10" />
			</Style>
			<Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="TextBlock">
				<Setter Property="VerticalAlignment" Value="Center" />
			</Style>
			<Style BasedOn="{StaticResource ReduxCheckBoxStyle}" TargetType="CheckBox">
				<Setter Property="VerticalAlignment" Value="Center" />
				<Setter Property="Margin" Value="0,1" />
			</Style>
			<Style TargetType="controls:AutoGrid">
				<Setter Property="Margin" Value="10,0" />
				<Setter Property="ChildMargin" Value="4" />
				<Setter Property="ColumnCount" Value="2" />
				<Setter Property="Columns" Value="*,*" />
				<Setter Property="RowCount" Value="1" />
				<Setter Property="RowHeight" Value="*" />
				<Setter Property="Rows" Value="auto" />
			</Style>
			<Style x:Key="TabItemWithContextMenu" BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="TextBlock">
				<Setter Property="ContextMenu">
					<Setter.Value>
						<ContextMenu DataContext="{Binding RelativeSource={RelativeSource Mode=Self}, Path=PlacementTarget.Tag}">
							<MenuItem Command="{Binding Path=OpenInFileExplorerCommand, Source={x:Static dapp:DivinityApp.Commands}}" CommandParameter="{Binding}" Header="Open in File Explorer...">
								<MenuItem.Icon><controls:ReduxIcon StrokeData="{StaticResource Redux.Icon.FolderOpen}" /></MenuItem.Icon>
							</MenuItem>
							<MenuItem Command="{Binding CopyPathToClipboardCommand}" CommandParameter="{Binding}" Header="Copy Path to Clipboard">
								<MenuItem.Icon><controls:ReduxIcon StrokeData="{StaticResource Redux.Icon.Copy}" /></MenuItem.Icon>
							</MenuItem>
						</ContextMenu>
					</Setter.Value>
				</Setter>
			</Style>
			<DataTemplate x:Key="EnumEntryTemplate" DataType="mv:EnumEntry">
				<TextBlock Text="{Binding Name}" ToolTip="{Binding Description}" />
			</DataTemplate>
		</ResourceDictionary>
	</Window.Resources>
	<Grid Background="{DynamicResource ReduxWindowBrush}">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>
		<Border Margin="12,10,12,8"
			Padding="10,8"
			Background="{DynamicResource ReduxSurfaceElevatedBrush}"
			BorderBrush="{DynamicResource ReduxBorderBrush}"
			BorderThickness="1"
			CornerRadius="{DynamicResource Redux.CornerRadius.Card}">
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="2*" />
				<ColumnDefinition Width="1*" />
			</Grid.ColumnDefinitions>
			<StackPanel Margin="0" HorizontalAlignment="Left" Orientation="Horizontal">
				<Button x:Name="SaveSettingsButton" Style="{StaticResource SettingsActionButtonStyle}" ToolTip="Save all Preferences now (Ctrl+S)">
					<StackPanel Margin="0" Orientation="Horizontal">
						<controls:ReduxIcon Margin="0,0,6,0" StrokeData="{StaticResource Redux.Icon.Save}" />
						<TextBlock Text="Save Preferences" />
					</StackPanel>
				</Button>
				<Button x:Name="OpenSettingsFolderButton" Style="{StaticResource SettingsActionButtonStyle}" ToolTip="Open Settings Folder">
					<StackPanel Margin="0" Orientation="Horizontal">
						<controls:ReduxIcon Margin="0,0,6,0" StrokeData="{StaticResource Redux.Icon.FolderOpen}" />
						<TextBlock Text="Settings Folder" />
					</StackPanel>
				</Button>
			</StackPanel>
			<Button x:Name="ResetSettingsButton"
			    Grid.Column="1"
			    HorizontalAlignment="Right"
			    Style="{StaticResource SettingsWarningButtonStyle}">
				<StackPanel Margin="0" Orientation="Horizontal">
					<controls:ReduxIcon Margin="0,0,6,0" Foreground="{DynamicResource ReduxWarningBrush}" StrokeData="{StaticResource Redux.Icon.RefreshStroke}" />
					<TextBlock Text="Reset" />
				</StackPanel>
			</Button>
		</Grid>
		</Border>

		<TabControl x:Name="PreferencesTabControl"
			Grid.Row="1"
			ItemContainerStyle="{StaticResource SettingsTabItemStyle}"
			Style="{StaticResource SettingsTabControlStyle}">
			<TabItem x:Name="GeneralSettingssTab" FocusManager.FocusedElement="{Binding ElementName=SettingsAutoGrid}">
				<TabItem.Header>
					<TextBlock x:Name="GeneralSettingsTabHeader"
					    Style="{StaticResource TabItemWithContextMenu}"
					    Text="General"
					    ToolTip="Mod Manager Settings (Data/settings.json)" />
				</TabItem.Header>
				<ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
					<Grid Margin="18,14">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>
						<TextBlock Style="{StaticResource SettingsPageTitleStyle}" Text="General preferences" />
						<TextBlock Grid.Row="1"
							Style="{StaticResource SettingsPageDescriptionStyle}"
							Text="Core mod manager behavior, paths, integrations, and everyday workflow." />
						<Border Grid.Row="2" Style="{StaticResource SettingsSectionCardStyle}">
							<Grid>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="1" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>
								<TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="General settings" />
								<Border Grid.Row="1" Margin="0,10,0,0" Background="{DynamicResource ReduxBorderBrush}" />
								<controls:AutoGrid x:Name="SettingsAutoGrid" Grid.Row="2" Margin="0,12,0,0" Columns="2*,3*" />
							</Grid>
						</Border>
					</Grid>
				</ScrollViewer>
			</TabItem>
			<TabItem x:Name="AppearanceSettingsTab">
				<TabItem.Header><TextBlock Text="Theme &amp; Appearance" ToolTip="Redux colors and appearance" /></TabItem.Header>
				<TabItem.Resources>
					<Style TargetType="{x:Type StackPanel}">
						<Setter Property="Margin" Value="0" />
						<Setter Property="Orientation" Value="Vertical" />
					</Style>
				</TabItem.Resources>
				<ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
					<Grid Margin="18,12">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="1" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>
						<TextBlock Style="{StaticResource SettingsPageTitleStyle}" Text="Theme &amp; Appearance" />
						<TextBlock Grid.Row="1" Style="{StaticResource SettingsPageDescriptionStyle}"
							Text="Customize the look and feel of Redux. Themes control colors and surfaces, while typography can be selected independently." />
						<Border Grid.Row="2" Margin="0,12,0,0" Background="{DynamicResource ReduxBorderBrush}" />

						<StackPanel Grid.Row="3" Margin="0,12,0,0">
							<Grid Margin="0,0,0,8">
								<TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="Built-in themes" />
								<TextBlock HorizontalAlignment="Right" Foreground="{DynamicResource ReduxTextMutedBrush}" Text="Ctrl+L cycles built-in themes" />
							</Grid>
							<ComboBox x:Name="ThemeComboBox" Width="1" Height="1" HorizontalAlignment="Left" Opacity="0"
								IsHitTestVisible="False" IsTabStop="False" DisplayMemberPath="Description"
								ItemsSource="{Binding Source={ext:EnumExtension {x:Type data:ReduxThemeType}}}" SelectedValuePath="Value"
								SelectionChanged="ThemeComboBox_SelectionChanged" />
							<UniformGrid Columns="3">
								<RadioButton x:Name="ReduxDarkThemeCard" GroupName="BuiltInThemes" Style="{StaticResource ThemeCardRadioStyle}"
									Tag="{x:Static data:ReduxThemeType.ReduxDark}" Click="ThemeCard_Click">
									<StackPanel>
										<Border Height="76" Margin="0,0,0,8" Padding="8" Background="#17151C" BorderBrush="#3A3346" BorderThickness="1" CornerRadius="6">
											<Grid>
												<Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
												<Border Margin="0,0,7,0" Background="#211D28" CornerRadius="4" />
												<StackPanel Grid.Column="1">
													<Border Height="13" Margin="0,0,0,7" Background="#2A2433" CornerRadius="3" />
													<Border Height="21" Margin="0,0,0,6" Background="#342B49" CornerRadius="3" />
													<Border Height="7" Width="54" HorizontalAlignment="Left" Background="#8A6AF1" CornerRadius="3" />
												</StackPanel>
											</Grid>
										</Border>
										<TextBlock FontSize="{DynamicResource Redux.FontSize.14}" FontWeight="SemiBold" Foreground="{DynamicResource ReduxTextPrimaryBrush}" Text="Redux Dark" />
										<TextBlock Margin="0,3,0,0" FontSize="{DynamicResource Redux.FontSize.11}" Foreground="{DynamicResource ReduxTextMutedBrush}" Text="Deep, focused, and easy on the eyes." TextWrapping="Wrap" />
									</StackPanel>
								</RadioButton>
								<RadioButton x:Name="ReduxLightThemeCard" GroupName="BuiltInThemes" Style="{StaticResource ThemeCardRadioStyle}"
									Tag="{x:Static data:ReduxThemeType.ReduxLight}" Click="ThemeCard_Click">
									<StackPanel>
										<Border Height="76" Margin="0,0,0,8" Padding="8" Background="#F5F3FA" BorderBrush="#C9C4D7" BorderThickness="1" CornerRadius="6">
											<Grid>
												<Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
												<Border Margin="0,0,7,0" Background="#EAE6F2" CornerRadius="4" />
												<StackPanel Grid.Column="1">
													<Border Height="13" Margin="0,0,0,7" Background="#FFFFFF" CornerRadius="3" />
													<Border Height="21" Margin="0,0,0,6" Background="#EAE6FF" CornerRadius="3" />
													<Border Height="7" Width="54" HorizontalAlignment="Left" Background="#6755E8" CornerRadius="3" />
												</StackPanel>
											</Grid>
										</Border>
										<TextBlock FontSize="{DynamicResource Redux.FontSize.14}" FontWeight="SemiBold" Foreground="{DynamicResource ReduxTextPrimaryBrush}" Text="Redux Light" />
										<TextBlock Margin="0,3,0,0" FontSize="{DynamicResource Redux.FontSize.11}" Foreground="{DynamicResource ReduxTextMutedBrush}" Text="Clean and bright for daytime use." TextWrapping="Wrap" />
									</StackPanel>
								</RadioButton>
								<RadioButton x:Name="ParchmentThemeCard" GroupName="BuiltInThemes" Margin="0" Style="{StaticResource ThemeCardRadioStyle}"
									Tag="{x:Static data:ReduxThemeType.Parchment}" Click="ThemeCard_Click">
									<StackPanel>
										<Border Height="76" Margin="0,0,0,8" Padding="8" Background="#E6DCC6" BorderBrush="#A89980" BorderThickness="1" CornerRadius="6">
											<Grid>
												<Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
												<Border Margin="0,0,7,0" Background="#D8CCB2" CornerRadius="4" />
												<StackPanel Grid.Column="1">
													<Border Height="13" Margin="0,0,0,7" Background="#EDE2CC" CornerRadius="3" />
													<Border Height="21" Margin="0,0,0,6" Background="#D5B4A8" CornerRadius="3" />
													<Border Height="7" Width="54" HorizontalAlignment="Left" Background="#7B1E1E" CornerRadius="3" />
												</StackPanel>
											</Grid>
										</Border>
										<TextBlock FontSize="{DynamicResource Redux.FontSize.14}" FontWeight="SemiBold" Foreground="{DynamicResource ReduxTextPrimaryBrush}" Text="Parchment" />
										<TextBlock Margin="0,3,0,0" FontSize="{DynamicResource Redux.FontSize.11}" Foreground="{DynamicResource ReduxTextMutedBrush}" Text="Warm parchment tones for a classic feel." TextWrapping="Wrap" />
									</StackPanel>
								</RadioButton>
							</UniformGrid>
						</StackPanel>

						<Border Grid.Row="4" Margin="0,10,0,0" Style="{StaticResource CompactThemeSectionCardStyle}">
							<StackPanel>
								<StackPanel Orientation="Horizontal">
									<TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="Theme details" />
									<TextBlock Margin="6,0,0,0" Foreground="{DynamicResource ReduxTextMutedBrush}"
										Text="{Binding SelectedItem.Description, ElementName=ThemeComboBox, StringFormat=(Current: {0})}" />
								</StackPanel>
								<UniformGrid Margin="0,8,0,0" Columns="6">
									<StackPanel Margin="0,0,6,0"><TextBlock Margin="0,0,0,4" FontSize="{DynamicResource Redux.FontSize.10}" Text="Background" /><Border Height="26" Background="{DynamicResource ReduxWindowBrush}" BorderBrush="{DynamicResource ReduxBorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource Redux.CornerRadius.Small}" /></StackPanel>
									<StackPanel Margin="0,0,6,0"><TextBlock Margin="0,0,0,4" FontSize="{DynamicResource Redux.FontSize.10}" Text="Surface" /><Border Height="26" Background="{DynamicResource ReduxSurfaceBrush}" BorderBrush="{DynamicResource ReduxBorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource Redux.CornerRadius.Small}" /></StackPanel>
									<StackPanel Margin="0,0,6,0"><TextBlock Margin="0,0,0,4" FontSize="{DynamicResource Redux.FontSize.10}" Text="Accent" /><Border Height="26" Background="{DynamicResource ReduxAccentBrush}" CornerRadius="{DynamicResource Redux.CornerRadius.Small}" /></StackPanel>
									<StackPanel Margin="0,0,6,0"><TextBlock Margin="0,0,0,4" FontSize="{DynamicResource Redux.FontSize.10}" Text="Success" /><Border Height="26" Background="{DynamicResource ReduxSuccessBrush}" CornerRadius="{DynamicResource Redux.CornerRadius.Small}" /></StackPanel>
									<StackPanel Margin="0,0,6,0"><TextBlock Margin="0,0,0,4" FontSize="{DynamicResource Redux.FontSize.10}" Text="Warning" /><Border Height="26" Background="{DynamicResource ReduxWarningBrush}" CornerRadius="{DynamicResource Redux.CornerRadius.Small}" /></StackPanel>
									<StackPanel><TextBlock Margin="0,0,0,4" FontSize="{DynamicResource Redux.FontSize.10}" Text="Error" /><Border Height="26" Background="{DynamicResource ReduxErrorBrush}" CornerRadius="{DynamicResource Redux.CornerRadius.Small}" /></StackPanel>
								</UniformGrid>
								<Border Height="1" Margin="0,10,0,8" Background="{DynamicResource ReduxBorderBrush}" />
								<TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="Theme behavior" />
								<UniformGrid Margin="0,7,0,0" Columns="3">
									<CheckBox Margin="0,0,12,0" VerticalAlignment="Top"
										IsChecked="{Binding Settings.UseCategoryColorsForHover, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
										<StackPanel Margin="6,0,0,0"><TextBlock FontWeight="SemiBold" Text="Match hover to category" /><TextBlock Margin="0,3,0,0" Foreground="{DynamicResource ReduxTextMutedBrush}" Text="Use the category color for mod-row hover." TextWrapping="Wrap" /></StackPanel>
									</CheckBox>
									<CheckBox Margin="0,0,12,0" VerticalAlignment="Top"
										IsChecked="{Binding Settings.ShowCategoryIconsInPills, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
										<StackPanel Margin="6,0,0,0"><TextBlock FontWeight="SemiBold" Text="Icons in category pills" /><TextBlock Margin="0,3,0,0" Foreground="{DynamicResource ReduxTextMutedBrush}" Text="Show category icons in list and drawer pills." TextWrapping="Wrap" /></StackPanel>
									</CheckBox>
									<CheckBox VerticalAlignment="Top"
										IsChecked="{Binding Settings.UseCategoryColorsForSidebarText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
										<StackPanel Margin="6,0,0,0"><TextBlock FontWeight="SemiBold" Text="Color category names" /><TextBlock Margin="0,3,0,0" Foreground="{DynamicResource ReduxTextMutedBrush}" Text="Match sidebar names to category colors." TextWrapping="Wrap" /></StackPanel>
									</CheckBox>
								</UniformGrid>
							</StackPanel>
						</Border>

						<Border Grid.Row="5" Margin="0,10,0,0" Style="{StaticResource CompactThemeSectionCardStyle}">
							<Grid>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="10" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="10" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>

								<Grid>
									<Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
									<Border Width="32" Height="32" Margin="0,0,10,0"
										Background="{DynamicResource ReduxAccentSoftBrush}"
										BorderBrush="{DynamicResource ReduxAccentBrush}"
										BorderThickness="1"
										CornerRadius="16">
										<controls:ReduxIcon Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center" StrokeData="{StaticResource Redux.Icon.ColorPalette}" />
									</Border>
									<StackPanel Grid.Column="1" Margin="0" Orientation="Vertical">
										<TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="Typography &amp; custom themes" />
										<TextBlock Margin="0,3,0,0" Foreground="{DynamicResource ReduxTextMutedBrush}"
											Text="Tune Redux typography and manage reusable themes in one place."
											TextWrapping="Wrap" />
									</StackPanel>
								</Grid>

								<Border Grid.Row="2" Padding="12" Background="{DynamicResource ReduxSurfaceMutedBrush}"
									BorderBrush="{DynamicResource ReduxBorderBrush}" BorderThickness="1"
									CornerRadius="{DynamicResource Redux.CornerRadius.Card}">
								<Grid>
									<Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
									<StackPanel Margin="0,0,16,0" Orientation="Vertical">
										<TextBlock FontWeight="SemiBold" Text="Typography" />
										<TextBlock Margin="0,3,0,0" Foreground="{DynamicResource ReduxTextMutedBrush}"
										Text="Typeface and text size apply throughout Redux." TextWrapping="Wrap" />
										<TextBlock x:Name="TypographyPreviewText" Margin="0,6,0,0" FontSize="{DynamicResource Redux.FontSize.22}"
											FontFamily="{DynamicResource Redux.FontFamily.UI}"
											Text="Aa Qg 0O 1Il" />
										<TextBlock Margin="0,7,0,0" FontSize="{DynamicResource Redux.FontSize.11}"
											Foreground="{DynamicResource ReduxTextMutedBrush}"
											Text="Imported fonts are provided as-is; some may render incorrectly or may not be compatible with Redux."
											TextWrapping="Wrap" />
									</StackPanel>
									<StackPanel Grid.Column="1" Width="306" Margin="0,0,10,0" Orientation="Vertical">
										<TextBlock Margin="2,0,0,4" Foreground="{DynamicResource ReduxTextMutedBrush}" Text="Typeface" />
										<Grid>
											<Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
											<ComboBox x:Name="TypographyComboBox" DisplayMemberPath="Name"
												SelectionChanged="TypographyComboBox_SelectionChanged"
												ToolTip="Choose a bundled or imported typeface" />
											<Button Grid.Column="1" Width="32" MinWidth="32" Margin="6,0,0,0" Padding="7"
												Style="{StaticResource SettingsActionButtonStyle}" Click="ImportCustomFont_Click"
												ToolTip="Import a TrueType or OpenType font">
												<controls:ReduxIcon Width="14" Height="14" StrokeData="{StaticResource Redux.Icon.Download}" />
											</Button>
											<Button x:Name="DeleteCustomFontButton" Grid.Column="2" Width="32" MinWidth="32" Margin="6,0,0,0" Padding="7"
												Style="{StaticResource SettingsActionButtonStyle}" Click="DeleteCustomFont_Click"
												ToolTip="Remove the selected imported font">
												<controls:ReduxIcon Width="14" Height="14" StrokeData="{StaticResource Redux.Icon.Trash}" Foreground="{DynamicResource ReduxErrorBrush}" />
											</Button>
											<Button Grid.Column="3" Width="32" MinWidth="32" Margin="6,0,0,0" Padding="7"
												Style="{StaticResource SettingsActionButtonStyle}" Click="OpenCustomFontsFolder_Click"
												ToolTip="Open the custom fonts folder">
												<controls:ReduxIcon Width="14" Height="14" StrokeData="{StaticResource Redux.Icon.FolderOpen}" />
											</Button>
										</Grid>
									</StackPanel>
									<StackPanel Grid.Column="2" Width="140" Orientation="Vertical">
										<TextBlock Margin="2,0,0,4" Foreground="{DynamicResource ReduxTextMutedBrush}" Text="Text size" />
										<ComboBox x:Name="TextSizeComboBox"
											DisplayMemberPath="Description"
											ItemsSource="{Binding Source={ext:EnumExtension {x:Type data:ReduxTextSize}}}"
											SelectedValuePath="Value"
											ToolTip="Choose Compact, Default, or Large interface text" />
									</StackPanel>
								</Grid>
								</Border>

								<Border Grid.Row="4" Padding="12" Background="{DynamicResource ReduxSurfaceMutedBrush}"
									BorderBrush="{DynamicResource ReduxBorderBrush}" BorderThickness="1"
									CornerRadius="{DynamicResource Redux.CornerRadius.Card}">
								<Grid>
									<Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
									<Grid>
										<StackPanel Margin="0" Orientation="Vertical">
											<TextBlock FontWeight="SemiBold" Text="Custom themes" />
											<TextBlock Margin="0,3,0,0" Foreground="{DynamicResource ReduxTextMutedBrush}"
												Text="Save colors, typeface, and text size as a reusable theme." TextWrapping="Wrap" />
											<TextBlock x:Name="CustomThemeStatusText" Margin="0,5,0,0"
												Foreground="{DynamicResource ReduxTextMutedBrush}" Text="No custom themes yet." TextTrimming="CharacterEllipsis" />
										</StackPanel>
									</Grid>

									<Grid Grid.Row="1" Margin="0,10,0,0">
										<Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
										<ComboBox x:Name="CustomThemeComboBox" MinWidth="240" DisplayMemberPath="Name"
											SelectionChanged="CustomThemeComboBox_SelectionChanged" ToolTip="Select and apply a custom theme" />
										<Button Grid.Column="1" MinWidth="82" Margin="8,0,0,0" Style="{StaticResource SettingsActionButtonStyle}" Click="CreateCustomTheme_Click">
											<StackPanel Margin="0" Orientation="Horizontal"><controls:ReduxIcon Margin="0,0,6,0" StrokeData="{StaticResource Redux.Icon.AddCircle}" /><TextBlock Text="Create" /></StackPanel>
										</Button>
										<Button x:Name="EditCustomThemeButton" Grid.Column="2" MinWidth="74" Margin="6,0,0,0" Style="{StaticResource SettingsActionButtonStyle}" Click="EditCustomTheme_Click">
											<StackPanel Margin="0" Orientation="Horizontal"><controls:ReduxIcon Margin="0,0,6,0" StrokeData="{StaticResource Redux.Icon.Create}" /><TextBlock Text="Edit" /></StackPanel>
										</Button>
										<Button x:Name="DeleteCustomThemeButton" Grid.Column="3" MinWidth="82" Margin="6,0,0,0" Style="{StaticResource SettingsActionButtonStyle}" Click="DeleteCustomTheme_Click">
											<StackPanel Margin="0" Orientation="Horizontal"><controls:ReduxIcon Margin="0,0,6,0" StrokeData="{StaticResource Redux.Icon.Trash}" Foreground="{DynamicResource ReduxErrorBrush}" /><TextBlock Text="Delete" /></StackPanel>
										</Button>
									</Grid>

									<Grid Grid.Row="2" Margin="0,6,0,0">
										<Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
										<Button x:Name="DuplicateCustomThemeButton" Grid.Column="1" MinWidth="92" Margin="0" Style="{StaticResource SettingsActionButtonStyle}" Click="DuplicateCustomTheme_Click" Content="Duplicate" />
										<Button Grid.Column="2" MinWidth="80" Margin="6,0,0,0" Style="{StaticResource SettingsActionButtonStyle}" Click="ImportCustomTheme_Click">
											<StackPanel Margin="0" Orientation="Horizontal"><controls:ReduxIcon Margin="0,0,6,0" StrokeData="{StaticResource Redux.Icon.Download}" /><TextBlock Text="Import" /></StackPanel>
										</Button>
										<Button x:Name="ExportCustomThemeButton" Grid.Column="3" MinWidth="80" Margin="6,0,0,0" Style="{StaticResource SettingsActionButtonStyle}" Click="ExportCustomTheme_Click">
											<StackPanel Margin="0" Orientation="Horizontal"><controls:ReduxIcon Margin="0,0,6,0" StrokeData="{StaticResource Redux.Icon.CloudUpload}" /><TextBlock Text="Export" /></StackPanel>
										</Button>
									</Grid>
								</Grid>
								</Border>
							</Grid>
						</Border>
					</Grid>
				</ScrollViewer>
			</TabItem>
			<TabItem x:Name="ScriptExtenderTab" FocusManager.FocusedElement="{Binding ElementName=ExtenderSettingsAutoGrid}">
				<TabItem.Header>
					<TextBlock x:Name="ScriptExtenderTabHeader"
					    Style="{StaticResource TabItemWithContextMenu}"
					    Text="Script Extender"
					    ToolTip="Script Extender Settings (ScriptExtenderSettings.json)" />
				</TabItem.Header>
				<ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
					<Grid Margin="18,14">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>
						<TextBlock Style="{StaticResource SettingsPageTitleStyle}" Text="Script Extender" />
						<TextBlock Grid.Row="1"
							Style="{StaticResource SettingsPageDescriptionStyle}"
							Text="Configure Script Extender behavior without changing your installed mods or load order." />
						<Border Grid.Row="2" Style="{StaticResource SettingsSectionCardStyle}">
							<Grid>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="1" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>
								<TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="Extender settings" />
								<Border Grid.Row="1" Margin="0,10,0,0" Background="{DynamicResource ReduxBorderBrush}" />
								<controls:AutoGrid x:Name="ExtenderSettingsAutoGrid" Grid.Row="2" Margin="0,12,0,0" />
							</Grid>
						</Border>
					</Grid>
				</ScrollViewer>
			</TabItem>
			<TabItem x:Name="ScriptExtenderUpdaterTab" FocusManager.FocusedElement="{Binding ElementName=ExtenderUpdaterSettingsAutoGrid}">
				<TabItem.Header>
					<TextBlock x:Name="UpdaterTabHeader"
					    Style="{StaticResource TabItemWithContextMenu}"
					    Text="Updater"
					    ToolTip="Script Extender Updater Settings (ScriptExtenderUpdaterConfig.json)" />
				</TabItem.Header>
				<ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
					<Grid Margin="18,14">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>
						<TextBlock Style="{StaticResource SettingsPageTitleStyle}" Text="Extender updater" />
						<TextBlock Grid.Row="1"
							Style="{StaticResource SettingsPageDescriptionStyle}"
							Text="Choose how Script Extender update information is retrieved and which version is targeted." />
						<Border Grid.Row="2" Style="{StaticResource SettingsSectionCardStyle}">
							<Grid>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="1" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>
								<TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="Update source and version" />
								<Border Grid.Row="1" Margin="0,10,0,0" Background="{DynamicResource ReduxBorderBrush}" />
								<controls:AutoGrid x:Name="ExtenderUpdaterSettingsAutoGrid" Grid.Row="2" Margin="0,12,0,0">
							<TextBlock x:Name="UpdateChannelTextBlock"
							    Grid.Column="0"
							    behavior:TextBlockSettingsEntryAttributeBehavior.Property="UpdateChannel"
							    behavior:TextBlockSettingsEntryAttributeBehavior.TargetType="{x:Type extdata:ScriptExtenderUpdateConfig}"
							    Text="Update Channel" />
							<ComboBox x:Name="UpdateChannelComboBox"
							    DisplayMemberPath="Description"
							    ItemsSource="{Binding Source={ext:EnumExtension {x:Type core:ExtenderUpdateChannel}}}"
							    SelectedValuePath="Value"
							    ToolTip="{Binding ElementName=UpdateChannelTextBlock, Path=ToolTip}" />
							<TextBlock x:Name="SelectVersionTextBlock"
							    Grid.Column="0"
							    Text="Select Version"
							    ToolTip="Select a version to automatically set the Target Version and Target Digest&#x0a;This list is automatically populated from the online extender manifest data, using the selected Update Channel" />
							<ComboBox x:Name="UpdaterTargetVersionComboBox"
							    Grid.Column="1"
							    DisplayMemberPath="DisplayName"
							    ToolTip="{StaticResource ExtenderUpdateEntryToolTip}" />
								</controls:AutoGrid>
							</Grid>
						</Border>
					</Grid>
				</ScrollViewer>
			</TabItem>
			<TabItem x:Name="KeybindingsTabItem" FocusManager.FocusedElement="{Binding ElementName=KeybindingsListView}">
				<TabItem.Header>
					<TextBlock x:Name="KeybindingsTabHeader"
					    Style="{StaticResource TabItemWithContextMenu}"
					    Text="Keyboard Shortcuts"
					    ToolTip="Mod Manager Settings (Data/keybindings.json)" />
				</TabItem.Header>
				<Grid Margin="18,14">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>
					<TextBlock Style="{StaticResource SettingsPageTitleStyle}" Text="Keyboard shortcuts" />
					<TextBlock Grid.Row="1"
						Style="{StaticResource SettingsPageDescriptionStyle}"
						Text="Double-click a shortcut to edit it, or right-click for reset and remove options." />
					<Border Grid.Row="2"
						Padding="0"
						ClipToBounds="True"
						Style="{StaticResource SettingsSectionCardStyle}">
						<ListView x:Name="KeybindingsListView"
				    KeyboardNavigation.TabNavigation="Continue"
				    MouseDoubleClick="HotkeyListViewItem_MouseDoubleClick"
				    ScrollViewer.VerticalScrollBarVisibility="Auto"
				    Style="{StaticResource SettingsListViewStyle}">
					<ListView.ItemContainerStyle>
						<Style BasedOn="{StaticResource {x:Type ListViewItem}}" TargetType="ListViewItem">
							<Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
							<Setter Property="Tag" Value="{Binding}" />
							<Setter Property="HorizontalContentAlignment" Value="Stretch" />
							<Setter Property="VerticalContentAlignment" Value="Stretch" />
							<Setter Property="ToolTip" Value="{Binding ToolTip}" />
							<Setter Property="ContextMenu">
								<Setter.Value>
									<ContextMenu>
										<MenuItem x:Name="ResetHotkeyMenuItem" Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}, Path=PlacementTarget.DataContext.ResetCommand}" Header="Reset Keybinding">
											<MenuItem.Icon><controls:ReduxIcon StrokeData="{StaticResource Redux.Icon.RefreshStroke}" /></MenuItem.Icon>
										</MenuItem>
										<MenuItem x:Name="ClearHotkeyMenuItem" Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ContextMenu}}, Path=PlacementTarget.DataContext.ClearCommand}" Header="Remove Keybinding">
											<MenuItem.Icon><controls:ReduxIcon StrokeData="{StaticResource Redux.Icon.RemoveCircle}" Foreground="{DynamicResource ReduxErrorBrush}" /></MenuItem.Icon>
										</MenuItem>
									</ContextMenu>
								</Setter.Value>
							</Setter>
						</Style>
					</ListView.ItemContainerStyle>
					<ListView.View>
						<GridView AllowsColumnReorder="False" ColumnHeaderContainerStyle="{StaticResource GridViewLeftContainerStyle}">
							<GridView.Columns>
								<GridViewColumn Width="450" Header="Command" HeaderTemplate="{StaticResource GridViewTextblockHeaderTemplate}">
									<GridViewColumn.CellTemplate>
										<DataTemplate>
											<TextBlock Margin="0,4"
											    Padding="0"
											    HorizontalAlignment="Stretch"
											    VerticalAlignment="Bottom"
											    IsHitTestVisible="False"
											    TextAlignment="Left">
												<Run Foreground="{DynamicResource ReduxSuccessBrush}" Text="{Binding ModifiedText, Mode=OneWay}" />
												<Run Text="{Binding DisplayName, Mode=OneWay}" /></TextBlock>
										</DataTemplate>
									</GridViewColumn.CellTemplate>
								</GridViewColumn>
								<GridViewColumn Width="200" Header="Keybinding" HeaderTemplate="{StaticResource GridViewTextblockHeaderTemplate}">
									<GridViewColumn.CellTemplate>
										<DataTemplate>
											<controls:HotkeyEditorControl HorizontalAlignment="Left"
											    FocusReturnTarget="{Binding ElementName=KeybindingsListView}"
											    GotFocus="HotkeyEditorControl_GotFocus"
											    Hotkey="{Binding}"
											    LostFocus="HotkeyEditorControl_LostFocus" />
										</DataTemplate>
									</GridViewColumn.CellTemplate>
								</GridViewColumn>
							</GridView.Columns>
						</GridView>
					</ListView.View>
						</ListView>
					</Border>
				</Grid>
			</TabItem>
			<TabItem x:Name="AdvancedSettingsTab" FocusManager.FocusedElement="{Binding ElementName=AdvancedSettingsAutoGrid}">
				<TabItem.Header>
					<TextBlock x:Name="AdvancedSettingsTabHeader"
					    Style="{StaticResource TabItemWithContextMenu}"
					    Text="Advanced"
					    ToolTip="Advanced Mod Manager Settings (Data/settings.json)" />
				</TabItem.Header>
				<ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
					<Grid Margin="18,14">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>
						<TextBlock Style="{StaticResource SettingsPageTitleStyle}" Text="Advanced tools" />
						<TextBlock Grid.Row="1"
							Style="{StaticResource SettingsPageDescriptionStyle}"
							Text="Diagnostics, launch arguments, and maintenance options. Change these only when needed." />
						<Border Grid.Row="2" Style="{StaticResource SettingsSectionCardStyle}">
							<Grid>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="1" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>
								<TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="Diagnostics and launch behavior" />
								<Border Grid.Row="1" Margin="0,10,0,0" Background="{DynamicResource ReduxBorderBrush}" />
								<controls:AutoGrid x:Name="AdvancedSettingsAutoGrid"
									Grid.Row="2"
				    Margin="10,0"
				    ChildMargin="8,4"
				    ColumnCount="2"
				    Columns="auto,*"
				    RowCount="4"
				    RowHeight="*"
				    Rows="auto,auto,auto,auto">
					<TextBlock x:Name="DebugModeTextBlock" behavior:TextBlockSettingsEntryAttributeBehavior.Property="DebugModeEnabled" behavior:TextBlockSettingsEntryAttributeBehavior.TargetType="{x:Type data:DivinityModManagerSettings}" />
					<CheckBox x:Name="DebugModeCheckBox" VerticalAlignment="Center" ToolTip="{Binding ElementName=DebugModeTextBlock, Path=ToolTip}" />
					<TextBlock Text="Enable Mod Manager Logs" ToolTip="Automatically save logs to _Logs" />
					<CheckBox x:Name="LogEnabledCheckBox" VerticalAlignment="Center" />
					<Button x:Name="GameLaunchParamsMainButton"
					    VerticalAlignment="Center"
					    Content="Launch Params"
					    Style="{StaticResource SettingsActionButtonStyle}"
					    ToolTip="Parameters to pass to the game executable when launching the game through the mod manager">
						<Button.ContextMenu>
							<ContextMenu x:Name="GameLaunchParamsMainMenu">
								<ContextMenu.ItemTemplate>
									<DataTemplate DataType="vm:GameLaunchParamEntry">
										<TextBlock Text="{Binding}" />
									</DataTemplate>
								</ContextMenu.ItemTemplate>
								<ContextMenu.ItemContainerStyle>
									<Style BasedOn="{StaticResource {x:Type MenuItem}}" TargetType="MenuItem">
										<Setter Property="Header" Value="{Binding Name}" />
										<Setter Property="ToolTip" Value="{Binding Description}" />
										<Setter Property="ToolTipService.IsEnabled" Value="{Binding HasToolTip, FallbackValue=False}" />
										<Setter Property="ToolTipService.InitialShowDelay" Value="250" />
										<Setter Property="Command" Value="{Binding Path=DataContext.AddLaunchParamCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:SettingsWindow}}}" />
										<Setter Property="CommandParameter" Value="{Binding Name}" />
									</Style>
								</ContextMenu.ItemContainerStyle>
							</ContextMenu>
						</Button.ContextMenu>
					</Button>
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<TextBox x:Name="GameLaunchParamsTextBox"
						    VerticalAlignment="Center"
						    adonisExtensions:CornerRadiusExtension.CornerRadius="{DynamicResource Redux.CornerRadius.Control}"
						    Background="{DynamicResource ReduxSurfaceMutedBrush}"
						    BorderBrush="{DynamicResource ReduxBorderStrongBrush}"
						    TextWrapping="Wrap"
						    ToolTip="Parameters to pass to the game executable when launching the game through the mod manager" />
						<Button x:Name="ClearLaunchParamsMenuItem"
						    Grid.Column="1"
						    Style="{StaticResource IconButtonStyle}"
						    ToolTip="Clear current params">
							<controls:ReduxIcon StrokeData="{StaticResource Redux.Icon.Close}" />
						</Button>
					</Grid>
					<TextBlock Text="Experimental" />
					<Button x:Name="ClearCacheButton"
					    HorizontalAlignment="Center"
					    VerticalAlignment="Center"
					    Content="Delete Cache"
					    Style="{StaticResource SettingsWarningButtonStyle}"
					    ToolTip="Delete the local mod cache, located in the mod manager's Data folder" />
								</controls:AutoGrid>
							</Grid>
						</Border>
					</Grid>
				</ScrollViewer>
			</TabItem>
		</TabControl>
		<StatusBar Grid.Row="2"
			MinHeight="16"
			Background="{DynamicResource ReduxSurfaceElevatedBrush}"
			BorderBrush="{DynamicResource ReduxBorderBrush}"
			BorderThickness="0,1,0,0"
			Foreground="{DynamicResource ReduxTextSecondaryBrush}">
			<StatusBarItem HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
				<controls:AlertBar x:Name="AlertBar" Theme="Standard" />
			</StatusBarItem>
		</StatusBar>
	</Grid>
</local:SettingsWindowBase>
