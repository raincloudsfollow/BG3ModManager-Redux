<adonisUI:AdonisWindow x:Class="DivinityModManager.Views.ReduxPreviewWarningWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:adonisUI="clr-namespace:AdonisUI.Controls;assembly=AdonisUI"
	Title="Redux Preview"
	Width="650" Height="360" MinWidth="650" MinHeight="360" MaxWidth="650" MaxHeight="360"
	FontFamily="{DynamicResource Redux.FontFamily.UI}" FontWeight="Medium"
	ResizeMode="NoResize" ShowInTaskbar="False"
	TitleBarBackground="{DynamicResource ReduxSurfaceElevatedBrush}"
	TitleBarForeground="{DynamicResource ReduxTextPrimaryBrush}"
	WindowStartupLocation="CenterOwner">
	<Window.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries>
		<ResourceDictionary Source="../Themes/MainResourceDictionary.xaml" />
	</ResourceDictionary.MergedDictionaries></ResourceDictionary></Window.Resources>
	<Border Padding="22" Background="{DynamicResource ReduxAppBackgroundBrush}" BorderBrush="{DynamicResource ReduxBorderBrush}" BorderThickness="1">
		<Grid>
			<Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
			<Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
				<Border Width="42" Height="42" Margin="0,0,14,0" VerticalAlignment="Top" Background="{DynamicResource ReduxAccentSoftBrush}" BorderBrush="{DynamicResource ReduxAccentBrush}" BorderThickness="1" CornerRadius="21">
					<TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="23" Foreground="{DynamicResource ReduxAccentHoverBrush}" Text="◇" />
				</Border>
				<StackPanel Grid.Column="1"><TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource ReduxTextPrimaryBrush}" Text="Redux is an early preview" />
					<TextBlock Margin="0,5,0,0" Foreground="{DynamicResource ReduxTextSecondaryBrush}" Text="This build is still a work in progress intended for careful personal use and private testing." TextWrapping="Wrap" /></StackPanel>
			</Grid>
			<Border Grid.Row="1" Margin="0,18,0,14" Padding="14,12" Background="{DynamicResource ReduxSurfaceBrush}" BorderBrush="{DynamicResource ReduxAccentBrush}" BorderThickness="1" CornerRadius="8">
				<StackPanel>
					<TextBlock Foreground="{DynamicResource ReduxTextPrimaryBrush}" Text="Features, metadata matching, themes, and interface details may be incomplete or change between builds. Keep backups of important profiles and mod files, and verify your exported load order before launching the game." TextWrapping="Wrap" />
					<TextBlock Margin="0,9,0,0" Foreground="{DynamicResource ReduxTextSecondaryBrush}" Text="If something behaves unexpectedly, stop and report what happened before repeating a destructive action." TextWrapping="Wrap" />
					<CheckBox x:Name="AcknowledgementCheckBox" Margin="0,14,0,0" FontWeight="SemiBold" Foreground="{DynamicResource ReduxTextPrimaryBrush}" Content="I understand that this Redux build is a work in progress." />
				</StackPanel>
			</Border>
			<Button Grid.Row="2" Width="116" Height="34" HorizontalAlignment="Right" Background="{DynamicResource ReduxAccentBrush}" BorderBrush="{DynamicResource ReduxAccentHoverBrush}" Click="ContinueButton_Click" Content="Continue" Foreground="White" IsDefault="True" IsEnabled="{Binding IsChecked, ElementName=AcknowledgementCheckBox}" />
		</Grid>
	</Border>
</adonisUI:AdonisWindow>
