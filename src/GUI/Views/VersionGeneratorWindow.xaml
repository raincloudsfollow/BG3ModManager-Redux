<local:VersionGeneratorWindowBase
	x:Class="DivinityModManager.Views.VersionGeneratorWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="clr-namespace:DivinityModManager.Controls"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:DivinityModManager.Views"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:xc="http://schemas.xceed.com/wpf/xaml/toolkit"
	Title="Version Generator"
	Width="600"
	Height="300"
	FontFamily="{DynamicResource Redux.FontFamily.UI}" FontSize="{DynamicResource Redux.FontSize.12}"
	Background="{DynamicResource ReduxWindowBrush}"
	TitleBarBackground="{DynamicResource ReduxWindowBrush}"
	TitleBarForeground="{DynamicResource ReduxTextPrimaryBrush}"
	WindowStartupLocation="CenterOwner"
	mc:Ignorable="d">
	<Window.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="../Themes/MainResourceDictionary.xaml" />
			</ResourceDictionary.MergedDictionaries>
			<Style BasedOn="{StaticResource {x:Type xc:ULongUpDown}}" TargetType="xc:ULongUpDown">
				<Setter Property="Background" Value="{DynamicResource ReduxSurfaceElevatedBrush}" />
				<Setter Property="Foreground" Value="{DynamicResource ReduxTextPrimaryBrush}" />
				<Setter Property="BorderBrush" Value="{DynamicResource ReduxBorderBrush}" />
				<Setter Property="WatermarkTemplate" Value="{StaticResource DefaultXCWatermarkTemplate}" />
				<Setter Property="BorderThickness" Value="0" />
				<Setter Property="VerticalAlignment" Value="Center" />
				<Setter Property="HorizontalAlignment" Value="Center" />
				<Setter Property="MinHeight" Value="25" />
				<Setter Property="Margin" Value="2" />
				<Setter Property="ClipValueToMinMax" Value="True" />
			</Style>
			<Style TargetType="{x:Type StackPanel}">
				<Setter Property="Margin" Value="4,0" />
			</Style>
			<Style TargetType="{x:Type TextBlock}">
				<Setter Property="Foreground" Value="{DynamicResource ReduxTextMutedBrush}" />
			</Style>
		</ResourceDictionary>
	</Window.Resources>
	<Border Margin="12"
		Padding="18"
		Background="{DynamicResource ReduxSurfaceBrush}"
		BorderBrush="{DynamicResource ReduxBorderBrush}"
		BorderThickness="1"
		CornerRadius="{DynamicResource Redux.CornerRadius.Card}">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>
			<Grid HorizontalAlignment="Center" VerticalAlignment="Center">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="Auto" />
					<RowDefinition Height="Auto" />
					<RowDefinition Height="Auto" />
				</Grid.RowDefinitions>
				<StackPanel
					HorizontalAlignment="Center"
					VerticalAlignment="Center"
					Orientation="Horizontal">
					<StackPanel>
						<TextBlock Text="Major" />
						<xc:ULongUpDown
							x:Name="MajorUpDown"
							Maximum="127"
							Minimum="0" />
					</StackPanel>
					<StackPanel>
						<TextBlock Text="Minor" />
						<xc:ULongUpDown
							x:Name="MinorUpDown"
							Maximum="127"
							Minimum="0" />
					</StackPanel>
					<StackPanel>
						<TextBlock Text="Revision" />
						<xc:ULongUpDown
							x:Name="RevisionUpDown"
							Maximum="65536"
							Minimum="0" />
					</StackPanel>
					<StackPanel>
						<TextBlock Text="Build" />
						<xc:ULongUpDown
							x:Name="BuildUpDown"
							Maximum="2147483647"
							Minimum="0" />
					</StackPanel>
				</StackPanel>
				<StackPanel
					Grid.Row="1"
					Margin="10"
					HorizontalAlignment="Center"
					VerticalAlignment="Center"
					Orientation="Horizontal">
					<TextBlock Text="Version Number: " VerticalAlignment="Center" />
					<controls:UnfocusableTextBox x:Name="VersionNumberTextBox" />
				</StackPanel>
				<StackPanel
					Grid.Row="2"
					Margin="10"
					HorizontalAlignment="Center"
					VerticalAlignment="Center"
					Orientation="Horizontal">
					<StackPanel.Resources>
						<Style BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
							<Setter Property="Margin" Value="4,0" />
						</Style>
					</StackPanel.Resources>
					<Button x:Name="CopyButton" Content="Copy" />
					<Button x:Name="ResetButton" Content="Reset" />
				</StackPanel>
			</Grid>
			<StatusBar Grid.Row="1" MinHeight="16" Background="{DynamicResource ReduxSurfaceElevatedBrush}">
				<StatusBarItem HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
					<controls:AlertBar x:Name="AlertBar" Theme="Standard" />
				</StatusBarItem>
			</StatusBar>
		</Grid>
	</Border>
</local:VersionGeneratorWindowBase>
