<adonisUi:AdonisWindow x:Class="DivinityModManager.Views.CategoryNameDialog"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:adonisUi="clr-namespace:AdonisUI.Controls;assembly=AdonisUI"
	xmlns:controls="clr-namespace:DivinityModManager.Controls"
	xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
	Title="Add Mod Category"
	Width="580"
	Height="700"
	MinWidth="540"
	MinHeight="660"
	ResizeMode="CanResizeWithGrip"
	ShowInTaskbar="False"
	WindowStartupLocation="CenterOwner"
	FontFamily="{DynamicResource Redux.FontFamily.UI}"
	Background="{DynamicResource ReduxSurfaceBrush}"
	TitleBarBackground="{DynamicResource ReduxSurfaceElevatedBrush}"
	TitleBarForeground="{DynamicResource ReduxTextPrimaryBrush}">
	<adonisUi:AdonisWindow.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="../Themes/MainResourceDictionary.xaml" />
			</ResourceDictionary.MergedDictionaries>
		<SolidColorBrush x:Key="Redux.CategoryEditor.IconBrush" Color="#8A6AF1" />
		<Style x:Key="CategoryColorSwatchStyle" TargetType="Border">
			<Setter Property="Width" Value="32" /><Setter Property="Height" Value="25" />
			<Setter Property="Margin" Value="0,0,8,0" /><Setter Property="CornerRadius" Value="6" />
			<Setter Property="BorderBrush" Value="{DynamicResource ReduxBorderStrongBrush}" />
			<Setter Property="BorderThickness" Value="1" /><Setter Property="Cursor" Value="Hand" />
			<Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="BorderBrush" Value="{DynamicResource ReduxTextPrimaryBrush}" /><Setter Property="BorderThickness" Value="2" /></Trigger></Style.Triggers>
		</Style>
		<Style x:Key="CategoryColorSliderStyle" TargetType="Slider">
			<Setter Property="Height" Value="20" /><Setter Property="Minimum" Value="0" /><Setter Property="Maximum" Value="255" />
			<Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Slider">
				<Track x:Name="PART_Track" Height="16" VerticalAlignment="Center">
					<Track.DecreaseRepeatButton><RepeatButton Command="Slider.DecreaseLarge"><RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Height="6" VerticalAlignment="Center" Background="{DynamicResource ReduxAccentBrush}" CornerRadius="3" /></ControlTemplate></RepeatButton.Template></RepeatButton></Track.DecreaseRepeatButton>
					<Track.Thumb><Thumb Width="15" Height="15"><Thumb.Template><ControlTemplate TargetType="Thumb"><Ellipse Fill="{DynamicResource ReduxTextPrimaryBrush}" Stroke="{DynamicResource ReduxBorderStrongBrush}" StrokeThickness="1" /></ControlTemplate></Thumb.Template></Thumb></Track.Thumb>
					<Track.IncreaseRepeatButton><RepeatButton Command="Slider.IncreaseLarge"><RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Height="6" VerticalAlignment="Center" Background="{DynamicResource ReduxBorderStrongBrush}" CornerRadius="3" /></ControlTemplate></RepeatButton.Template></RepeatButton></Track.IncreaseRepeatButton>
				</Track>
			</ControlTemplate></Setter.Value></Setter>
		</Style>
		<Style x:Key="CategoryDialogButtonStyle" TargetType="{x:Type Button}">
			<Setter Property="MinHeight" Value="30" />
			<Setter Property="Padding" Value="12,5" />
			<Setter Property="Background" Value="{DynamicResource ReduxSurfaceElevatedBrush}" />
			<Setter Property="BorderBrush" Value="{DynamicResource ReduxBorderBrush}" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="Foreground" Value="{DynamicResource ReduxTextPrimaryBrush}" />
			<Setter Property="FocusVisualStyle" Value="{x:Null}" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="{x:Type Button}">
						<Border x:Name="ButtonChrome" Background="{TemplateBinding Background}"
							BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
							CornerRadius="{DynamicResource Redux.CornerRadius.Control}">
							<ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center"
								VerticalAlignment="Center" RecognizesAccessKey="True" />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ReduxHoverBrush}" />
								<Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource ReduxBorderStrongBrush}" />
							</Trigger>
							<Trigger Property="IsPressed" Value="True"><Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ReduxPressedBrush}" /></Trigger>
							<Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.45" /></Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
		</ResourceDictionary>
	</adonisUi:AdonisWindow.Resources>
	<Border Background="{DynamicResource ReduxSurfaceBrush}" BorderBrush="{DynamicResource ReduxBorderBrush}" BorderThickness="1">
	<Grid Margin="18">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>
		<TextBlock x:Name="DialogHeading" FontSize="16" FontWeight="SemiBold" Text="Create a custom mod category" />
		<TextBlock x:Name="DialogHelperText" Grid.Row="1" Margin="0,4,0,10" Foreground="{DynamicResource ReduxTextSecondaryBrush}"
			Text="You can assign installed mods to it from their right-click menu." />
		<TextBox x:Name="CategoryNameTextBox" Grid.Row="2" MinHeight="32" VerticalAlignment="Top"
			MaxLength="40" Padding="8,4" ToolTip="Category name" />
		<TextBlock x:Name="ColorFieldLabel" Grid.Row="3" Margin="0,10,0,6" FontWeight="SemiBold"
			Foreground="{DynamicResource ReduxTextSecondaryBrush}" Text="Category color" />
		<Border Grid.Row="4" Padding="12" Background="{DynamicResource ReduxSurfaceElevatedBrush}"
			BorderBrush="{DynamicResource ReduxBorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource Redux.CornerRadius.Control}">
			<Grid>
				<Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="14" /><RowDefinition Height="Auto" /><RowDefinition Height="14" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
				<Grid.ColumnDefinitions><ColumnDefinition Width="295" /><ColumnDefinition Width="14" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
				<Grid Width="295" Height="190" HorizontalAlignment="Left">
					<Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="10" /><ColumnDefinition Width="18" /></Grid.ColumnDefinitions>
					<Border x:Name="SpectrumSurface" ClipToBounds="True" Cursor="Cross"
						BorderBrush="{DynamicResource ReduxBorderStrongBrush}" BorderThickness="1" CornerRadius="{DynamicResource Redux.CornerRadius.ControlInner}"
						MouseLeftButtonDown="Spectrum_MouseLeftButtonDown" MouseMove="Spectrum_MouseMove" MouseLeftButtonUp="ColorSurface_MouseLeftButtonUp">
						<Grid>
							<Rectangle>
								<Rectangle.Fill><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#00FFFFFF" Offset="0" /><GradientStop Color="#FF000000" Offset="1" /></LinearGradientBrush></Rectangle.Fill>
							</Rectangle>
							<Ellipse x:Name="SpectrumMarker" Width="11" Height="11" HorizontalAlignment="Left" VerticalAlignment="Top"
								Fill="Transparent" Stroke="White" StrokeThickness="2" IsHitTestVisible="False" />
						</Grid>
					</Border>
					<Border x:Name="HueSurface" Grid.Column="2" Cursor="Hand" ClipToBounds="True"
						BorderBrush="{DynamicResource ReduxBorderStrongBrush}" BorderThickness="1" CornerRadius="{DynamicResource Redux.CornerRadius.Small}"
						MouseLeftButtonDown="Hue_MouseLeftButtonDown" MouseMove="Hue_MouseMove" MouseLeftButtonUp="ColorSurface_MouseLeftButtonUp">
						<Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
							<GradientStop Color="#FFFF0000" Offset="0" /><GradientStop Color="#FFFFFF00" Offset="0.167" />
							<GradientStop Color="#FF00FF00" Offset="0.333" /><GradientStop Color="#FF00FFFF" Offset="0.5" />
							<GradientStop Color="#FF0000FF" Offset="0.667" /><GradientStop Color="#FFFF00FF" Offset="0.833" />
							<GradientStop Color="#FFFF0000" Offset="1" />
						</LinearGradientBrush></Border.Background>
						<Rectangle x:Name="HueMarker" Height="3" Margin="-2,0" VerticalAlignment="Top" Fill="White" Stroke="#FF17151C" StrokeThickness="1" IsHitTestVisible="False" />
					</Border>
				</Grid>
				<xctk:ColorCanvas x:Name="CategoryColorPicker" Visibility="Collapsed" UsingAlphaChannel="False" SelectedColorChanged="CategoryColorPicker_SelectedColorChanged" />
				<StackPanel Grid.Column="2" VerticalAlignment="Top">
					<TextBlock Margin="0,0,0,6" FontSize="11" FontWeight="SemiBold"
						Foreground="{DynamicResource ReduxTextMutedBrush}" Text="PREVIEW" />
					<Border x:Name="SelectedColorPreview" Height="54" Background="#8A6AF1"
						BorderBrush="{DynamicResource ReduxBorderStrongBrush}" BorderThickness="1" CornerRadius="{DynamicResource Redux.CornerRadius.Control}" />
					<TextBlock Margin="0,10,0,4" FontSize="11" FontWeight="SemiBold"
						Foreground="{DynamicResource ReduxTextMutedBrush}" Text="HEX COLOR" />
					<TextBox x:Name="HexColorTextBox" MinHeight="30" Padding="7,3" Text="#8A6AF1"
						LostFocus="HexColorTextBox_Commit" KeyDown="HexColorTextBox_KeyDown" />
					<StackPanel x:Name="IconChooserPanel" Margin="0,8,0,0">
						<TextBlock x:Name="IconFieldLabel" Margin="0,0,0,4" FontSize="11" FontWeight="SemiBold"
							Foreground="{DynamicResource ReduxTextMutedBrush}" Text="ICON" />
						<ComboBox x:Name="CategoryIconComboBox"
							Width="92"
							HorizontalAlignment="Left"
							ItemsSource="{x:Static controls:ReduxIconCatalog.Choices}"
							SelectedValuePath="Id"
							MaxDropDownHeight="239"
							ScrollViewer.HorizontalScrollBarVisibility="Disabled"
							ScrollViewer.VerticalScrollBarVisibility="Disabled"
							ToolTip="Choose a category icon. Hover an icon to see its name.">
							<ComboBox.ItemsPanel>
								<ItemsPanelTemplate>
									<WrapPanel Width="297" IsItemsHost="True" />
								</ItemsPanelTemplate>
							</ComboBox.ItemsPanel>
							<ComboBox.ItemContainerStyle>
								<Style BasedOn="{StaticResource ReduxComboBoxItemStyle}" TargetType="{x:Type ComboBoxItem}">
									<Setter Property="Width" Value="31" />
									<Setter Property="Height" Value="31" />
									<Setter Property="Margin" Value="1" />
									<Setter Property="Padding" Value="0" />
									<Setter Property="HorizontalContentAlignment" Value="Center" />
									<Setter Property="VerticalContentAlignment" Value="Center" />
									<Setter Property="ToolTip" Value="{Binding DisplayName}" />
									<Setter Property="ToolTipService.InitialShowDelay" Value="250" />
								</Style>
							</ComboBox.ItemContainerStyle>
							<ComboBox.ItemTemplate>
								<DataTemplate>
									<Grid Width="20" Height="20" VerticalAlignment="Center">
											<Ellipse Width="8" Height="8" Fill="{DynamicResource Redux.CategoryEditor.IconBrush}"
												Visibility="{Binding IsNone, Converter={StaticResource BoolToVisibilityConverter}}" />
											<controls:ReduxIcon Width="18" Height="18" IconKey="{Binding Id}"
												Foreground="{DynamicResource Redux.CategoryEditor.IconBrush}"
												Visibility="{Binding IsNone, Converter={StaticResource BoolToVisibilityConverterReversed}}" />
									</Grid>
								</DataTemplate>
							</ComboBox.ItemTemplate>
						</ComboBox>
						<TextBlock Visibility="Collapsed" Margin="0,7,0,4" FontSize="10" Foreground="{DynamicResource ReduxTextMutedBrush}"
							Text="Quick choices — hover for names" />
					</StackPanel>
				</StackPanel>
				<Grid Grid.Row="2" Grid.ColumnSpan="3">
					<Grid.ColumnDefinitions><ColumnDefinition Width="18" /><ColumnDefinition Width="*" /><ColumnDefinition Width="38" /></Grid.ColumnDefinitions>
					<Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
					<TextBlock VerticalAlignment="Center" Foreground="{DynamicResource ReduxTextSecondaryBrush}" Text="R" />
					<Slider x:Name="RedSlider" Grid.Column="1" Style="{StaticResource CategoryColorSliderStyle}" Foreground="#EF4444" ValueChanged="RgbSlider_ValueChanged" />
					<TextBlock Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{DynamicResource ReduxTextSecondaryBrush}" Text="{Binding Value, ElementName=RedSlider, StringFormat={}{0:0}}" />
					<TextBlock Grid.Row="1" VerticalAlignment="Center" Foreground="{DynamicResource ReduxTextSecondaryBrush}" Text="G" />
					<Slider x:Name="GreenSlider" Grid.Row="1" Grid.Column="1" Style="{StaticResource CategoryColorSliderStyle}" Foreground="#22C55E" ValueChanged="RgbSlider_ValueChanged" />
					<TextBlock Grid.Row="1" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{DynamicResource ReduxTextSecondaryBrush}" Text="{Binding Value, ElementName=GreenSlider, StringFormat={}{0:0}}" />
					<TextBlock Grid.Row="2" VerticalAlignment="Center" Foreground="{DynamicResource ReduxTextSecondaryBrush}" Text="B" />
					<Slider x:Name="BlueSlider" Grid.Row="2" Grid.Column="1" Style="{StaticResource CategoryColorSliderStyle}" Foreground="#3B82F6" ValueChanged="RgbSlider_ValueChanged" />
					<TextBlock Grid.Row="2" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{DynamicResource ReduxTextSecondaryBrush}" Text="{Binding Value, ElementName=BlueSlider, StringFormat={}{0:0}}" />
				</Grid>
				<StackPanel Grid.Row="4" Grid.ColumnSpan="3">
					<TextBlock Margin="0,0,0,7" FontSize="11" FontWeight="SemiBold"
						Foreground="{DynamicResource ReduxTextMutedBrush}" Text="REDUX PRESETS" />
					<WrapPanel>
						<Border Style="{StaticResource CategoryColorSwatchStyle}" Background="#8A6AF1" Tag="#8A6AF1" ToolTip="Arcane Violet" MouseLeftButtonUp="ColorSwatch_Click" />
						<Border Style="{StaticResource CategoryColorSwatchStyle}" Background="#3B82F6" Tag="#3B82F6" ToolTip="Electric Blue" MouseLeftButtonUp="ColorSwatch_Click" />
						<Border Style="{StaticResource CategoryColorSwatchStyle}" Background="#22B8C5" Tag="#22B8C5" ToolTip="Cyan Tide" MouseLeftButtonUp="ColorSwatch_Click" />
						<Border Style="{StaticResource CategoryColorSwatchStyle}" Background="#3FA37A" Tag="#3FA37A" ToolTip="Emerald Mist" MouseLeftButtonUp="ColorSwatch_Click" />
						<Border Style="{StaticResource CategoryColorSwatchStyle}" Background="#71B96B" Tag="#71B96B" ToolTip="Moss Green" MouseLeftButtonUp="ColorSwatch_Click" />
						<Border Style="{StaticResource CategoryColorSwatchStyle}" Background="#D7A24B" Tag="#D7A24B" ToolTip="Antique Amber" MouseLeftButtonUp="ColorSwatch_Click" />
						<Border Style="{StaticResource CategoryColorSwatchStyle}" Background="#F97316" Tag="#F97316" ToolTip="Ember Orange" MouseLeftButtonUp="ColorSwatch_Click" />
						<Border Style="{StaticResource CategoryColorSwatchStyle}" Background="#D66B55" Tag="#D66B55" ToolTip="Terracotta" MouseLeftButtonUp="ColorSwatch_Click" />
						<Border Style="{StaticResource CategoryColorSwatchStyle}" Background="#D45A9E" Tag="#D45A9E" ToolTip="Rose" MouseLeftButtonUp="ColorSwatch_Click" />
						<Border Style="{StaticResource CategoryColorSwatchStyle}" Background="#8F879E" Tag="#8F879E" ToolTip="Muted Lilac" MouseLeftButtonUp="ColorSwatch_Click" />
					</WrapPanel>
					<DockPanel Margin="0,12,0,7" LastChildFill="False">
						<TextBlock VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"
							Foreground="{DynamicResource ReduxTextMutedBrush}" Text="SAVED COLORS" />
						<Button DockPanel.Dock="Right" MinWidth="96" Style="{StaticResource CategoryDialogButtonStyle}"
							Click="SaveCurrentColor_Click" Content="+ Save current" />
					</DockPanel>
					<WrapPanel x:Name="SavedColorsPanel" />
					<TextBlock x:Name="NoSavedColorsText" Foreground="{DynamicResource ReduxTextMutedBrush}"
						FontSize="11" Text="No saved colors yet." />
				</StackPanel>
			</Grid>
		</Border>
		<StackPanel Grid.Row="5" Margin="0,12,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
			<Button x:Name="ResetToDefaultButton" MinWidth="138" Margin="0,0,8,0"
				Style="{StaticResource CategoryDialogButtonStyle}" Visibility="Collapsed"
				Click="ResetToDefault_Click">
				<StackPanel Orientation="Horizontal">
					<controls:ReduxIcon Width="14" Height="14" Margin="0,0,6,0"
						StrokeData="{StaticResource Redux.Icon.RefreshStroke}" />
					<TextBlock Text="Reset to default" />
				</StackPanel>
			</Button>
			<Button x:Name="ConfirmButton" MinWidth="84" Margin="0,0,8,0" Style="{StaticResource ReduxRoundedPrimaryButtonStyle}" IsDefault="True" Click="Add_Click" Content="Add" />
			<Button MinWidth="84" Style="{StaticResource CategoryDialogButtonStyle}" IsCancel="True" Content="Cancel" />
		</StackPanel>
	</Grid>
	</Border>
</adonisUi:AdonisWindow>
