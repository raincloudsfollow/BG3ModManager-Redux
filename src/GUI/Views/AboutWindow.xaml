<local:AboutWindowBase x:Class="DivinityModManager.Views.AboutWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:app="clr-namespace:DivinityModManager;assembly=DivinityModManagerCore"
	xmlns:c="clr-namespace:DivinityModManager.Controls"
	xmlns:local="clr-namespace:DivinityModManager.Views"
	Title="About BG3 Mod Manager Redux"
	Width="720"
	Height="470"
	ResizeMode="NoResize"
	ShowInTaskbar="False"
	WindowStartupLocation="CenterOwner"
	FontFamily="{DynamicResource Redux.FontFamily.UI}" FontSize="{DynamicResource Redux.FontSize.12}"
	FontWeight="Medium"
	Background="{DynamicResource ReduxWindowBrush}"
	TitleBarBackground="{DynamicResource ReduxWindowBrush}"
	TitleBarForeground="{DynamicResource ReduxTextPrimaryBrush}">
	<Window.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="../Themes/MainResourceDictionary.xaml" />
			</ResourceDictionary.MergedDictionaries>
			<Style x:Key="AboutLinkStyle" TargetType="c:HyperlinkText">
				<Setter Property="Foreground" Value="{DynamicResource ReduxAccentHoverBrush}" />
				<Setter Property="HorizontalAlignment" Value="Left" />
			</Style>
			<Style x:Key="AboutLabelStyle" TargetType="TextBlock">
				<Setter Property="Foreground" Value="{DynamicResource ReduxTextMutedBrush}" />
				<Setter Property="VerticalAlignment" Value="Center" />
			</Style>
		</ResourceDictionary>
	</Window.Resources>
	<Border Margin="12"
		Padding="22"
		Background="{DynamicResource ReduxSurfaceBrush}"
		BorderBrush="{DynamicResource ReduxBorderBrush}"
		BorderThickness="1"
		CornerRadius="{DynamicResource Redux.CornerRadius.Card}">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>
			<StackPanel Orientation="Horizontal">
				<Border Width="48" Height="48"
					Background="{DynamicResource ReduxAccentSoftBrush}"
					BorderBrush="{DynamicResource ReduxAccentBrush}"
					BorderThickness="1"
					CornerRadius="{DynamicResource Redux.CornerRadius.Pill}">
					<TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
						FontSize="{DynamicResource Redux.FontSize.22}" FontWeight="SemiBold"
						Foreground="{DynamicResource ReduxAccentHoverBrush}" Text="R" />
				</Border>
				<StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
					<TextBlock x:Name="TitleText" FontSize="{DynamicResource Redux.FontSize.21}" FontWeight="SemiBold"
						Foreground="{DynamicResource ReduxTextPrimaryBrush}" />
					<TextBlock Margin="0,3,0,0" Foreground="{DynamicResource ReduxTextSecondaryBrush}">
						<Run Text="v" /><Run Text="{x:Static app:DivinityApp.REDUX_DISPLAY_VERSION}" /><Run Text="  •  A modern interface for Baldur's Gate 3 mod management" />
					</TextBlock>
				</StackPanel>
			</StackPanel>

			<Separator Grid.Row="1" Margin="0,18,0,16"
				Background="{DynamicResource ReduxBorderBrush}" />

			<Grid Grid.Row="2">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="16" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<Border Padding="16" Background="{DynamicResource ReduxSurfaceElevatedBrush}"
					BorderBrush="{DynamicResource ReduxBorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource Redux.CornerRadius.Card}">
					<StackPanel>
						<TextBlock FontSize="{DynamicResource Redux.FontSize.15}" FontWeight="SemiBold" Foreground="{DynamicResource ReduxTextPrimaryBrush}" Text="Redux Project" />
						<TextBlock Margin="0,4,0,14" Foreground="{DynamicResource ReduxTextSecondaryBrush}"
							Text="Maintained by raincloudsfollow." />
						<Grid>
							<Grid.ColumnDefinitions><ColumnDefinition Width="76" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
							<Grid.RowDefinitions><RowDefinition MinHeight="28" /><RowDefinition MinHeight="28" /><RowDefinition MinHeight="28" /><RowDefinition MinHeight="28" /></Grid.RowDefinitions>
							<TextBlock Style="{StaticResource AboutLabelStyle}" Text="Project" />
							<c:HyperlinkText Grid.Column="1" Style="{StaticResource AboutLinkStyle}" DisplayText="Open Redux on GitHub" URL="{x:Static app:DivinityApp.URL_REDUX_REPO}" />
							<TextBlock Grid.Row="1" Style="{StaticResource AboutLabelStyle}" Text="Releases" />
							<c:HyperlinkText Grid.Row="1" Grid.Column="1" Style="{StaticResource AboutLinkStyle}" DisplayText="View Redux releases" URL="{x:Static app:DivinityApp.URL_REDUX_RELEASES}" />
							<TextBlock Grid.Row="2" Style="{StaticResource AboutLabelStyle}" Text="Issues" />
							<c:HyperlinkText Grid.Row="2" Grid.Column="1" Style="{StaticResource AboutLinkStyle}" DisplayText="Report a Redux issue" URL="{x:Static app:DivinityApp.URL_REDUX_BUG_REPORT}" />
							<TextBlock Grid.Row="3" Style="{StaticResource AboutLabelStyle}" Text="License" />
							<c:HyperlinkText Grid.Row="3" Grid.Column="1" Style="{StaticResource AboutLinkStyle}" DisplayText="MIT License" URL="{x:Static app:DivinityApp.URL_REDUX_LICENSE}" />
						</Grid>
					</StackPanel>
				</Border>

				<Border Grid.Column="2" Padding="16" Background="{DynamicResource ReduxSurfaceElevatedBrush}"
					BorderBrush="{DynamicResource ReduxBorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource Redux.CornerRadius.Card}">
					<StackPanel>
						<TextBlock FontSize="{DynamicResource Redux.FontSize.15}" FontWeight="SemiBold" Foreground="{DynamicResource ReduxTextPrimaryBrush}" Text="Original Project Credit" />
						<TextBlock Margin="0,4,0,14" TextWrapping="Wrap" Foreground="{DynamicResource ReduxTextSecondaryBrush}"
							Text="Redux is based on LaughingLeader's original BG3 Mod Manager and retains its core functionality." />
						<Grid>
							<Grid.ColumnDefinitions><ColumnDefinition Width="76" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
							<Grid.RowDefinitions><RowDefinition MinHeight="28" /><RowDefinition MinHeight="28" /><RowDefinition MinHeight="28" /></Grid.RowDefinitions>
							<TextBlock Style="{StaticResource AboutLabelStyle}" Text="Upstream" />
							<c:HyperlinkText Grid.Column="1" Style="{StaticResource AboutLinkStyle}" DisplayText="Original BG3 Mod Manager" URL="{x:Static app:DivinityApp.URL_REPO}" />
							<TextBlock Grid.Row="1" Style="{StaticResource AboutLabelStyle}" Text="Author" />
							<c:HyperlinkText Grid.Row="1" Grid.Column="1" Style="{StaticResource AboutLinkStyle}" DisplayText="LaughingLeader" URL="{x:Static app:DivinityApp.URL_AUTHOR}" />
							<TextBlock Grid.Row="2" Style="{StaticResource AboutLabelStyle}" Text="Support" />
							<c:HyperlinkText Grid.Row="2" Grid.Column="1" Style="{StaticResource AboutLinkStyle}" DisplayText="Support on Ko-fi" URL="{x:Static app:DivinityApp.URL_DONATION}" />
						</Grid>
					</StackPanel>
				</Border>
			</Grid>

			<TextBlock Grid.Row="3" Margin="0,16,0,0" HorizontalAlignment="Center"
				Foreground="{DynamicResource ReduxTextMutedBrush}"
				Text="Organize. Sort. Launch." />
		</Grid>
	</Border>
</local:AboutWindowBase>
