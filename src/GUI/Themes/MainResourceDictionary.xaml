	<!--
		Single source of truth for pill/chip chrome (category pills, source pills, drawer
		metadata chips). Variants set only Background/BorderBrush/coloring logic via BasedOn;
		do not redeclare Padding/MinHeight/CornerRadius locally.
	-->
	<Style x:Key="ReduxPillBaseStyle" TargetType="{x:Type Border}">
		<Setter Property="MinHeight" Value="21" />
		<Setter Property="Padding" Value="8,2" />
		<Setter Property="HorizontalAlignment" Value="Left" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="BorderThickness" Value="1.5" />
		<Setter Property="CornerRadius" Value="{DynamicResource Redux.CornerRadius.Pill}" />
		<Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
		<Setter Property="RenderTransform">
			<Setter.Value>
				<ScaleTransform x:Name="PillHoverScale" ScaleX="1" ScaleY="1" />
			</Setter.Value>
		</Setter>
		<Style.Resources>
			<Style TargetType="{x:Type TextBlock}">
				<Setter Property="FontSize" Value="{DynamicResource Redux.FontSize.11}" />
			</Style>
		</Style.Resources>
		<!--
			Opacity, not an Effect: a Effect (DropShadowEffect etc.) forces the whole subtree
			through an intermediate bitmap, which disables ClearType and makes the pill's own
			text render blurry while hovered. Plain opacity gives hover feedback without that.
			Scale is kept small (1.02): several pill containers (ModSourceTemplate,
			ModCategoryTemplate) set ClipToBounds="True" on their own root to stop overflowing
			pill text from spilling into the next list column, so a RenderTransform grow here
			has to stay inside that clip region rather than assuming free space.
		-->
		<Style.Triggers>
			<Trigger Property="IsMouseOver" Value="True">
				<Setter Property="Opacity" Value="0.85" />
				<Trigger.EnterActions>
					<BeginStoryboard>
						<Storyboard>
							<DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.02"
								Duration="{StaticResource Redux.Motion.Fast}" EasingFunction="{StaticResource Redux.Motion.EaseOut}" />
							<DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.02"
								Duration="{StaticResource Redux.Motion.Fast}" EasingFunction="{StaticResource Redux.Motion.EaseOut}" />
						</Storyboard>
					</BeginStoryboard>
				</Trigger.EnterActions>
				<Trigger.ExitActions>
					<BeginStoryboard>
						<Storyboard>
							<DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="{StaticResource Redux.Motion.Standard}" />
							<DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="{StaticResource Redux.Motion.Standard}" />
						</Storyboard>
					</BeginStoryboard>
				</Trigger.ExitActions>
			</Trigger>
		</Style.Triggers>
	</Style>
