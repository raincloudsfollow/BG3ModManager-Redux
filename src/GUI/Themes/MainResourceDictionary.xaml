							<ItemsPresenter x:Name="ListItemsPresenter" />
						</ScrollViewer>
						<Border Name="EmptyStatePanel"
							Margin="24"
							HorizontalAlignment="Center"
							VerticalAlignment="Center"
							IsHitTestVisible="False"
							Visibility="Collapsed">
							<StackPanel HorizontalAlignment="Center">
								<TextBlock HorizontalAlignment="Center" FontSize="14" FontWeight="SemiBold" Text="No mods here yet" />
								<TextBlock Margin="0,6,0,0"
									HorizontalAlignment="Center"
									Foreground="{DynamicResource ReduxTextMutedBrush}"
									Text="Use Install Mod or move a mod into this list." />
							</StackPanel>
						</Border>
						<Rectangle Name="DisabledRect"
						    HorizontalAlignment="Stretch"
						    VerticalAlignment="Stretch"
						    Fill="{DynamicResource {x:Static divThemes:DivinityColors.ListInactiveBrush}}"
						    IsHitTestVisible="False"
						    KeyboardNavigation.IsTabStop="False"
						    Visibility="Collapsed" />
					</Grid>
					<ControlTemplate.Triggers>
						<Trigger Property="HasItems" Value="False">
							<Setter TargetName="EmptyStatePanel" Property="Visibility" Value="Visible" />
						</Trigger>
						<Trigger Property="IsGrouping" Value="True">
							<Setter TargetName="ListScrollViewer" Property="CanContentScroll" Value="False" />
						</Trigger>
						<MultiDataTrigger>
							<MultiDataTrigger.Conditions>
								<Condition Binding="{Binding Path=IsKeyboardFocusWithin, RelativeSource={RelativeSource Self}}" Value="False" />
								<Condition Binding="{Binding Path=(dapp:DivinityApp.IsKeyboardNavigating)}" Value="True" />
							</MultiDataTrigger.Conditions>
							<MultiDataTrigger.Setters>
								<Setter TargetName="DisabledRect" Property="Visibility" Value="Visible" />
							</MultiDataTrigger.Setters>
						</MultiDataTrigger>
					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
	<DataTemplate x:Key="TagTemplate">
		<Border Background="{DynamicResource {x:Static divThemes:DivinityColors.TagBackgroundBrush}}" BorderThickness="2" CornerRadius="{DynamicResource Redux.CornerRadius.Pill}">
			<TextBlock Padding="12,2" Foreground="{DynamicResource {x:Static adonisUI:Brushes.Layer3InteractionForegroundBrush}}" Text="{Binding}">
				<TextBlock.Effect>
					<DropShadowEffect BlurRadius="4"
					    Direction="330"
					    Opacity="0.5"
					    ShadowDepth="4"
					    Color="Black" />
				</TextBlock.Effect>
			</TextBlock>
			<Border.Effect>
				<DropShadowEffect BlurRadius="4"
				    Direction="330"
				    Opacity="0.35"
				    ShadowDepth="2"
				    Color="Black" />
			</Border.Effect>
		</Border>
	</DataTemplate>
	<DataTemplate x:Key="ModeTagTemplate">
		<Border Background="{DynamicResource {x:Static divThemes:DivinityColors.ModeTagBackgroundBrush}}" BorderThickness="2" CornerRadius="{DynamicResource Redux.CornerRadius.Pill}">
			<TextBlock Padding="12,2" Foreground="{DynamicResource {x:Static adonisUI:Brushes.Layer3InteractionForegroundBrush}}" Text="{Binding}">
				<TextBlock.Effect>
					<DropShadowEffect BlurRadius="4"
					    Direction="330"
					    Opacity="0.5"
					    ShadowDepth="4"
					    Color="Black" />
				</TextBlock.Effect>
			</TextBlock>
			<Border.Effect>
				<DropShadowEffect BlurRadius="4"
				    Direction="330"
				    Opacity="0.35"
				    ShadowDepth="2"
				    Color="Black" />
			</Border.Effect>
		</Border>
	</DataTemplate>
	<DataTemplate x:Key="CustomTagTemplate">
		<Border Background="{DynamicResource {x:Static divThemes:DivinityColors.CustomTagBackgroundBrush}}" BorderThickness="2" CornerRadius="{DynamicResource Redux.CornerRadius.Pill}">
			<TextBlock Padding="12,2" Foreground="{DynamicResource {x:Static adonisUI:Brushes.Layer3InteractionForegroundBrush}}" Text="{Binding}">
				<TextBlock.Effect>
					<DropShadowEffect BlurRadius="4"
					    Direction="330"
					    Opacity="0.5"
					    ShadowDepth="4"
					    Color="Black" />
				</TextBlock.Effect>
			</TextBlock>
			<Border.Effect>
				<DropShadowEffect BlurRadius="4"
				    Direction="330"
				    Opacity="0.35"
				    ShadowDepth="2"
				    Color="Black" />
			</Border.Effect>
		</Border>
	</DataTemplate>
	<!-- Shared pill chrome used by list cells, the selected-mod drawer, and mod hover cards. -->
	<Style x:Key="ReduxCategoryPillBaseStyle" TargetType="{x:Type Border}">
		<Setter Property="MinHeight" Value="21" />
		<Setter Property="Padding" Value="8,2" />
		<Setter Property="HorizontalAlignment" Value="Left" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="Background" Value="{Binding SoftColor}" />
		<Setter Property="BorderBrush" Value="{Binding Color}" />
		<Setter Property="BorderThickness" Value="1.5" />
		<Setter Property="CornerRadius" Value="{DynamicResource Redux.CornerRadius.Pill}" />
		<Style.Triggers>
			<DataTrigger Binding="{Binding Name}" Value="No Category">
				<Setter Property="Visibility" Value="Collapsed" />
			</DataTrigger>
		</Style.Triggers>
	</Style>
	<Style x:Key="ReduxSourcePillStyle" TargetType="{x:Type Border}">
		<Setter Property="MinHeight" Value="21" />
		<Setter Property="Padding" Value="8,2" />
		<Setter Property="HorizontalAlignment" Value="Left" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="BorderThickness" Value="1.5" />
		<Setter Property="CornerRadius" Value="{DynamicResource Redux.CornerRadius.Pill}" />
		<Setter Property="Background" Value="{StaticResource Redux.Pill.Local.Background}" />
		<Setter Property="BorderBrush" Value="{StaticResource Redux.Pill.Local.Border}" />
		<Setter Property="TextElement.Foreground" Value="{StaticResource Redux.Pill.Local.Border}" />
		<Style.Triggers>
			<DataTrigger Binding="{Binding Metadata.SourceType}" Value="{x:Static dapp:ModSourceType.NEXUSMODS}">
				<Setter Property="Background" Value="{StaticResource Redux.Pill.Nexus.Background}" />
				<Setter Property="BorderBrush" Value="{StaticResource Redux.Pill.Nexus.Border}" />
				<Setter Property="TextElement.Foreground" Value="{StaticResource Redux.Pill.Nexus.Border}" />
			</DataTrigger>
			<DataTrigger Binding="{Binding Metadata.SourceType}" Value="{x:Static dapp:ModSourceType.MODIO}">
				<Setter Property="Background" Value="{StaticResource Redux.Pill.Modio.Background}" />
				<Setter Property="BorderBrush" Value="{StaticResource Redux.Pill.Modio.Border}" />
				<Setter Property="TextElement.Foreground" Value="{StaticResource Redux.Pill.Modio.Border}" />
			</DataTrigger>
		</Style.Triggers>
	</Style>
	<DataTemplate x:Key="ModTooltipCategoryPillItemTemplate">
		<Border MaxWidth="170" Margin="0,0,6,0" Style="{StaticResource ReduxCategoryPillBaseStyle}">
			<StackPanel Orientation="Horizontal">
				<controls:ReduxIcon Width="12" Height="12" Margin="0,0,5,0"
					IconKey="{Binding IconId}" Foreground="{Binding Color}">
					<controls:ReduxIcon.Style>
						<Style BasedOn="{StaticResource {x:Type controls:ReduxIcon}}" TargetType="{x:Type controls:ReduxIcon}">
							<Setter Property="Visibility" Value="Collapsed" />
							<Style.Triggers>
								<MultiDataTrigger>
									<MultiDataTrigger.Conditions>
										<Condition Binding="{Binding HasIcon}" Value="True" />
										<Condition Binding="{Binding MainWindow.DataContext.Settings.ShowCategoryIconsInPills, Source={x:Static Application.Current}, FallbackValue=True}" Value="True" />
									</MultiDataTrigger.Conditions>
									<Setter Property="Visibility" Value="Visible" />
								</MultiDataTrigger>
							</Style.Triggers>
						</Style>
					</controls:ReduxIcon.Style>
				</controls:ReduxIcon>
				<TextBlock Margin="0" FontSize="11" FontWeight="Medium" Foreground="{Binding Color}"
					Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
			</StackPanel>
		</Border>
	</DataTemplate>
	<controls:AutomationTooltip x:Key="ModToolTip" DataContext="{Binding RelativeSource={RelativeSource Mode=Self}, Path=PlacementTarget.Tag}">
		<controls:AutomationTooltip.Style>
			<Style BasedOn="{StaticResource {x:Type ToolTip}}" TargetType="controls:AutomationTooltip">
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="controls:AutomationTooltip">
							<Border Padding="12"
							    Background="{DynamicResource ReduxSurfaceElevatedBrush}"
							    BorderBrush="{DynamicResource ReduxBorderStrongBrush}"
							    BorderThickness="1"
							    CornerRadius="{DynamicResource Redux.CornerRadius.Card}">
								<Border.Effect>
									<DropShadowEffect BlurRadius="14" Color="Black" Opacity="0.28" ShadowDepth="3" />
								</Border.Effect>
								<ContentPresenter />
							</Border>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
		</controls:AutomationTooltip.Style>
		<StackPanel x:Name="InfoStackPanel"
			Width="420"
		    MaxWidth="420"
		    Background="Transparent"
		    Orientation="Vertical">
			<StackPanel.Resources>
				<Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="TextBlock">
					<Setter Property="TextWrapping" Value="Wrap" />
					<Setter Property="Margin" Value="2" />
					<Setter Property="Foreground" Value="{DynamicResource ReduxTextPrimaryBrush}" />
					<!--<Setter Property="FontFamily" Value="Arial" />-->
				</Style>
				<Style BasedOn="{StaticResource {x:Type ListBox}}" TargetType="ListBox" />
			</StackPanel.Resources>
			<Grid Margin="4,2,4,8">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="112" />
				</Grid.ColumnDefinitions>
				<StackPanel VerticalAlignment="Center">
					<TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource ReduxTextPrimaryBrush}"
						Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
					<TextBlock Margin="2,3,2,0" Foreground="{DynamicResource ReduxTextMutedBrush}"
						Text="{Binding Metadata.Title, StringFormat='Source project: {0}'}"
						TextTrimming="CharacterEllipsis" Visibility="{Binding Metadata.OnlineSourceVisibility}" />
				</StackPanel>
				<TextBlock Grid.Column="1" Margin="8,2,10,0" VerticalAlignment="Top"
					Foreground="{DynamicResource ReduxTextSecondaryBrush}" Text="{Binding DisplayVersion}" />
				<Border Grid.Column="2" Width="104" Height="78" HorizontalAlignment="Right"
					Background="{DynamicResource ReduxListInteriorBrush}" BorderBrush="{DynamicResource ReduxBorderStrongBrush}"
					BorderThickness="1" CornerRadius="{DynamicResource Redux.CornerRadius.Control}">
					<Image Margin="2" RenderOptions.BitmapScalingMode="HighQuality"
						Source="{Binding Metadata.PreviewImageUri}" Stretch="Uniform"
						Visibility="{Binding Metadata.PreviewImageVisibility}" />
				</Border>
				<StackPanel Grid.Column="0" Margin="0,54,0,0" HorizontalAlignment="Left" Orientation="Horizontal">
					<TextBlock HorizontalAlignment="Right"
					    Foreground="Lime"
					    Text="(Editor Project)"
					    Visibility="{Binding IsEditorMod, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />
				</StackPanel>
			</Grid>

			<WrapPanel Margin="4,0,4,9">
				<ItemsControl ItemsSource="{Binding DisplayCategories}"
					ItemTemplate="{StaticResource ModTooltipCategoryPillItemTemplate}">
					<ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
				</ItemsControl>
				<Border MinHeight="21" Margin="0,0,6,0" Padding="8,2" BorderThickness="1.5" CornerRadius="{DynamicResource Redux.CornerRadius.Pill}">
					<Border.Style><Style TargetType="Border">
						<Setter Property="Background" Value="{DynamicResource ReduxSuccessSoftBrush}" /><Setter Property="BorderBrush" Value="{DynamicResource ReduxSuccessBrush}" />
						<Style.Triggers>
							<DataTrigger Binding="{Binding IsActive}" Value="False">
								<Setter Property="Background" Value="{DynamicResource ReduxSurfaceMutedBrush}" />
								<Setter Property="BorderBrush" Value="{DynamicResource ReduxBorderStrongBrush}" />
							</DataTrigger>
							<MultiDataTrigger>
								<MultiDataTrigger.Conditions>
									<Condition Binding="{Binding IsForceLoaded}" Value="True" />
									<Condition Binding="{Binding IsForceLoadedMergedMod}" Value="False" />
									<Condition Binding="{Binding ForceAllowInLoadOrder}" Value="False" />
								</MultiDataTrigger.Conditions>
								<Setter Property="Background" Value="{DynamicResource ReduxAccentSoftBrush}" />
								<Setter Property="BorderBrush" Value="{DynamicResource ReduxAccentBrush}" />
							</MultiDataTrigger>
						</Style.Triggers>
					</Style></Border.Style>
					<TextBlock Margin="0" FontSize="11" FontWeight="Medium">
						<TextBlock.Style><Style TargetType="TextBlock">
							<Setter Property="Foreground" Value="{DynamicResource ReduxSuccessBrush}" /><Setter Property="Text" Value="Active" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding IsActive}" Value="False">
									<Setter Property="Foreground" Value="{DynamicResource ReduxTextMutedBrush}" /><Setter Property="Text" Value="Inactive" />
								</DataTrigger>
								<MultiDataTrigger>
									<MultiDataTrigger.Conditions>
										<Condition Binding="{Binding IsForceLoaded}" Value="True" />
										<Condition Binding="{Binding IsForceLoadedMergedMod}" Value="False" />
										<Condition Binding="{Binding ForceAllowInLoadOrder}" Value="False" />
									</MultiDataTrigger.Conditions>
									<Setter Property="Foreground" Value="{DynamicResource ReduxAccentHoverBrush}" />
									<Setter Property="Text" Value="Always Loaded" />
								</MultiDataTrigger>
							</Style.Triggers>
						</Style></TextBlock.Style>
					</TextBlock>
				</Border>
				<Border Margin="0,0,6,0" Style="{StaticResource ReduxSourcePillStyle}">
					<StackPanel Orientation="Horizontal">
						<Grid Width="14" Height="14" Margin="0,0,5,0" Visibility="{Binding Metadata.OnlineSourceVisibility}">
							<Image RenderOptions.BitmapScalingMode="HighQuality"
								Source="/BG3ModManager;component/Resources/Icons/Platforms/nexus.png" Stretch="Uniform">
								<Image.Style><Style TargetType="Image"><Setter Property="Visibility" Value="Collapsed" />
									<Style.Triggers><DataTrigger Binding="{Binding Metadata.SourceType}" Value="{x:Static dapp:ModSourceType.NEXUSMODS}"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
								</Style></Image.Style>
							</Image>
							<Image RenderOptions.BitmapScalingMode="HighQuality"
								Source="/BG3ModManager;component/Resources/Icons/Platforms/modio.png" Stretch="Uniform">
								<Image.Style><Style TargetType="Image"><Setter Property="Visibility" Value="Collapsed" />
									<Style.Triggers><DataTrigger Binding="{Binding Metadata.SourceType}" Value="{x:Static dapp:ModSourceType.MODIO}"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
								</Style></Image.Style>
							</Image>
						</Grid>
						<TextBlock Margin="0" VerticalAlignment="Center" FontSize="11" FontWeight="Medium"
							Foreground="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType={x:Type Border}}}"
							Text="{Binding DisplaySource}" />
					</StackPanel>
				</Border>
			</WrapPanel>

			<Separator Margin="4,0" Background="{DynamicResource ReduxBorderBrush}" />
			<TextBlock Margin="4,8,4,5" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ReduxAccentHoverBrush}" Text="Local package" />
			<Grid Margin="6,0,6,6">
				<Grid.ColumnDefinitions><ColumnDefinition Width="112" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
				<Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
				<TextBlock Foreground="{DynamicResource ReduxTextMutedBrush}" Text="File" /><TextBlock Grid.Column="1" Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
				<TextBlock Grid.Row="1" Foreground="{DynamicResource ReduxTextMutedBrush}" Text="Last modified" /><TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LastModifiedDateText}" />
				<Grid Grid.Row="2" Grid.ColumnSpan="2">
					<Grid.Style>
						<Style TargetType="Grid">
							<Setter Property="Visibility" Value="Visible" />
							<Style.Triggers>
								<MultiDataTrigger>
									<MultiDataTrigger.Conditions>
										<Condition Binding="{Binding IsForceLoaded}" Value="True" />
										<Condition Binding="{Binding IsForceLoadedMergedMod}" Value="False" />
										<Condition Binding="{Binding ForceAllowInLoadOrder}" Value="False" />
									</MultiDataTrigger.Conditions>
									<Setter Property="Visibility" Value="Collapsed" />
								</MultiDataTrigger>
							</Style.Triggers>
						</Style>
					</Grid.Style>
					<Grid.ColumnDefinitions><ColumnDefinition Width="112" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
					<TextBlock Foreground="{DynamicResource ReduxTextMutedBrush}" Text="Load order" />
					<TextBlock Grid.Column="1" Text="{Binding LoadOrderDisplayText}" />
				</Grid>
				<TextBlock Grid.Row="3" Foreground="{DynamicResource ReduxTextMutedBrush}" Text="UUID" /><TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding UUID}" TextTrimming="CharacterEllipsis" ToolTip="{Binding UUID}" />
			</Grid>

			<StackPanel Visibility="{Binding Metadata.OnlineSourceVisibility}">
				<Separator Margin="4,0" Background="{DynamicResource ReduxBorderBrush}" />
				<TextBlock Margin="4,8,4,5" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ReduxAccentHoverBrush}"
					Text="{Binding Metadata.SourceLabel, StringFormat='Source · {0}'}" />
				<Grid Margin="6,0,6,6">
					<Grid.ColumnDefinitions><ColumnDefinition Width="112" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
					<Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
					<TextBlock Foreground="{DynamicResource ReduxTextMutedBrush}" Text="Project" /><TextBlock Grid.Column="1" Text="{Binding Metadata.Title}" TextTrimming="CharacterEllipsis" />
					<TextBlock Grid.Row="1" Foreground="{DynamicResource ReduxTextMutedBrush}" Text="Author" /><TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Metadata.Author}" />
					<TextBlock Grid.Row="2" Foreground="{DynamicResource ReduxTextMutedBrush}" Text="Source updated" /><TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Metadata.UpdatedLabel}" />
					<TextBlock Grid.Row="3" Foreground="{DynamicResource ReduxTextMutedBrush}" Text="Linked packages" /><TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SourceComponentCount}" />
				</Grid>
			</StackPanel>
			<StackPanel Margin="2,5,2,2" Orientation="Vertical" Visibility="{Binding DependencyVisibility, FallbackValue=Collapsed}">
				<TextBlock Margin="2,0,2,5" FontWeight="SemiBold" Text="Dependencies" />
				<Border Background="{DynamicResource ReduxListInteriorBrush}"
					BorderBrush="{DynamicResource ReduxBorderBrush}" BorderThickness="1"
					CornerRadius="{DynamicResource Redux.CornerRadius.Control}" ClipToBounds="True">
					<ListBox Grid.IsSharedSizeScope="True"
						ItemTemplate="{StaticResource DependencyModTemplate}"
						ItemsSource="{Binding DisplayedDependencies}">
						<ListBox.Style>
							<Style BasedOn="{StaticResource ModuleShortDescListBox}" TargetType="ListBox">
								<Setter Property="Background" Value="Transparent" />
								<Setter Property="BorderThickness" Value="0" />
								<Setter Property="Margin" Value="0" />
							</Style>
						</ListBox.Style>
					</ListBox>
				</Border>
			</StackPanel>
			<StackPanel Margin="2,5,2,2" Orientation="Vertical" Visibility="{Binding ConflictsVisibility, FallbackValue=Collapsed}">
				<TextBlock Margin="2,0,2,5" FontWeight="SemiBold" Text="Conflicts" />
				<Border Background="{DynamicResource ReduxListInteriorBrush}"
					BorderBrush="{DynamicResource ReduxBorderBrush}" BorderThickness="1"
					CornerRadius="{DynamicResource Redux.CornerRadius.Control}" ClipToBounds="True">
					<ListBox Grid.IsSharedSizeScope="True"
						ItemTemplate="{StaticResource ConflictModTemplate}"
						ItemsSource="{Binding DisplayedConflicts}">
						<ListBox.Style>
							<Style BasedOn="{StaticResource ModuleShortDescListBox}" TargetType="ListBox">
								<Setter Property="Background" Value="Transparent" />
								<Setter Property="BorderThickness" Value="0" />
								<Setter Property="Margin" Value="0" />
							</Style>
						</ListBox.Style>
					</ListBox>
				</Border>
			</StackPanel>
			<StackPanel Margin="2" DataContext="{Binding}" Orientation="Vertical">
				<ItemsControl ItemTemplateSelector="{StaticResource TagTemplateSelector}" ItemsSource="{Binding Tags}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<StackPanel Orientation="Horizontal" />
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.Style>
						<Style>
							<Style.Triggers>
								<DataTrigger Binding="{Binding}" />
							</Style.Triggers>
						</Style>
					</ItemsControl.Style>
				</ItemsControl>
			</StackPanel>
			<TextBlock Margin="6,4" Foreground="{DynamicResource ReduxWarningBrush}" Text="{Binding ScriptExtenderSupportToolTipText}" Visibility="{Binding ExtenderStatusVisibility}" />
			<StackPanel Margin="2" Orientation="Vertical" Visibility="{Binding IsForceLoaded, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
				<Separator Background="{DynamicResource ReduxBorderBrush}" />
				<TextBlock FontWeight="SemiBold" Foreground="{DynamicResource ReduxWarningBrush}" Text="Overrides Game Files" />
				<TextBlock Foreground="{DynamicResource ReduxTextSecondaryBrush}" TextWrapping="Wrap"
					Text="This package contains files that directly override built-in game files. Those overrides remain active while the .pak exists in the Mods folder and usually are not written to modsettings.lsx." />
				<TextBlock Foreground="{DynamicResource ReduxTextSecondaryBrush}" TextWrapping="Wrap"
					Text="This package also has a normal load-order entry. Disabling that entry may not disable its direct file overrides."
					Visibility="{Binding IsForceLoadedMergedMod, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />
				<TextBlock Foreground="{DynamicResource ReduxWarningBrush}" Text="Overridden built-in folders:" />
				<TextBlock Text="{Binding BuiltinOverrideModsText}" />
			</StackPanel>
			<Grid Margin="2" Visibility="{Binding HasInvalidUUIDVisibility}">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="1*" />
					<ColumnDefinition Width="4*" />
					<ColumnDefinition Width="1*" />
				</Grid.ColumnDefinitions>
				<controls:ReduxIcon Width="16"
				    Height="16"
				    MaxWidth="16"
				    MaxHeight="16"
				    Margin="4"
				    HorizontalAlignment="Center"
				    VerticalAlignment="Center"
				    Data="{StaticResource Redux.Icon.Danger}"
				    Foreground="{DynamicResource ReduxErrorBrush}" />
				<TextBlock Grid.Column="1"
				    FontWeight="Bold"
				    Foreground="Red"
				    Text="This mod has an invalid UUID, and will likely fail to load, resetting your load order." />
				<controls:ReduxIcon Grid.Column="2"
				    Width="16"
				    Height="16"
				    MaxWidth="16"
				    MaxHeight="16"
				    Margin="4"
				    HorizontalAlignment="Center"
				    VerticalAlignment="Center"
				    Data="{StaticResource Redux.Icon.Danger}"
				    Foreground="{DynamicResource ReduxErrorBrush}" />
			</Grid>
		</StackPanel>
	</controls:AutomationTooltip>

	<DataTemplate x:Key="ModNameTemplate" DataType="{x:Type data:DivinityModData}">
		<controls:ModEntryGrid>
			<controls:ModEntryGrid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="Auto" />
			</controls:ModEntryGrid.ColumnDefinitions>
			<TextBlock x:Name="ModNameText"
			    HorizontalAlignment="Stretch"
			    Tag="{Binding}"
				Text="{Binding DisplayTitle}"
				TextTrimming="CharacterEllipsis"
			    ToolTip="{StaticResource ModToolTip}"
			    ToolTipService.IsEnabled="{Binding HasToolTip}" />
			<Border Grid.Column="1"
				Width="8"
				Height="8"
				Margin="7,0,3,0"
				VerticalAlignment="Center"
				Background="{DynamicResource ReduxSuccessBrush}"
				BorderBrush="{DynamicResource ReduxSuccessBrush}"
				BorderThickness="0"
				CornerRadius="{DynamicResource Redux.CornerRadius.Small}"
				ToolTip="Newly detected mod"
				Visibility="{Binding IsNewlyDetected, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
				<Border.Effect>
					<DropShadowEffect BlurRadius="8"
						Color="{DynamicResource ReduxSuccessColor}"
						Opacity="0.85"
						ShadowDepth="0" />
				</Border.Effect>
			</Border>
			<Border Grid.Column="2" Padding="0,0,4,0" BorderThickness="0">
				<StackPanel Orientation="Horizontal">
					<controls:ReduxIcon Width="16"
					    Height="16"
					    MaxWidth="16"
					    MaxHeight="16"
					    Margin="2,0"
					    HorizontalAlignment="Center"
					    VerticalAlignment="Center"
					    IsHitTestVisible="True"
					    DataContext="{Binding}"
					>
						<controls:ReduxIcon.ToolTip>
							<ToolTip Style="{StaticResource ReduxRichToolTipStyle}">
								<Border MaxWidth="390" Padding="12,10"
									Background="{DynamicResource ReduxSurfaceElevatedBrush}"
									BorderThickness="1" CornerRadius="{DynamicResource Redux.CornerRadius.Card}">
									<Border.Style>
										<Style TargetType="{x:Type Border}">
											<Setter Property="BorderBrush" Value="{DynamicResource ReduxInfoBrush}" />
											<Style.Triggers>
												<DataTrigger Binding="{Binding OsirisModStatus}" Value="{x:Static dapp:DivinityOsirisModStatus.MODFIXER}">
													<Setter Property="BorderBrush" Value="{DynamicResource ReduxWarningBrush}" />
												</DataTrigger>
											</Style.Triggers>
										</Style>
									</Border.Style>
									<StackPanel>
										<TextBlock FontSize="13" FontWeight="SemiBold">
											<TextBlock.Style>
												<Style TargetType="{x:Type TextBlock}">
													<Setter Property="Foreground" Value="{DynamicResource ReduxInfoBrush}" />
													<Setter Property="Text" Value="Osiris scripting detected" />
													<Style.Triggers>
														<DataTrigger Binding="{Binding OsirisModStatus}" Value="{x:Static dapp:DivinityOsirisModStatus.MODFIXER}">
															<Setter Property="Foreground" Value="{DynamicResource ReduxWarningBrush}" />
															<Setter Property="Text" Value="Mod Fixer detected" />
														</DataTrigger>
													</Style.Triggers>
												</Style>
											</TextBlock.Style>
										</TextBlock>
										<TextBlock Margin="0,5,0,0"
											Foreground="{DynamicResource ReduxTextPrimaryBrush}"
											Text="{Binding OsirisStatusToolTipText}"
											TextWrapping="Wrap" />
									</StackPanel>
								</Border>
							</ToolTip>
						</controls:ReduxIcon.ToolTip>
						<controls:ReduxIcon.Style>
							<Style BasedOn="{StaticResource {x:Type controls:ReduxIcon}}" TargetType="{x:Type controls:ReduxIcon}">
								<Setter Property="Visibility" Value="Collapsed" />
								<Style.Triggers>
									<DataTrigger Binding="{Binding Path=OsirisModStatus}" Value="{x:Static dapp:DivinityOsirisModStatus.NONE}">
										<Setter Property="Data" Value="{x:Null}" />
									</DataTrigger>
								<DataTrigger Binding="{Binding Path=OsirisModStatus}" Value="{x:Static dapp:DivinityOsirisModStatus.SCRIPTS}">
									<Setter Property="Data" Value="{StaticResource Redux.Icon.Terminal}" />
									<Setter Property="Foreground" Value="{DynamicResource ReduxInfoBrush}" />
									<Setter Property="Opacity" Value="1.0" />
									<Setter Property="Visibility" Value="Visible" />
								</DataTrigger>
								<DataTrigger Binding="{Binding Path=OsirisModStatus}" Value="{x:Static dapp:DivinityOsirisModStatus.MODFIXER}">
									<Setter Property="Data" Value="{StaticResource Redux.Icon.Build}" />
									<Setter Property="Foreground" Value="{DynamicResource ReduxWarningBrush}" />
									<Setter Property="Opacity" Value="1.0" />
									<Setter Property="Visibility" Value="Visible" />
								</DataTrigger>
								</Style.Triggers>
							</Style>
						</controls:ReduxIcon.Style>
					</controls:ReduxIcon>
					<controls:ReduxIcon Width="16"
					    Height="16"
					    MaxWidth="16"
					    MaxHeight="16"
					    Margin="2,0"
					    HorizontalAlignment="Center"
					    VerticalAlignment="Center"
					    Data="{StaticResource Redux.Icon.Danger}"
					    Foreground="{DynamicResource ReduxErrorBrush}"
					    IsHitTestVisible="True"
					    ToolTip="{Binding MissingDependencyToolTip}"
					    Visibility="{Binding MissingDependencyIconVisibility, FallbackValue=Collapsed}" />
					<controls:ReduxIcon Width="16"
					    Height="16"
					    MaxWidth="16"
					    MaxHeight="16"
					    Margin="2,0"
					    HorizontalAlignment="Center"
					    VerticalAlignment="Center"
					    Data="{StaticResource Redux.Icon.Danger}"
					    Foreground="{DynamicResource ReduxErrorBrush}"
					    IsHitTestVisible="True"
					    ToolTip="This mod has an invalid UUID, and will likely fail to load"
					    Visibility="{Binding HasInvalidUUIDVisibility, FallbackValue=Collapsed}" />
					<controls:ReduxIcon Width="16"
					    Height="16"
					    MaxWidth="16"
					    MaxHeight="16"
					    Margin="2,0"
					    HorizontalAlignment="Center"
					    VerticalAlignment="Center"
					    Data="{StaticResource Redux.Icon.Build}"
					    IsHitTestVisible="True"
					    ToolTip="Toolkit Mod Project"
					    Visibility="{Binding ToolkitIconVisibility, FallbackValue=Collapsed}" />
					<controls:ReduxIcon Width="16"
					    Height="16"
					    MaxWidth="16"
					    MaxHeight="16"
					    Margin="2,0"
					    HorizontalAlignment="Center"
					    VerticalAlignment="Center"
					    IsHitTestVisible="True"
					    DataContext="{Binding}"
					    Visibility="{Binding ExtenderStatusVisibility, FallbackValue=Collapsed}">
						<controls:ReduxIcon.ToolTip>
							<ToolTip Style="{StaticResource ReduxRichToolTipStyle}">
								<Border MaxWidth="390" Padding="12,10"
									Background="{DynamicResource ReduxSurfaceElevatedBrush}"
									BorderThickness="1" CornerRadius="{DynamicResource Redux.CornerRadius.Card}">
									<Border.Style>
										<Style TargetType="{x:Type Border}">
											<Setter Property="BorderBrush" Value="{DynamicResource ReduxInfoBrush}" />
											<Style.Triggers>
												<DataTrigger Binding="{Binding ExtenderIcon}" Value="{x:Static dapp:ScriptExtenderIconType.Warning}">
													<Setter Property="BorderBrush" Value="{DynamicResource ReduxWarningBrush}" />
												</DataTrigger>
												<DataTrigger Binding="{Binding ExtenderIcon}" Value="{x:Static dapp:ScriptExtenderIconType.Missing}">
													<Setter Property="BorderBrush" Value="{DynamicResource ReduxErrorBrush}" />
												</DataTrigger>
											</Style.Triggers>
										</Style>
									</Border.Style>
									<StackPanel>
										<TextBlock FontSize="13" FontWeight="SemiBold">
											<TextBlock.Style>
												<Style TargetType="{x:Type TextBlock}">
													<Setter Property="Foreground" Value="{DynamicResource ReduxInfoBrush}" />
													<Setter Property="Text" Value="Script Extender status" />
													<Style.Triggers>
														<DataTrigger Binding="{Binding ExtenderIcon}" Value="{x:Static dapp:ScriptExtenderIconType.Warning}">
															<Setter Property="Foreground" Value="{DynamicResource ReduxWarningBrush}" />
															<Setter Property="Text" Value="Script Extender warning" />
														</DataTrigger>
														<DataTrigger Binding="{Binding ExtenderIcon}" Value="{x:Static dapp:ScriptExtenderIconType.Missing}">
															<Setter Property="Foreground" Value="{DynamicResource ReduxErrorBrush}" />
															<Setter Property="Text" Value="Script Extender missing" />
														</DataTrigger>
													</Style.Triggers>
												</Style>
											</TextBlock.Style>
										</TextBlock>
										<TextBlock Margin="0,5,0,0"
											Foreground="{DynamicResource ReduxTextPrimaryBrush}"
											Text="{Binding ScriptExtenderSupportToolTipText}"
											TextWrapping="Wrap" />
									</StackPanel>
								</Border>
							</ToolTip>
						</controls:ReduxIcon.ToolTip>
						<controls:ReduxIcon.Style>
							<Style BasedOn="{StaticResource {x:Type controls:ReduxIcon}}" TargetType="{x:Type controls:ReduxIcon}">
								<Setter Property="Data" Value="{StaticResource Redux.Icon.ExtensionPuzzle}" />
								<Setter Property="Foreground" Value="{DynamicResource ReduxInfoBrush}" />
								<Style.Triggers>
									<DataTrigger Binding="{Binding Path=ExtenderIcon}" Value="{x:Static dapp:ScriptExtenderIconType.None}">
										<Setter Property="Data" Value="{x:Null}" />
									</DataTrigger>
									<DataTrigger Binding="{Binding Path=ExtenderIcon}" Value="{x:Static dapp:ScriptExtenderIconType.Missing}">
										<Setter Property="Foreground" Value="{DynamicResource ReduxErrorBrush}" />
										<Setter Property="Opacity" Value="1.0" />
									</DataTrigger>
									<DataTrigger Binding="{Binding Path=ExtenderIcon}" Value="{x:Static dapp:ScriptExtenderIconType.Warning}">
										<Setter Property="Foreground" Value="{DynamicResource ReduxWarningBrush}" />
										<Setter Property="Opacity" Value="1.0" />
									</DataTrigger>
									<DataTrigger Binding="{Binding Path=ExtenderIcon}" Value="{x:Static dapp:ScriptExtenderIconType.FulfilledRequired}">
										<Setter Property="Foreground" Value="{DynamicResource ReduxSuccessBrush}" />
										<Setter Property="Opacity" Value="1.0" />
									</DataTrigger>
									<DataTrigger Binding="{Binding Path=ExtenderIcon}" Value="{x:Static dapp:ScriptExtenderIconType.FulfilledSupports}">
										<Setter Property="Foreground" Value="{DynamicResource ReduxInfoBrush}" />
										<Setter Property="Opacity" Value="0.5" />
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</controls:ReduxIcon.Style>
					</controls:ReduxIcon>
				</StackPanel>
			</Border>
		</controls:ModEntryGrid>
	</DataTemplate>
	<DataTemplate x:Key="ModAuthorTemplate" DataType="{x:Type data:DivinityModData}">
		<TextBlock>
			<TextBlock.Style>
				<Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="{x:Type TextBlock}">
					<Setter Property="Text" Value="{Binding Author}" />
					<Setter Property="ToolTip" Value="{Binding Author}" />
					<Style.Triggers>
						<DataTrigger Binding="{Binding NexusModsInformationVisibility}" Value="Visible">
							<Setter Property="Text" Value="{Binding NexusModsData.Author}" />
							<Setter Property="ToolTip" Value="{Binding NexusModsData.Author}" />
						</DataTrigger>
						<DataTrigger Binding="{Binding NexusModsData.Author}" Value="">
							<Setter Property="Text" Value="{Binding Author}" />
							<Setter Property="ToolTip" Value="{Binding Author}" />
						</DataTrigger>
						<DataTrigger Binding="{Binding NexusModsData.Author}" Value="{x:Null}">
							<Setter Property="Text" Value="{Binding Author}" />
							<Setter Property="ToolTip" Value="{Binding Author}" />
						</DataTrigger>
					</Style.Triggers>
				</Style>
			</TextBlock.Style>
		</TextBlock>
	</DataTemplate>
	<DataTemplate x:Key="ModLastUpdatedTemplate" DataType="{x:Type data:DivinityModData}">
		<TextBlock Text="{Binding DisplayLastUpdated, StringFormat={x:Static dapp:DivinityApp.DateTimeColumnFormat}}"
		    ToolTip="{Binding DisplayLastUpdated, StringFormat={x:Static dapp:DivinityApp.DateTimeTooltipFormat}}" />
	</DataTemplate>
	<DataTemplate x:Key="ModLastModifiedTemplate" DataType="{x:Type data:DivinityModData}">
		<TextBlock Text="{Binding LastModified, StringFormat={x:Static dapp:DivinityApp.DateTimeColumnFormat}}"
		    ToolTip="{Binding LastModified, StringFormat={x:Static dapp:DivinityApp.DateTimeTooltipFormat}}" />
	</DataTemplate>
	<DataTemplate x:Key="NexusPlatformIconTemplate">
		<Image Width="14" Height="14"
			RenderOptions.BitmapScalingMode="HighQuality"
			Source="/BG3ModManager;component/Resources/Icons/Platforms/nexus.png"
			Stretch="Uniform" />
	</DataTemplate>
	<DataTemplate x:Key="ModioPlatformIconTemplate">
		<Image Width="14" Height="14"
			RenderOptions.BitmapScalingMode="HighQuality"
			Source="/BG3ModManager;component/Resources/Icons/Platforms/modio.png"
			Stretch="Uniform" />
	</DataTemplate>
	<DataTemplate x:Key="PlatformIconPresenterTemplate" DataType="{x:Type data:DivinityModData}">
		<Grid Width="14" Height="14">
			<ContentControl ContentTemplate="{StaticResource NexusPlatformIconTemplate}">
				<ContentControl.Style><Style TargetType="ContentControl"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding Metadata.SourceType}" Value="{x:Static dapp:ModSourceType.NEXUSMODS}"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></ContentControl.Style>
			</ContentControl>
			<ContentControl ContentTemplate="{StaticResource ModioPlatformIconTemplate}">
				<ContentControl.Style><Style TargetType="ContentControl"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding Metadata.SourceType}" Value="{x:Static dapp:ModSourceType.MODIO}"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></ContentControl.Style>
			</ContentControl>
		</Grid>
	</DataTemplate>
	<DataTemplate x:Key="ModSourceTemplate" DataType="{x:Type data:DivinityModData}">
		<Grid HorizontalAlignment="Left" ClipToBounds="True">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<Border Grid.Column="0" Style="{StaticResource ReduxSourcePillStyle}"
				ToolTip="{Binding DisplaySource, StringFormat='Metadata source: {0}'}">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>
					<ContentControl Margin="0,0,5,0" Content="{Binding}" ContentTemplate="{StaticResource PlatformIconPresenterTemplate}" Visibility="{Binding Metadata.OnlineSourceVisibility}" />
					<TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="11" FontWeight="Medium"
						Foreground="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType={x:Type Border}}}"
						Text="{Binding DisplaySource}" TextTrimming="CharacterEllipsis" />
				</Grid>
			</Border>
			<Viewbox Grid.Column="1" Width="16" Height="16" Margin="5,0,0,0"
				VerticalAlignment="Center" Stretch="Uniform">
				<Viewbox.ToolTip>
					<ToolTip Placement="Mouse" HorizontalOffset="12" VerticalOffset="10" Style="{StaticResource ReduxRichToolTipStyle}">
						<Border MaxWidth="390"
							Padding="12,10"
							Background="{DynamicResource ReduxSurfaceElevatedBrush}"
							BorderBrush="{DynamicResource ReduxWarningBrush}"
							BorderThickness="1"
							CornerRadius="{DynamicResource Redux.CornerRadius.Card}">
							<StackPanel>
								<TextBlock FontFamily="{DynamicResource Redux.FontFamily.UI}"
									FontSize="13"
									FontWeight="SemiBold"
									Foreground="{DynamicResource ReduxWarningBrush}"
									Text="Limited mod.io support" />
								<TextBlock Margin="0,5,0,0"
									FontFamily="{DynamicResource Redux.FontFamily.UI}"
									Foreground="{DynamicResource ReduxTextPrimaryBrush}"
									Text="Subscribed mods can be restored or redownloaded by BG3 after Redux deletes the local file."
									TextWrapping="Wrap" />
								<TextBlock Margin="0,6,0,0"
									FontFamily="{DynamicResource Redux.FontFamily.UI}"
									Foreground="{DynamicResource ReduxTextSecondaryBrush}"
									Text="Unsubscribe through mod.io or BG3's in-game Mod Manager when removing the mod. Manual/local or Nexus Mods installations are recommended for predictable file management."
									TextWrapping="Wrap" />
							</StackPanel>
						</Border>
					</ToolTip>
				</Viewbox.ToolTip>
				<Viewbox.Style>
					<Style TargetType="{x:Type Viewbox}">
						<Setter Property="Visibility" Value="Collapsed" />
						<Style.Triggers>
							<MultiDataTrigger>
								<MultiDataTrigger.Conditions>
									<Condition Binding="{Binding Metadata.ModioWarningVisibility}" Value="Visible" />
									<Condition Binding="{Binding DataContext.Settings.HideModioSourceWarningIcons, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" Value="False" />
								</MultiDataTrigger.Conditions>
								<Setter Property="Visibility" Value="Visible" />
							</MultiDataTrigger>
						</Style.Triggers>
					</Style>
				</Viewbox.Style>
				<controls:ReduxIcon Width="16" Height="16"
					Data="{StaticResource Redux.Icon.Danger}"
					Foreground="{DynamicResource ReduxWarningBrush}"
					IsHitTestVisible="True" />
			</Viewbox>
		</Grid>
	</DataTemplate>
	<Style x:Key="ReduxCategoryPillStyle" BasedOn="{StaticResource ReduxCategoryPillBaseStyle}" TargetType="{x:Type Border}">
		<Setter Property="Margin" Value="0,0,5,0" />
	</Style>
	<DataTemplate x:Key="ModCategoryPillItemTemplate">
		<Border MaxWidth="170" Style="{StaticResource ReduxCategoryPillStyle}">
			<StackPanel Orientation="Horizontal">
				<controls:ReduxIcon Width="12" Height="12" Margin="0,0,5,0" IconKey="{Binding IconId}" Foreground="{Binding Color}">
					<controls:ReduxIcon.Style>
						<Style BasedOn="{StaticResource {x:Type controls:ReduxIcon}}" TargetType="{x:Type controls:ReduxIcon}">
							<Setter Property="Visibility" Value="Collapsed" />
							<Style.Triggers>
								<MultiDataTrigger>
									<MultiDataTrigger.Conditions>
										<Condition Binding="{Binding HasIcon}" Value="True" />
										<Condition Binding="{Binding DataContext.Settings.ShowCategoryIconsInPills, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" Value="True" />
									</MultiDataTrigger.Conditions>
									<Setter Property="Visibility" Value="Visible" />
								</MultiDataTrigger>
							</Style.Triggers>
						</Style>
					</controls:ReduxIcon.Style>
				</controls:ReduxIcon>
				<TextBlock FontSize="11" FontWeight="Medium" Foreground="{Binding Color}"
					Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
			</StackPanel>
		</Border>
	</DataTemplate>
	<DataTemplate x:Key="ModCategoryTemplate" DataType="{x:Type data:DivinityModData}">
		<ItemsControl ClipToBounds="True"
			ItemTemplate="{StaticResource ModCategoryPillItemTemplate}"
			ItemsSource="{Binding DisplayCategories}"
			ToolTip="{Binding DisplayCategory}">
			<ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
		</ItemsControl>
	</DataTemplate>
	<Style x:Key="GridViewLeftContainerStyle" BasedOn="{StaticResource {x:Type GridViewColumnHeader}}" TargetType="{x:Type GridViewColumnHeader}">
		<Setter Property="Height" Value="30" />
		<Setter Property="Padding" Value="8,0" />
		<Setter Property="FontWeight" Value="SemiBold" />
		<Setter Property="Background" Value="{DynamicResource ReduxSurfaceMutedBrush}" />
		<Setter Property="BorderBrush" Value="{DynamicResource ReduxBorderBrush}" />
		<Setter Property="Foreground" Value="{DynamicResource ReduxTextSecondaryBrush}" />
		<Setter Property="HorizontalContentAlignment" Value="Left" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="Margin" Value="0" />
	</Style>
	<Style x:Key="GridViewCenteredContainerStyle" BasedOn="{StaticResource {x:Type GridViewColumnHeader}}" TargetType="{x:Type GridViewColumnHeader}">
		<Setter Property="HorizontalContentAlignment" Value="Center" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="Margin" Value="2" />
	</Style>
	<DataTemplate x:Key="GridViewTextblockHeaderTemplate">
		<TextBlock Margin="2,0,2,0" Text="{Binding}" />
	</DataTemplate>
	<GridView x:Key="ModGridView"
	    x:Shared="False"
	    AllowsColumnReorder="True"
	    ColumnHeaderContainerStyle="{StaticResource GridViewLeftContainerStyle}">
