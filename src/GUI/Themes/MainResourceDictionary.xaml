	<DataTemplate x:Key="ModSourceTemplate" DataType="{x:Type data:DivinityModData}">
		<!--
			ClipToBounds off: the pill's MaxWidth clamp already stops text spilling into the
			next column (ellipsis inside the pill), and clipping here visibly cuts off the
			shared 2% hover grow when the pill sits flush against the cell edge.
		-->
		<Grid HorizontalAlignment="Left" ClipToBounds="False">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<Border Grid.Column="0" Style="{StaticResource ReduxSourcePillStyle}"
				ToolTip="{Binding DisplaySource, StringFormat='Metadata source: {0}'}">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
