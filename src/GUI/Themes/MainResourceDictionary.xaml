	<DataTemplate x:Key="ModSourceTemplate" DataType="{x:Type data:DivinityModData}">
		<StackPanel Orientation="Horizontal">
			<Border Padding="7,2" VerticalAlignment="Center" BorderThickness="1" CornerRadius="8"
				ToolTip="{Binding DisplaySource, StringFormat='Metadata source: {0}'}">
				<Border.Style><Style TargetType="Border">
					<Setter Property="Background" Value="#168F879E" /><Setter Property="BorderBrush" Value="#668F879E" />
					<Style.Triggers>
						<DataTrigger Binding="{Binding Metadata.SourceType}" Value="{x:Static dapp:ModSourceType.NEXUSMODS}"><Setter Property="Background" Value="#22F9A332" /><Setter Property="BorderBrush" Value="#F9A332" /></DataTrigger>
						<DataTrigger Binding="{Binding Metadata.SourceType}" Value="{x:Static dapp:ModSourceType.MODIO}"><Setter Property="Background" Value="#2205C2D8" /><Setter Property="BorderBrush" Value="#05C2D8" /></DataTrigger>
					</Style.Triggers>
				</Style></Border.Style>
				<StackPanel Orientation="Horizontal">
					<ContentControl Margin="0,0,5,0" Content="{Binding}" ContentTemplate="{StaticResource PlatformIconPresenterTemplate}" Visibility="{Binding Metadata.OnlineSourceVisibility}" />
					<TextBlock VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ReduxTextPrimaryBrush}" Text="{Binding DisplaySource}" />
				</StackPanel>
			</Border>
			<Image Width="16" Height="16" Margin="6,0,0,0"
			    VerticalAlignment="Center"
				RenderOptions.BitmapScalingMode="HighQuality"
				Source="/BG3ModManager;component/Resources/Icons/Platforms/modio-warning.png"
				Stretch="Uniform">
				<Image.ToolTip>
					<ToolTip Placement="Mouse" HorizontalOffset="12" VerticalOffset="10">
						<Border MaxWidth="390"
							Padding="12,10"
							Background="{DynamicResource ReduxSurfaceElevatedBrush}"
							BorderBrush="{DynamicResource ReduxWarningBrush}"
							BorderThickness="1"
							CornerRadius="8">
							<StackPanel>
								<TextBlock FontFamily="{DynamicResource Redux.FontFamily.UI}"
									FontSize="13"
									FontWeight="SemiBold"
									Foreground="{DynamicResource ReduxWarningBrush}"
									Text="Limited mod.io support" />
								<TextBlock Margin="0,5,0,0"
									FontFamily="{DynamicResource Redux.FontFamily.UI}"
									Foreground="{DynamicResource ReduxTextPrimaryBrush}"
									Text="Subscribed mods can be restored or redownloaded by BG3 after Redux deletes the local file."
									TextWrapping="Wrap" />
								<TextBlock Margin="0,6,0,0"
									FontFamily="{DynamicResource Redux.FontFamily.UI}"
									Foreground="{DynamicResource ReduxTextSecondaryBrush}"
									Text="Unsubscribe through mod.io or BG3's in-game Mod Manager when removing the mod. Manual/local or Nexus Mods installations are recommended for predictable file management."
									TextWrapping="Wrap" />
							</StackPanel>
						</Border>
					</ToolTip>
				</Image.ToolTip>
				<Image.Style>
					<Style TargetType="{x:Type Image}">
						<Setter Property="Visibility" Value="Collapsed" />
						<Style.Triggers>
							<MultiDataTrigger>
								<MultiDataTrigger.Conditions>
									<Condition Binding="{Binding Metadata.ModioWarningVisibility}" Value="Visible" />
									<Condition Binding="{Binding DataContext.Settings.HideModioSourceWarningIcons, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" Value="False" />
								</MultiDataTrigger.Conditions>
								<Setter Property="Visibility" Value="Visible" />
							</MultiDataTrigger>
						</Style.Triggers>
					</Style>
				</Image.Style>
			</Image>
		</StackPanel>
	</DataTemplate>
	<DataTemplate x:Key="ModCategoryTemplate" DataType="{x:Type data:DivinityModData}">
		<ItemsControl ItemsSource="{Binding DisplayCategories}" ToolTip="{Binding DisplayCategory}">
			<ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
			<ItemsControl.ItemTemplate>
				<DataTemplate>
					<Border Margin="0,0,4,0" Padding="7,2" HorizontalAlignment="Left" VerticalAlignment="Center"
						Background="{Binding SoftColor}" BorderBrush="{Binding Color}" BorderThickness="1" CornerRadius="8">
						<TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ReduxTextPrimaryBrush}"
							Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
					</Border>
				</DataTemplate>
			</ItemsControl.ItemTemplate>
		</ItemsControl>
