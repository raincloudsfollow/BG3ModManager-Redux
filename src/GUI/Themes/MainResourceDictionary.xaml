	<!--
		Shared "accent-soft pill" button chrome (Settings action buttons, drawer source/author
		buttons). Variants set only sizing (Height/Padding/Margin) and color-trigger overrides
		via BasedOn; do not redeclare the template.
	-->
	<ControlTemplate x:Key="ReduxAccentPillButtonTemplate" TargetType="{x:Type Button}">
		<Border x:Name="ButtonChrome"
			Padding="{TemplateBinding Padding}"
			Background="{TemplateBinding Background}"
			BorderBrush="{TemplateBinding BorderBrush}"
			BorderThickness="{TemplateBinding BorderThickness}"
			CornerRadius="{DynamicResource Redux.CornerRadius.Pill}"
			RenderTransformOrigin="0.5,0.5"
			SnapsToDevicePixels="True">
			<Border.RenderTransform>
				<ScaleTransform ScaleX="1" ScaleY="1" />
			</Border.RenderTransform>
			<ContentPresenter HorizontalAlignment="Center"
				VerticalAlignment="Center"
				Content="{TemplateBinding Content}"
				ContentTemplate="{TemplateBinding ContentTemplate}" />
		</Border>
		<ControlTemplate.Triggers>
			<!--
				Opacity, not a color swap: variants set their own identity color (accent,
				Nexus orange, mod.io cyan, warning red) via Background/BorderBrush, and a
				hardcoded hover color here would stomp whichever one is active.
				Hover grow matches ReduxPillBaseStyle so pill-shaped buttons and static
				pills feel like one family.
			-->
			<Trigger Property="IsMouseOver" Value="True">
				<Setter TargetName="ButtonChrome" Property="Opacity" Value="0.85" />
				<Trigger.EnterActions>
					<BeginStoryboard>
						<Storyboard>
							<DoubleAnimation Storyboard.TargetName="ButtonChrome" Storyboard.TargetProperty="RenderTransform.ScaleX"
								To="1.02" Duration="{StaticResource Redux.Motion.Fast}" EasingFunction="{StaticResource Redux.Motion.EaseOut}" />
							<DoubleAnimation Storyboard.TargetName="ButtonChrome" Storyboard.TargetProperty="RenderTransform.ScaleY"
								To="1.02" Duration="{StaticResource Redux.Motion.Fast}" EasingFunction="{StaticResource Redux.Motion.EaseOut}" />
						</Storyboard>
					</BeginStoryboard>
				</Trigger.EnterActions>
				<Trigger.ExitActions>
					<BeginStoryboard>
						<Storyboard>
							<DoubleAnimation Storyboard.TargetName="ButtonChrome" Storyboard.TargetProperty="RenderTransform.ScaleX"
								To="1" Duration="{StaticResource Redux.Motion.Standard}" />
							<DoubleAnimation Storyboard.TargetName="ButtonChrome" Storyboard.TargetProperty="RenderTransform.ScaleY"
								To="1" Duration="{StaticResource Redux.Motion.Standard}" />
						</Storyboard>
					</BeginStoryboard>
				</Trigger.ExitActions>
			</Trigger>
			<Trigger Property="IsPressed" Value="True">
				<Setter TargetName="ButtonChrome" Property="Opacity" Value="0.72" />
			</Trigger>
			<Trigger Property="IsEnabled" Value="False">
				<Setter TargetName="ButtonChrome" Property="Opacity" Value="0.45" />
			</Trigger>
		</ControlTemplate.Triggers>
	</ControlTemplate>
	<Style x:Key="ReduxAccentPillButtonStyle" TargetType="{x:Type Button}">
