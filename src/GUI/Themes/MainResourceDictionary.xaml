	<!--  Keep native menu behavior while giving Redux popups a softer silhouette.  -->
	<!--
		Redux corner-radius scale. Single source of truth; do not hardcode radii on new
		surfaces. Small = checkboxes/small chips/markers. Control = buttons, fields,
		combos, menus, tab chrome. ControlInner = hover/selection overlays nested 1px
		inside Control chrome. Card = panels, section cards, popups, dialogs.
		Pill = capsule pills and badges. Intentionally NOT tokenized: true circles,
		height-dependent capsules, the 1-2px underline accents, and the miniature
		mockup shapes inside theme preview cards.
	-->
	<CornerRadius x:Key="Redux.CornerRadius.Small">4</CornerRadius>
	<CornerRadius x:Key="Redux.CornerRadius.Control">7</CornerRadius>
	<CornerRadius x:Key="Redux.CornerRadius.ControlInner">6</CornerRadius>
	<CornerRadius x:Key="Redux.CornerRadius.Card">8</CornerRadius>
	<CornerRadius x:Key="Redux.CornerRadius.Pill">10</CornerRadius>
	<Style BasedOn="{StaticResource {x:Type ContextMenu}}" TargetType="{x:Type ContextMenu}">
		<Setter Property="Background" Value="{DynamicResource ReduxSurfaceElevatedBrush}" />
		<Setter Property="BorderBrush" Value="{DynamicResource ReduxBorderBrush}" />
		<Setter Property="BorderThickness" Value="1" />
		<Setter Property="adonisExtensions:CornerRadiusExtension.CornerRadius" Value="{DynamicResource Redux.CornerRadius.Control}" />
	</Style>
	<!--  Short, functional motion only: hover feedback and state transitions.  -->
	<Duration x:Key="Redux.Motion.Fast">0:0:0.12</Duration>
	<Duration x:Key="Redux.Motion.Standard">0:0:0.16</Duration>
	<QuadraticEase x:Key="Redux.Motion.EaseOut" EasingMode="EaseOut" />
	<!--  Shared source-pill palette. Keep list, drawer, and preview treatments visually identical.  -->
	<SolidColorBrush x:Key="Redux.Pill.Local.Background" Color="#168F879E" />
	<SolidColorBrush x:Key="Redux.Pill.Local.Border" Color="#668F879E" />
	<SolidColorBrush x:Key="Redux.Pill.Nexus.Background" Color="#2EF9A332" />
	<SolidColorBrush x:Key="Redux.Pill.Nexus.Border" Color="#F9A332" />
	<SolidColorBrush x:Key="Redux.Pill.Modio.Background" Color="#2E05C2D8" />
	<SolidColorBrush x:Key="Redux.Pill.Modio.Border" Color="#05C2D8" />

