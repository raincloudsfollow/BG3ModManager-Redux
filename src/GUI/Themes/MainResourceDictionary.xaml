		<Setter Property="HorizontalContentAlignment" Value="Stretch" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="{x:Type ListViewItem}">
					<StackPanel>
						<Border x:Name="VisualDivider"
							Margin="12,8,12,6"
							Padding="0,4"
							Background="Transparent"
							Visibility="{Binding ShowVisualDivider, Converter={StaticResource BoolToVisibilityConverter}}">
							<Grid>
								<Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
								<ToggleButton Width="22" Height="22" Margin="0,0,5,0" Padding="0" Background="Transparent" BorderThickness="0"
									Tag="ReduxDividerToggle" ToolTip="Collapse or expand this separator section" IsChecked="{Binding IsVisualDividerCollapsed, Mode=OneWay}">
									<Path Width="8" Height="5" Fill="{DynamicResource ReduxTextSecondaryBrush}" Stretch="Uniform">
										<Path.Style><Style TargetType="Path"><Setter Property="Data" Value="M 0,0 L 8,0 L 4,5 Z" /><Style.Triggers><DataTrigger Binding="{Binding IsVisualDividerCollapsed}" Value="True"><Setter Property="Data" Value="M 0,0 L 5,4 L 0,8 Z" /><Setter Property="Width" Value="5" /><Setter Property="Height" Value="8" /></DataTrigger></Style.Triggers></Style></Path.Style>
									</Path>
								</ToggleButton>
								<Path Grid.Column="1" Width="12" Height="12" Margin="0,0,8,0"
										Data="M 6,0 L 12,6 L 6,12 L 0,6 Z M 6,3 L 9,6 L 6,9 L 3,6 Z"
										Fill="{Binding VisualDividerColor, Converter={StaticResource StringToSolidBrushConverter}}"
										Stretch="Uniform" />
								<TextBlock Grid.Column="2" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"
										Foreground="{Binding VisualDividerColor, Converter={StaticResource StringToSolidBrushConverter}}"
										Text="{Binding VisualDividerTitle}" TextTrimming="CharacterEllipsis"
										Visibility="{Binding VisualDividerTitle, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" />
								<Border Grid.Column="3" Height="1" VerticalAlignment="Center"
									Background="{Binding VisualDividerColor, Converter={StaticResource StringToSolidBrushConverter}}" />
							</Grid>
						</Border>
						<Border x:Name="RowBorder"
							MinHeight="{TemplateBinding MinHeight}"
							Padding="{TemplateBinding Padding}"
							Background="{TemplateBinding Background}"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="{TemplateBinding BorderThickness}"
							SnapsToDevicePixels="True">
							<GridViewRowPresenter
								Columns="{Binding Path=View.Columns, RelativeSource={RelativeSource AncestorType={x:Type ListView}}}"
								Content="{TemplateBinding Content}"
								VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
						</Border>
					</StackPanel>
					<ControlTemplate.Triggers>
						<Trigger Property="IsMouseOver" Value="True">
							<Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource ReduxAccentSoftBrush}" />
						</Trigger>
						<Trigger Property="IsSelected" Value="True">
							<Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource ReduxSelectionBrush}" />
							<Setter TargetName="RowBorder" Property="BorderBrush" Value="{DynamicResource ReduxAccentBrush}" />
						</Trigger>
						<MultiDataTrigger>
							<MultiDataTrigger.Conditions>
								<Condition Binding="{Binding IsVisualDivider}" Value="True" />
								<Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}}" Value="True" />
								<Condition Binding="{Binding DataContext.IsDragging, RelativeSource={RelativeSource AncestorType={x:Type ListView}}}" Value="True" />
							</MultiDataTrigger.Conditions>
							<Setter TargetName="VisualDivider" Property="Effect">
								<Setter.Value>
									<DropShadowEffect BlurRadius="13" Color="{DynamicResource ReduxAccentHoverColor}" Opacity="0.9" ShadowDepth="0" />
								</Setter.Value>
							</Setter>
						</MultiDataTrigger>
						<DataTrigger Binding="{Binding IsVisualDivider}" Value="True">
							<Setter TargetName="RowBorder" Property="Visibility" Value="Collapsed" />
						</DataTrigger>
					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
		<!--
			IsSelected is set via ActiveModListView_ItemContainerStatusChanged.UpdateViewSelection instead,
			so focus and selection can be more finely controlled.
		-->
		<!--<Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />-->
		<Setter Property="Visibility" Value="{Binding Visibility, FallbackValue='Visible'}" />
		<Setter Property="FocusVisualStyle">
			<Setter.Value>
				<Style>
					<Setter Property="Control.Template">
						<Setter.Value>
							<ControlTemplate>
								<Rectangle SnapsToDevicePixels="true" Stroke="{DynamicResource ReduxAccentHoverBrush}" StrokeThickness="2" />
							</ControlTemplate>
						</Setter.Value>
					</Setter>
				</Style>
			</Setter.Value>
		</Setter>
		<Style.Triggers>
			<DataTrigger Binding="{Binding IsHiddenByVisualDivider}" Value="True">
				<Setter Property="Visibility" Value="Collapsed" />
			</DataTrigger>
			<Trigger Property="IsMouseOver" Value="True">
				<Setter Property="Background" Value="{DynamicResource ReduxAccentSoftBrush}" />
			</Trigger>
			<Trigger Property="IsSelected" Value="True">
				<Setter Property="Background" Value="{DynamicResource ReduxSelectionBrush}" />
				<Setter Property="BorderBrush" Value="{DynamicResource ReduxAccentBrush}" />
			</Trigger>
			<MultiDataTrigger>
				<MultiDataTrigger.Conditions>
					<Condition Binding="{Binding HasColorOverride}" Value="True" />
					<Condition Binding="{Binding IsSelected}" Value="False" />
				</MultiDataTrigger.Conditions>
				<MultiDataTrigger.Setters>
					<Setter Property="Background" Value="{Binding ListColor, Converter={StaticResource StringToSolidBrushConverter}}" />
				</MultiDataTrigger.Setters>
			</MultiDataTrigger>
			<MultiDataTrigger>
				<MultiDataTrigger.Conditions>
					<Condition Binding="{Binding HasColorOverride}" Value="True" />
					<Condition Binding="{Binding IsSelected}" Value="True" />
				</MultiDataTrigger.Conditions>
				<MultiDataTrigger.Setters>
					<Setter Property="Background" Value="{Binding SelectedColor, Converter={StaticResource StringToLinearBrushConverter}}" />
				</MultiDataTrigger.Setters>
			</MultiDataTrigger>
		</Style.Triggers>
	</Style>
	<Style x:Key="DivinityModUpdateNewListItem" BasedOn="{StaticResource {x:Type ListViewItem}}" TargetType="{x:Type ListViewItem}">
