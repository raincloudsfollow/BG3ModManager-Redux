	<Style TargetType="{x:Type controls:ReduxIcon}">
		<Setter Property="Width" Value="18" />
		<Setter Property="Height" Value="18" />
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="Foreground" Value="{DynamicResource ReduxIconBrush}" />
		<Setter Property="Focusable" Value="False" />
		<Setter Property="IsHitTestVisible" Value="False" />
		<!-- Thin 2px Lucide strokes render smoother with sub-pixel anti-aliasing than pixel-snapped,
		     which was tuned for the old solid-fill icon set and makes thin strokes look jagged. -->
		<Setter Property="SnapsToDevicePixels" Value="False" />
		<Setter Property="UseLayoutRounding" Value="False" />
		<Setter Property="StrokeThickness" Value="2.25" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="{x:Type controls:ReduxIcon}">
					<Border Background="{TemplateBinding Background}">
						<Grid>
							<Viewbox Stretch="Uniform">
								<Canvas Width="24" Height="24" Background="Transparent">
									<Path Width="24" Height="24" Data="{TemplateBinding Data}" Fill="{TemplateBinding Foreground}" />
									<Path Width="24" Height="24" Data="{TemplateBinding StrokeData}" Fill="Transparent"
										Stroke="{TemplateBinding Foreground}" StrokeThickness="{TemplateBinding StrokeThickness}"
										StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
								</Canvas>
							</Viewbox>
						</Grid>
					</Border>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
