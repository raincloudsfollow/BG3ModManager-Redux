	<Style x:Key="IconButtonStyle" BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
		<Setter Property="Width" Value="24" />
		<Setter Property="Height" Value="24" />
		<Setter Property="Margin" Value="2,0,2,0" />
		<Setter Property="Padding" Value="0" />
		<Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
		<Setter Property="Background" Value="{DynamicResource {x:Static adonisUI:Brushes.Layer0BackgroundBrush}}" />
		<Setter Property="BorderThickness" Value="0" />
	</Style>
	<!--
		Modern Redux scrollbars keep a generous transparent interaction lane while the
		visible thumb remains thin and rounded. Hover changes contrast only; it never
		expands into the full square WPF/Adonis scrollbar chrome.
	-->
	<Style x:Key="ReduxScrollPageButtonStyle" TargetType="{x:Type RepeatButton}">
		<Setter Property="Focusable" Value="False" />
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="{x:Type RepeatButton}">
					<Border Background="Transparent" />
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
	<Style x:Key="ReduxVerticalScrollThumbStyle" TargetType="{x:Type Thumb}">
		<Setter Property="MinHeight" Value="28" />
		<Setter Property="Background" Value="{DynamicResource ReduxBorderStrongBrush}" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="{x:Type Thumb}">
					<Grid Background="Transparent">
						<Border x:Name="ThumbVisual"
							Width="5"
							HorizontalAlignment="Center"
							Background="{TemplateBinding Background}"
							CornerRadius="3" />
					</Grid>
					<ControlTemplate.Triggers>
						<Trigger Property="IsMouseOver" Value="True">
							<Setter TargetName="ThumbVisual" Property="Background" Value="{DynamicResource ReduxAccentBrush}" />
						</Trigger>
						<Trigger Property="IsDragging" Value="True">
							<Setter TargetName="ThumbVisual" Property="Background" Value="{DynamicResource ReduxAccentHoverBrush}" />
						</Trigger>
						<Trigger Property="IsEnabled" Value="False">
							<Setter TargetName="ThumbVisual" Property="Opacity" Value="0.35" />
						</Trigger>
					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
	<Style x:Key="ReduxHorizontalScrollThumbStyle" TargetType="{x:Type Thumb}">
		<Setter Property="MinWidth" Value="28" />
		<Setter Property="Background" Value="{DynamicResource ReduxBorderStrongBrush}" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="{x:Type Thumb}">
					<Grid Background="Transparent">
						<Border x:Name="ThumbVisual"
							Height="5"
							VerticalAlignment="Center"
							Background="{TemplateBinding Background}"
							CornerRadius="3" />
					</Grid>
					<ControlTemplate.Triggers>
						<Trigger Property="IsMouseOver" Value="True">
							<Setter TargetName="ThumbVisual" Property="Background" Value="{DynamicResource ReduxAccentBrush}" />
						</Trigger>
						<Trigger Property="IsDragging" Value="True">
							<Setter TargetName="ThumbVisual" Property="Background" Value="{DynamicResource ReduxAccentHoverBrush}" />
						</Trigger>
						<Trigger Property="IsEnabled" Value="False">
							<Setter TargetName="ThumbVisual" Property="Opacity" Value="0.35" />
						</Trigger>
					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
	<ControlTemplate x:Key="ReduxVerticalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
		<Grid Width="12" Background="Transparent">
			<Border x:Name="TrackRail"
				Width="3"
				HorizontalAlignment="Center"
				Background="{DynamicResource ReduxSurfaceMutedBrush}"
				CornerRadius="2"
				Opacity="0.45" />
			<Track x:Name="PART_Track"
				IsDirectionReversed="True"
				Orientation="Vertical">
				<Track.DecreaseRepeatButton>
					<RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Style="{StaticResource ReduxScrollPageButtonStyle}" />
				</Track.DecreaseRepeatButton>
				<Track.Thumb>
					<Thumb Style="{StaticResource ReduxVerticalScrollThumbStyle}" />
				</Track.Thumb>
				<Track.IncreaseRepeatButton>
					<RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Style="{StaticResource ReduxScrollPageButtonStyle}" />
				</Track.IncreaseRepeatButton>
			</Track>
		</Grid>
		<ControlTemplate.Triggers>
			<Trigger Property="IsMouseOver" Value="True">
				<Setter TargetName="TrackRail" Property="Opacity" Value="0.8" />
			</Trigger>
		</ControlTemplate.Triggers>
	</ControlTemplate>
	<ControlTemplate x:Key="ReduxHorizontalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
		<Grid Height="12" Background="Transparent">
			<Border x:Name="TrackRail"
				Height="3"
				VerticalAlignment="Center"
				Background="{DynamicResource ReduxSurfaceMutedBrush}"
				CornerRadius="2"
				Opacity="0.45" />
			<Track x:Name="PART_Track"
				IsDirectionReversed="False"
				Orientation="Horizontal">
				<Track.DecreaseRepeatButton>
					<RepeatButton Command="{x:Static ScrollBar.PageLeftCommand}" Style="{StaticResource ReduxScrollPageButtonStyle}" />
				</Track.DecreaseRepeatButton>
				<Track.Thumb>
					<Thumb Style="{StaticResource ReduxHorizontalScrollThumbStyle}" />
				</Track.Thumb>
				<Track.IncreaseRepeatButton>
					<RepeatButton Command="{x:Static ScrollBar.PageRightCommand}" Style="{StaticResource ReduxScrollPageButtonStyle}" />
				</Track.IncreaseRepeatButton>
			</Track>
		</Grid>
		<ControlTemplate.Triggers>
			<Trigger Property="IsMouseOver" Value="True">
				<Setter TargetName="TrackRail" Property="Opacity" Value="0.8" />
			</Trigger>
		</ControlTemplate.Triggers>
	</ControlTemplate>
	<Style TargetType="{x:Type ScrollBar}">
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="Focusable" Value="False" />
		<Setter Property="Template" Value="{StaticResource ReduxVerticalScrollBarTemplate}" />
		<Style.Triggers>
			<Trigger Property="Orientation" Value="Horizontal">
				<Setter Property="Template" Value="{StaticResource ReduxHorizontalScrollBarTemplate}" />
			</Trigger>
		</Style.Triggers>
	</Style>
	<Style TargetType="{x:Type controls:AutoGrayableImage}">
		<Setter Property="Width" Value="16" />
		<Setter Property="Height" Value="16" />
		<Setter Property="MaxWidth" Value="16" />
		<Setter Property="MaxHeight" Value="16" />
		<Setter Property="HorizontalAlignment" Value="Center" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="Stretch" Value="Uniform" />
		<Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality" />
		<Setter Property="SnapsToDevicePixels" Value="True" />
		<Setter Property="UseLayoutRounding" Value="True" />
	</Style>
	<Style x:Key="VerticalSeparator" TargetType="Rectangle">
		<Setter Property="Width" Value="1" />
		<Setter Property="Margin" Value="16,0,16,0" />
		<Setter Property="VerticalAlignment" Value="Stretch" />
		<Setter Property="Fill" Value="{DynamicResource {x:Static adonisUI:Brushes.DisabledForegroundBrush}}" />
	</Style>
	<ContextMenu x:Key="TextBoxContextMenu">
		<MenuItem Command="ApplicationCommands.Copy">
			<MenuItem.Icon><controls:ReduxIcon StrokeData="{StaticResource Redux.Icon.Copy}" /></MenuItem.Icon>
		</MenuItem>
		<MenuItem Command="ApplicationCommands.Cut">
			<MenuItem.Icon><controls:ReduxIcon StrokeData="{StaticResource Redux.Icon.Cut}" /></MenuItem.Icon>
		</MenuItem>
		<MenuItem Command="ApplicationCommands.Paste">
			<MenuItem.Icon><controls:ReduxIcon StrokeData="{StaticResource Redux.Icon.Clipboard}" /></MenuItem.Icon>
		</MenuItem>
		<MenuItem Command="{Binding Source={x:Static mm:AppCommands.Clear}}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" Header="Clear">
			<MenuItem.Icon><controls:ReduxIcon StrokeData="{StaticResource Redux.Icon.RemoveCircle}" Foreground="{DynamicResource ReduxErrorBrush}" /></MenuItem.Icon>
		</MenuItem>
	</ContextMenu>
	<Style BasedOn="{StaticResource {x:Type TextBox}}" TargetType="{x:Type controls:UnfocusableTextBox}">
		<Setter Property="ContextMenu" Value="{StaticResource TextBoxContextMenu}" />
	</Style>
	<Style BasedOn="{StaticResource {x:Type ToolTip}}" TargetType="{x:Type ToolTip}">
		<Setter Property="OverridesDefaultStyle" Value="True" />
		<Setter Property="HasDropShadow" Value="True" />
		<Setter Property="MaxWidth" Value="440" />
		<Setter Property="FontFamily" Value="{DynamicResource Redux.FontFamily.UI}" />
		<Setter Property="FontSize" Value="{DynamicResource Redux.FontSize.12}" />
		<Setter Property="Foreground" Value="{DynamicResource ReduxTextPrimaryBrush}" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="ToolTip">
					<ControlTemplate.Resources>
						<!-- Plain string tooltips wrap without forcing rich UIElement tooltips
						     through a text-only template. -->
						<DataTemplate DataType="{x:Type sys:String}">
							<TextBlock MaxWidth="400"
							    Text="{Binding}"
							    TextTrimming="None"
							    TextWrapping="Wrap" />
						</DataTemplate>
					</ControlTemplate.Resources>
					<Border Name="Border"
					    Padding="8,5"
					    Background="{DynamicResource ReduxSurfaceElevatedBrush}"
					    BorderBrush="{DynamicResource ReduxBorderBrush}"
					    BorderThickness="1"
					    CornerRadius="{DynamicResource Redux.CornerRadius.Card}">
						<ContentPresenter HorizontalAlignment="Left"
							VerticalAlignment="Top"
							RecognizesAccessKey="True" />
					</Border>
					<ControlTemplate.Triggers>
						<Trigger Property="HasDropShadow" Value="true">
							<Setter TargetName="Border" Property="SnapsToDevicePixels" Value="true" />
						</Trigger>
					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
	<!-- Rich safety/status tooltips provide their own themed card and must not inherit ordinary tooltip chrome. -->
	<Style x:Key="ReduxRichToolTipStyle" TargetType="{x:Type ToolTip}">
		<Setter Property="OverridesDefaultStyle" Value="True" />
		<Setter Property="HasDropShadow" Value="True" />
		<Setter Property="FontFamily" Value="{DynamicResource Redux.FontFamily.UI}" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="{x:Type ToolTip}">
					<ContentPresenter />
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
	<DataTemplate DataType="{x:Type data:DivinityProfileData}">
		<TextBlock Text="{Binding Name}" />
	</DataTemplate>
	<DataTemplate DataType="{x:Type data:DivinityLoadOrder}">
		<TextBlock Text="{Binding Name}" />
	</DataTemplate>
