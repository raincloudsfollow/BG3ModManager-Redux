	<!--
		Short, functional motion only: hover feedback and state transitions. StaticResource
		only in Storyboards/Timelines - DynamicResource there crashes when the owning
		Style/ControlTemplate is sealed (WPF cannot freeze a Timeline holding an expression).
	-->
	<Duration x:Key="Redux.Motion.Fast">0:0:0.12</Duration>
	<Duration x:Key="Redux.Motion.Standard">0:0:0.16</Duration>
	<Duration x:Key="Redux.Motion.Panel">0:0:0.30</Duration>
	<sys:Int32 x:Key="Redux.Motion.PanelMilliseconds">300</sys:Int32>
	<Duration x:Key="Redux.Motion.DialogEnter">0:0:0.18</Duration>
	<Duration x:Key="Redux.Motion.StatusPulseDuration">0:0:1.8</Duration>
	<QuadraticEase x:Key="Redux.Motion.EaseOut" EasingMode="EaseOut" />
	<CubicEase x:Key="Redux.Motion.EaseInOut" EasingMode="EaseInOut" />
	<SineEase x:Key="Redux.Motion.PanelEase" EasingMode="EaseInOut" />
	<sys:Double x:Key="Redux.Motion.HoverTranslateNegative">-1</sys:Double>
	<sys:Double x:Key="Redux.Motion.PressScale">0.98</sys:Double>
	<!-- Shared chrome for compact collapse/expand controls. Each caller supplies its directional chevron. -->
	<Style x:Key="ReduxChromeToggleStyle" TargetType="{x:Type ToggleButton}">
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="BorderThickness" Value="0" />
		<Setter Property="Cursor" Value="Hand" />
		<Setter Property="FocusVisualStyle" Value="{x:Null}" />
		<Setter Property="Foreground" Value="{DynamicResource ReduxTextSecondaryBrush}" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="{x:Type ToggleButton}">
					<Border Background="Transparent" CornerRadius="{DynamicResource Redux.CornerRadius.Control}">
						<Grid>
							<Border x:Name="HoverSurface"
								Width="24"
								Height="24"
								HorizontalAlignment="Center"
								VerticalAlignment="Center"
								Background="{DynamicResource ReduxAccentSoftBrush}"
								CornerRadius="{DynamicResource Redux.CornerRadius.Pill}"
								IsHitTestVisible="False"
								Opacity="0" />
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
						</Grid>
					</Border>
					<ControlTemplate.Triggers>
						<Trigger Property="IsMouseOver" Value="True">
							<Setter Property="Foreground" Value="{DynamicResource ReduxAccentHoverBrush}" />
							<Trigger.EnterActions>
								<BeginStoryboard>
									<Storyboard>
										<DoubleAnimation Storyboard.TargetName="HoverSurface"
											Storyboard.TargetProperty="Opacity"
											To="1"
											Duration="{StaticResource Redux.Motion.Fast}"
											EasingFunction="{StaticResource Redux.Motion.EaseOut}" />
									</Storyboard>
								</BeginStoryboard>
							</Trigger.EnterActions>
							<Trigger.ExitActions>
								<BeginStoryboard>
									<Storyboard>
										<DoubleAnimation Storyboard.TargetName="HoverSurface"
											Storyboard.TargetProperty="Opacity"
											To="0"
											Duration="{StaticResource Redux.Motion.Standard}" />
									</Storyboard>
								</BeginStoryboard>
							</Trigger.ExitActions>
						</Trigger>
						<Trigger Property="IsPressed" Value="True">
							<Setter TargetName="HoverSurface" Property="Background" Value="{DynamicResource ReduxPressedBrush}" />
						</Trigger>
					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
