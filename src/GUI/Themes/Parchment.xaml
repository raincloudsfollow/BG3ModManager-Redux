<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<!--
		Parchment intentionally reuses the shared Redux Light control mappings.
		Only semantic colors are overridden here; layouts, fonts, icons, templates,
		and behavior remain common to every built-in and future custom theme.
	-->
	<ResourceDictionary.MergedDictionaries>
		<ResourceDictionary Source="Light.xaml" />
	</ResourceDictionary.MergedDictionaries>

	<!-- Clean aged-paper hierarchy with dark ink and richer wax-seal emphasis. -->
	<Color x:Key="ReduxWindowColor">#E8DDC7</Color>
	<Color x:Key="ReduxListInteriorColor">#F4EAD6</Color>
	<Color x:Key="ReduxSurfaceColor">#EFE3CC</Color>
	<Color x:Key="ReduxSurfaceElevatedColor">#F7ECD8</Color>
	<Color x:Key="ReduxSurfaceMutedColor">#DDD0B8</Color>
	<Color x:Key="ReduxBorderColor">#BCA98B</Color>
	<Color x:Key="ReduxBorderStrongColor">#927B5B</Color>
	<Color x:Key="ReduxHoverColor">#E7D6B9</Color>
	<Color x:Key="ReduxPressedColor">#D8C4A3</Color>
	<Color x:Key="ReduxAccentColor">#8F2E32</Color>
	<Color x:Key="ReduxAccentHoverColor">#A84649</Color>
	<Color x:Key="ReduxAccentSoftColor">#E7C9C2</Color>
	<Color x:Key="ReduxSelectionColor">#DCB9B2</Color>
	<Color x:Key="ReduxCyanColor">#327D7B</Color>
	<Color x:Key="ReduxSuccessColor">#5E7D4B</Color>
	<Color x:Key="ReduxSuccessSoftColor">#D8E1C3</Color>
	<Color x:Key="ReduxWarningColor">#B8791D</Color>
	<Color x:Key="ReduxErrorColor">#A82F37</Color>
	<Color x:Key="ReduxInfoColor">#4E7196</Color>
	<Color x:Key="ReduxTextPrimaryColor">#30251D</Color>
	<Color x:Key="ReduxTextSecondaryColor">#5C4A3A</Color>
	<Color x:Key="ReduxTextMutedColor">#74614D</Color>
	<Color x:Key="ReduxAccentForegroundColor">#FFF7E8</Color>
</ResourceDictionary>
